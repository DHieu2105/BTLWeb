@model IEnumerable<BTL_Web.Models.KhoaHoc>

@{
    ViewData["Title"] = "Quản lý Khóa học";
}

<div class="container py-4">
    <h2 class="mb-3">Quản lý Khóa học</h2>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    <div class="d-flex justify-content-between align-items-center mb-3">
        <form method="get" class="d-flex" style="max-width: 360px;">
            <input class="form-control me-2" name="keyword" value="@ViewBag.Keyword" placeholder="Tìm theo mã hoặc tên khóa học" />
            <button class="btn btn-outline-primary" type="submit">Tìm</button>
        </form>
        <a asp-action="Create" class="btn btn-primary">Thêm khóa học</a>
    </div>

    <div class="table-responsive">
        <table class="table table-bordered table-hover align-middle">
            <thead class="table-light">
                <tr>
                    <th>Mã KH</th>
                    <th>Tên khóa học</th>
                    <th>Thời lượng</th>
                    <th>Học phí</th>
                    <th>Trung tâm</th>
                    <th style="width: 220px;">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.MaKhoaHoc</td>
                        <td>@item.TenKhoaHoc</td>
                        <td>@item.ThoiLuong</td>
                        <td>@item.HocPhi</td>
                        <td>@(item.MaTrungTamNavigation?.TenTrungTam ?? item.MaTrungTam)</td>
                        <td>
                            <a asp-action="Details" asp-route-id="@item.MaKhoaHoc" class="btn btn-sm btn-info">Chi tiết</a>
                            <a asp-action="Edit" asp-route-id="@item.MaKhoaHoc" class="btn btn-sm btn-warning">Sửa</a>
                            <a asp-action="Delete" asp-route-id="@item.MaKhoaHoc" class="btn btn-sm btn-danger">Xóa</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
