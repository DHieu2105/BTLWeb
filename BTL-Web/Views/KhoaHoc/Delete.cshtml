@model BTL_Web.Models.KhoaHoc

@{
    ViewData["Title"] = "Xóa Khóa học";
}

<div class="container py-4">
    <h2 class="mb-3 text-danger">Xóa Khóa học</h2>

    <div class="alert alert-warning">
        Bạn có chắc chắn muốn xóa khóa học này không?
    </div>

    <div class="card shadow-sm">
        <div class="card-body">
            <dl class="row mb-0">
                <dt class="col-sm-3">Mã khóa học</dt>
                <dd class="col-sm-9">@Model.MaKhoaHoc</dd>

                <dt class="col-sm-3">Tên khóa học</dt>
                <dd class="col-sm-9">@Model.TenKhoaHoc</dd>

                <dt class="col-sm-3">Trung tâm</dt>
                <dd class="col-sm-9">@(Model.MaTrungTamNavigation?.TenTrungTam ?? Model.MaTrungTam)</dd>
            </dl>
        </div>
    </div>

    <form asp-action="Delete" method="post" class="mt-3">
        <input type="hidden" name="id" value="@Model.MaKhoaHoc" />
        <button type="submit" class="btn btn-danger">Xác nhận xóa</button>
        <a asp-action="Index" class="btn btn-secondary">Hủy</a>
    </form>
</div>
