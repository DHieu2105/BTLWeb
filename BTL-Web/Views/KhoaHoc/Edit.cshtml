@model BTL_Web.ViewModels.KhoaHocFormViewModel

@{
    ViewData["Title"] = "Sửa Khóa học";
}

<div class="container py-4">
    <h2 class="mb-3">Sửa Khóa học</h2>

    <form asp-action="Edit" method="post" class="card p-3 shadow-sm">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>

        <input asp-for="MaKhoaHoc" type="hidden" />

        <div class="row g-3">
            <div class="col-md-4">
                <label class="form-label">Mã khóa học</label>
                <input value="@Model.MaKhoaHoc" class="form-control" disabled />
            </div>
            <div class="col-md-8">
                <label asp-for="TenKhoaHoc" class="form-label"></label>
                <input asp-for="TenKhoaHoc" class="form-control" />
                <span asp-validation-for="TenKhoaHoc" class="text-danger"></span>
            </div>

            <div class="col-md-4">
                <label asp-for="ThoiLuong" class="form-label"></label>
                <input asp-for="ThoiLuong" class="form-control" />
                <span asp-validation-for="ThoiLuong" class="text-danger"></span>
            </div>
            <div class="col-md-4">
                <label asp-for="HocPhi" class="form-label"></label>
                <input asp-for="HocPhi" class="form-control" />
                <span asp-validation-for="HocPhi" class="text-danger"></span>
            </div>
            <div class="col-md-4">
                <label asp-for="MaTrungTam" class="form-label"></label>
                <select asp-for="MaTrungTam" asp-items="Model.TrungTamOptions" class="form-select">
                    <option value="">-- Chọn trung tâm --</option>
                </select>
                <span asp-validation-for="MaTrungTam" class="text-danger"></span>
            </div>
        </div>

        <div class="mt-3">
            <button type="submit" class="btn btn-primary">Cập nhật</button>
            <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
