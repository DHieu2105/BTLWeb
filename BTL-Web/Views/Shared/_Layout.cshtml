<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - Academic Editorial</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
</head>
<body class="app-wrapper">
    @await Html.PartialAsync("_Sidebar")

    <div class="main-content">
        @await Html.PartialAsync("_Navbar")

        <main class="page-content container-fluid p-4">
            @RenderBody() </main>

        <footer class="mt-auto py-3 bg-light border-top">
            <div class="container-fluid text-center">
                <p class="text-muted mb-0">
                    <i class="fas fa-copyright me-1"></i>2026 English Center Management System. All rights reserved.
                </p>
            </div>
        </footer>
    </div>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
