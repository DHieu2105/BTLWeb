@using System.Security.Claims
@{
    var action = ViewContext.RouteData.Values["Action"]?.ToString() ?? "";
    var controller = ViewContext.RouteData.Values["Controller"]?.ToString() ?? "";
    var currentRole = User.FindFirst(ClaimTypes.Role)?.Value ?? "";
    var navSection = controller switch
    {
        "Admin" => "Admin",
        "Staff" => "NhanVien",
        "Teacher" => "GiaoVien",
        "Student" => "HocVien",
        _ => currentRole
    };
    string IsActive(string a, string c = "") => (action == a && (string.IsNullOrEmpty(c) || controller == c)) ? "active" : "";
}

<aside class="sidebar">
    <div class="sidebar-brand">
        <div class="brand-logo">
            <i class="fas fa-graduation-cap"></i>
        </div>
        <div class="brand-text">
            <div class="brand-title">Academic<br>Editorial</div>
            <div class="brand-subtitle">Management Suite</div>
        </div>
    </div>

    <nav class="sidebar-nav">
        @if (navSection == "Admin")
        {
            <div style="margin:8px 12px 6px;color:rgba(255,255,255,0.55);font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.6px;">Tổng quan</div>
            <a href="/Admin/Index" class="nav-item @IsActive("Index","Admin")">
                <i class="fas fa-chart-line"></i> Dashboard
            </a>

            <div style="margin:10px 12px 6px;color:rgba(255,255,255,0.55);font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.6px;">Quản lý Trung tâm & Cơ sở vật chất</div>
            <a href="/Admin/TrungTam" class="nav-item @IsActive("TrungTam")">
                <i class="fas fa-building"></i> Quản lý Trung tâm
            </a>
            <a href="/Admin/PhongHoc" class="nav-item @IsActive("PhongHoc")">
                <i class="fas fa-door-open"></i> Quản lý Phòng học
            </a>
            <a href="/Admin/ThietBi" class="nav-item @IsActive("ThietBi")">
                <i class="fas fa-laptop"></i> Quản lý Thiết bị
