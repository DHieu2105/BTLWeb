            <div style="margin:10px 12px 6px;color:rgba(255,255,255,0.55);font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.6px;">Quản lý Giáo viên & Phân công</div>
            <a href="/Admin/GiaoVien" class="nav-item @IsActive("GiaoVien","Admin")">
                <i class="fas fa-chalkboard-teacher"></i> Xem danh sách Giáo viên
            </a>
            <a href="/Admin/StaffTeacherAssignment" class="nav-item @IsActive("StaffTeacherAssignment","Admin")">
                <i class="fas fa-people-arrows"></i> Xem phân công
            </a>

            <div style="margin:10px 12px 6px;color:rgba(255,255,255,0.55);font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.6px;">Báo cáo cá nhân</div>
            <a href="/Staff/StudentManagement#mine" class="nav-item @IsActive("StudentManagement")">
