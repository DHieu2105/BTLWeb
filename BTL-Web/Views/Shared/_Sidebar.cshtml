            <a href="/Teacher/Index" class="nav-item @IsActive("Index","Teacher")">
                <i class="fas fa-th-large"></i> Dashboard
            </a>

            <div style="margin:10px 12px 6px;color:rgba(255,255,255,0.55);font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.6px;">Lớp học của tôi</div>
            <a href="/Teacher/MyClasses" class="nav-item @IsActive("MyClasses")">
