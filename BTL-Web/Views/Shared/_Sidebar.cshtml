            <a href="/Auth/Profile" class="nav-item @IsActive("Profile","Auth")">
                <i class="fas fa-user-circle"></i> Hồ sơ cá nhân
            </a>

            <div style="margin:10px 12px 6px;color:rgba(255,255,255,0.55);font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.6px;">Tài khoản</div>
            <a href="/Auth/Profile#register" class="nav-item @IsActive("Profile","Auth")">
                <i class="fas fa-file-signature"></i> Đăng ký khóa học mới
            </a>
            <a href="/Auth/Profile#security" class="nav-item @IsActive("Profile","Auth")">
                <i class="fas fa-key"></i> Đổi mật khẩu
            </a>
