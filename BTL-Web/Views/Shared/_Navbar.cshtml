@using System.Security.Claims
@inject Microsoft.AspNetCore.Hosting.IWebHostEnvironment WebHostEnvironment
@{
    var role = User.FindFirst(ClaimTypes.Role)?.Value ?? "";
    var controller = ViewContext.RouteData.Values["Controller"]?.ToString() ?? "";
    var action = ViewContext.RouteData.Values["Action"]?.ToString() ?? "";
    var navSection = role;
    if (controller == "Admin" && role == "Admin")
    {
        navSection = "Admin";
    }
    else if (controller == "Staff")
    {
        navSection = "NhanVien";
    }
    else if (controller == "Teacher")
    {
        navSection = "GiaoVien";
    }
    else if (controller == "Student")
    {
        navSection = "HocVien";
    }
    var roleDisplay = navSection switch {
        "Admin" => "Quản Trị Viên",
        "NhanVien" => "Nhân Viên",
        "GiaoVien" => "Giáo Viên",
        "HocVien" => "Học Viên",
        _ => "Người Dùng"
    };
    var name = User.Identity?.Name ?? "User";
    var initials = string.Join("", name.Split(' ').Take(2).Select(w => w.FirstOrDefault().ToString().ToUpper()));
    string? profileImageUrl = null;

    var imageKey = navSection switch
    {
        "Admin" => $"admin-{User.FindFirst(ClaimTypes.NameIdentifier)?.Value}",
        "NhanVien" => !string.IsNullOrWhiteSpace(User.FindFirst("MaNV")?.Value)
            ? $"nhanvien-{User.FindFirst("MaNV")?.Value}"
            : $"nhanvien-{User.FindFirst(ClaimTypes.NameIdentifier)?.Value}",
        "GiaoVien" => !string.IsNullOrWhiteSpace(User.FindFirst("MaGV")?.Value)
            ? $"giaovien-{User.FindFirst("MaGV")?.Value}"
            : $"giaovien-{User.FindFirst(ClaimTypes.NameIdentifier)?.Value}",
        "HocVien" => !string.IsNullOrWhiteSpace(User.FindFirst("MaHocVien")?.Value)
            ? $"hocvien-{User.FindFirst("MaHocVien")?.Value}"
            : $"hocvien-{User.FindFirst(ClaimTypes.NameIdentifier)?.Value}",
        _ => null
    };

    if (!string.IsNullOrWhiteSpace(imageKey))
    {
        var uploadDir = System.IO.Path.Combine(WebHostEnvironment.WebRootPath, "uploads", "profiles");
        if (System.IO.Directory.Exists(uploadDir))
        {
            var allowed = new[] { ".jpg", ".jpeg", ".png", ".webp" };
            foreach (var ext in allowed)
            {
                var fileName = $"{imageKey}{ext}";
                var fullPath = System.IO.Path.Combine(uploadDir, fileName);
                if (System.IO.File.Exists(fullPath))
                {
                    profileImageUrl = $"/uploads/profiles/{fileName}?v={DateTimeOffset.UtcNow.ToUnixTimeSeconds()}";
                    break;
                }
            }
        }
    }
    var overviewUrl = navSection switch
    {
        "Admin" => "/Admin/Index",
        "NhanVien" => "/Staff/Index",
        "GiaoVien" => "/Admin/MyTeacherProfile",
        "HocVien" => "/Student/Index",
        _ => "/Home/Index"
    };
    var featureUrl = navSection switch
    {
        "Admin" => "/Admin/TrungTam",
        "NhanVien" => "/Staff/TeacherManagement",
        "GiaoVien" => "/Teacher/MyCourses",
        "HocVien" => "/Student/MyCourses",
        _ => "/Home/Index"
    };
    var reportsUrl = navSection switch
    {
        "Admin" => "/Admin/ReportCenter",
        "NhanVien" => "/Staff/RevenueReport",
        "GiaoVien" => "/Auth/Profile",
        "HocVien" => "/Student/Results",
        _ => "/Home/Index"
    };
    var featureLabel = navSection switch
    {
        "Admin" => "Trung tâm & CSVC",
        "NhanVien" => "Giáo viên",
        "GiaoVien" => "Khóa học",
        "HocVien" => "Khóa học",
        _ => "Tính năng"
    };
    var reportsLabel = navSection switch
    {
        "Admin" => "Báo cáo",
        "NhanVien" => "Báo cáo",
        "GiaoVien" => "Tài khoản",
        "HocVien" => "Kết quả",
        _ => "Báo cáo"
    };

    var activeTab = "overview";
    if (navSection == "Admin")
    {
        var featureActions = new HashSet<string>(StringComparer.OrdinalIgnoreCase)
        {
            "TrungTam", "PhongHoc", "ThietBi", "LichHoc"
        };
        var reportActions = new HashSet<string>(StringComparer.OrdinalIgnoreCase)
        {
            "ReportCenter", "RevenueReport"
        };

        if (controller.Equals("Admin", StringComparison.OrdinalIgnoreCase) && reportActions.Contains(action))
        {
            activeTab = "reports";
        }
        else if (controller.Equals("Admin", StringComparison.OrdinalIgnoreCase) && featureActions.Contains(action))
        {
            activeTab = "feature";
        }
        else
        {
            activeTab = "overview";
        }
    }
    else
    {
        var currentPath = Context.Request.Path.Value ?? string.Empty;
        if (!string.IsNullOrWhiteSpace(reportsUrl) && currentPath.StartsWith(reportsUrl, StringComparison.OrdinalIgnoreCase))
        {
            activeTab = "reports";
        }
        else if (!string.IsNullOrWhiteSpace(featureUrl) && currentPath.StartsWith(featureUrl, StringComparison.OrdinalIgnoreCase))
        {
            activeTab = "feature";
        }
        else
        {
            activeTab = "overview";
        }
    }
}

<nav class="top-navbar">
    <div style="display:flex;align-items:center;gap:24px;flex:1;">
        <button type="button" class="mobile-menu-toggle" aria-label="Mở menu điều hướng" data-sidebar-toggle>
            <i class="fas fa-bars" style="font-size:16px;"></i>
        </button>
        <div class="search-box" style="max-width:360px;">
            <i class="fas fa-search"></i>
            <input type="text" placeholder="Tìm kiếm học viên, nhân viên hoặc tài nguyên...">
        </div>
        <div class="navbar-nav-links">
            <a href="@overviewUrl" class="@(activeTab == "overview" ? "active" : "")">Bảng điều khiển</a>
            <a href="@featureUrl" class="@(activeTab == "feature" ? "active" : "")">@featureLabel</a>
            <a href="@reportsUrl" class="@(activeTab == "reports" ? "active" : "")">@reportsLabel</a>
        </div>
    </div>

    <div class="navbar-actions">
        <a class="navbar-btn" title="Thông báo" href="@overviewUrl">
            <i class="far fa-bell" style="font-size:16px;"></i>
            <span class="badge-dot"></span>
        </a>
        <a class="navbar-btn" title="Tin nhắn" href="/Auth/Profile">
            <i class="far fa-comment-alt" style="font-size:16px;"></i>
        </a>
        <div class="navbar-divider"></div>
        <a class="user-info" href="/Auth/Profile" style="text-decoration:none;color:inherit;">
            <div class="user-text">
                <div class="user-name">@name</div>
                <div class="user-role">@roleDisplay</div>
            </div>
            <div class="user-avatar">
                @if (!string.IsNullOrWhiteSpace(profileImageUrl))
                {
                    <img src="@profileImageUrl" alt="Ảnh hồ sơ" />
                }
                else
                {
                    @initials
                }
            </div>
        </a>
    </div>
</nav>
