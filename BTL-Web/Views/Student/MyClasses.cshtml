@model IEnumerable<BTL_Web.Models.LopHoc>
@{
    ViewData["Title"] = "My Classes";
}

<div class="page-header">
    <div>
        <h2>My Classes</h2>
        <p>All classes you are currently enrolled in</p>
    </div>
    <div class="page-actions">
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
            <div class="card-plain" style="padding:16px;text-align:center;">
                <div class="stat-value" style="font-size:20px;">@(Model?.Count() ?? 0)</div>
                <div class="stat-label">Classes</div>
            </div>
            <div class="card-plain" style="padding:16px;text-align:center;">
                <div class="stat-value" style="font-size:20px;">@(Model?.Sum(l => l.MaHocViens.Count) ?? 0)</div>
                <div class="stat-label">Classmates</div>
            </div>
        </div>
    </div>
</div>

<!-- Featured Class -->
@{
    var featured = Model?.FirstOrDefault();
}
@if (featured != null)
{
    <div class="card-plain" style="padding:0;margin-bottom:24px;display:grid;grid-template-columns:1fr 1fr;overflow:hidden;">
        <div style="padding:32px;border-left:6px solid var(--primary);">
            <div style="display:flex;gap:8px;margin-bottom:16px;">
                <span class="chip chip-green">Active</span>
                <span class="chip chip-blue">@(featured.MaKhoaHocNavigation?.TenKhoaHoc ?? "—")</span>
            </div>
            <h3 style="font-size:22px;margin-bottom:8px;">@(featured.TenLop ?? featured.MaLop)</h3>
            <p class="text-muted" style="margin-bottom:20px;font-size:14px;">Advanced course with focus on structural analysis and professional communication.</p>
            <div style="display:flex;gap:24px;margin-bottom:20px;">
                <div>
                    <div class="stat-label">Teacher</div>
                    <div class="user-name" style="font-size:14px;">@(featured.MaGvNavigation?.Ten ?? "—")</div>
                </div>
                <div>
                    <div class="stat-label">Room</div>
                    <div class="user-name" style="font-size:14px;">@(featured.MaPhongNavigation?.TenPhong ?? "TBD")</div>
                </div>
                <div>
                    <div class="stat-label">Students</div>
                    <div class="user-name" style="font-size:14px;">@featured.MaHocViens.Count</div>
                </div>
            </div>
            <div style="display:flex;gap:8px;">
                <a href="/Student/Schedule" class="btn-primary btn-sm"><i class="fas fa-calendar"></i> View Schedule</a>
                <a href="/Student/Results" class="btn-outline btn-sm"><i class="fas fa-poll-h"></i> My Results</a>
            </div>
        </div>
        <div style="background:linear-gradient(135deg,var(--sidebar-bg),var(--primary));display:flex;align-items:center;justify-content:center;position:relative;overflow:hidden;">
            <i class="fas fa-graduation-cap" style="font-size:100px;color:rgba(255,255,255,0.1);"></i>
        </div>
    </div>
}

<!-- All Classes -->
<div class="card-plain" style="padding:0;margin-bottom:24px;">
    <div class="card-header-plain">
        <h5>All My Classes</h5>
        <div style="display:flex;gap:8px;">
            <button class="filter-btn active">All</button>
            <button class="filter-btn">Active</button>
            <button class="filter-btn">Completed</button>
        </div>
    </div>
    <table class="data-table">
        <thead>
            <tr>
                <th>Class</th>
                <th>Course</th>
                <th>Teacher</th>
                <th>Room</th>
                <th>Classmates</th>
                <th>Status</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                @foreach (var lop in Model)
                {
                    <tr>
                        <td>
                            <div class="user-name">@(lop.TenLop ?? lop.MaLop)</div>
                            <div class="user-sub">@lop.MaLop</div>
                        </td>
                        <td class="user-sub">@(lop.MaKhoaHocNavigation?.TenKhoaHoc ?? "—")</td>
                        <td>
                            <div class="user-row">
                                <div class="avatar avatar-sm">@(string.Join("", (lop.MaGvNavigation?.Ten ?? "?").Split(' ').Take(2).Select(w => w.FirstOrDefault().ToString().ToUpper())))</div>
                                <div class="user-name" style="font-size:13px;">@(lop.MaGvNavigation?.Ten ?? "—")</div>
                            </div>
                        </td>
                        <td class="user-sub">@(lop.MaPhongNavigation?.TenPhong ?? "—")</td>
                        <td><span class="chip chip-blue">@lop.MaHocViens.Count</span></td>
                        <td><span class="chip chip-green">Active</span></td>
                    </tr>
                }
            }
            else
            {
                <tr><td colspan="6"><div class="empty-state"><i class="fas fa-graduation-cap"></i><p>No classes enrolled</p></div></td></tr>
            }
        </tbody>
    </table>
</div>

<!-- Achievement + Attendance -->
<div style="display:grid;grid-template-columns:1fr 2fr;gap:24px;">
    <div class="card-plain" style="padding:32px;background:linear-gradient(135deg,rgba(43,84,191,0.05),rgba(73,110,218,0.1));border:1px solid rgba(43,84,191,0.15);">
        <div style="font-size:40px;color:rgba(43,84,191,0.3);margin-bottom:12px;"><i class="fas fa-trophy"></i></div>
        <h4 style="margin-bottom:8px;">Academic Achievement</h4>
        <p class="text-muted small" style="margin-bottom:16px;">You are 15 points away from the 'Platinum Scholar' badge. Complete the Literature Review by Friday!</p>
        <div class="progress-bar-wrap" style="margin-bottom:8px;"><div class="progress-bar-fill" style="width:85%;"></div></div>
        <span class="smaller text-muted">85% to next milestone</span>
    </div>

    <div class="card-plain" style="padding:32px;">
        <div class="section-heading">
            <h4>Attendance Overview</h4>
        </div>
        <div style="display:flex;align-items:flex-end;gap:8px;height:120px;margin-top:16px;">
            @{
                var bars = new[] { 90, 85, 95, 88, 100, 92 };
                var months = new[] { "Jan", "Feb", "Mar", "Apr", "May", "Jun" };
            }
            @for (int i = 0; i < bars.Length; i++)
            {
                <div style="flex:1;display:flex;flex-direction:column;align-items:center;gap:6px;">
                    <div style="width:100%;background:@(i == bars.Length-1 ? "var(--primary)" : "rgba(219,225,255,0.3)");border-radius:4px 4px 0 0;height:@(bars[i])px;"></div>
                    <span class="smaller text-muted">@months[i]</span>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
<script>
document.querySelectorAll('.filter-btn').forEach(btn => {
    btn.addEventListener('click', function() {
        document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
        this.classList.add('active');
    });
});
</script>
}
