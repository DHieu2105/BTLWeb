@model IEnumerable<BTL_Web.Models.DangKi>
@{
    ViewData["Title"] = "My Courses";
}

<div class="page-header">
    <div>
        <h2>My Courses</h2>
        <p>Your enrolled courses and academic progress</p>
    </div>
    <div class="page-actions">
        <button class="btn-outline"><i class="fas fa-filter"></i> Filter</button>
    </div>
</div>

<!-- Current Courses -->
<div style="margin-bottom:32px;">
    <div style="display:flex;align-items:center;gap:12px;margin-bottom:16px;">
        <span class="chip chip-green">Active</span>
        <h4>Current Courses</h4>
    </div>
    <div style="display:grid;grid-template-columns:2fr 1fr;gap:24px;">
        @{
            var activeCourses = Model?.Take(2).ToList();
        }
        @if (activeCourses != null && activeCourses.Any())
        {
            var first = activeCourses.First();
            <div class="card-plain" style="padding:0;display:grid;grid-template-columns:1fr 1fr;overflow:hidden;">
                <div style="padding:32px;">
                    <span class="chip chip-green" style="margin-bottom:16px;">Enrolled</span>
                    <h3 style="font-size:22px;margin-bottom:8px;">@(first.MaKhoaHocNavigation?.TenKhoaHoc ?? "—")</h3>
                    <p class="text-muted" style="margin-bottom:20px;font-size:14px;">Academic course information</p>
                    <div style="margin-bottom:16px;">
                        <div style="display:flex;justify-content:space-between;margin-bottom:6px;">
                            <span class="small">Progress</span><span class="small fw-bold">67%</span>
                        </div>
                        <div class="progress-bar-wrap"><div class="progress-bar-fill" style="width:67%;"></div></div>
                    </div>
                    <div style="display:flex;gap:16px;margin-bottom:20px;">
                        <div><div class="stat-label">Course ID</div><div class="user-name" style="font-size:13px;">@(first.MaKhoaHoc ?? "—")</div></div>
                        <div><div class="stat-label">Registered</div><div class="user-name" style="font-size:13px;">@(first.NgayDangKi?.ToString("dd/MM/yyyy") ?? "TBD")</div></div>
                    </div>
                    <a href="/Student/MyClasses" class="btn-primary btn-sm"><i class="fas fa-arrow-right"></i> View Class</a>
                </div>
                <div style="background:linear-gradient(135deg,var(--sidebar-bg),var(--primary));display:flex;align-items:center;justify-content:center;">
                    <i class="fas fa-book-open" style="font-size:80px;color:rgba(255,255,255,0.15);"></i>
                </div>
            </div>

            @if (activeCourses.Count > 1)
            {
                var second = activeCourses[1];
                <div class="card-plain" style="padding:32px;">
                    <span class="chip chip-blue" style="margin-bottom:16px;">Enrolled</span>
                    <h4 style="margin-bottom:8px;">@(second.MaKhoaHocNavigation?.TenKhoaHoc ?? "—")</h4>
                    <p class="text-muted" style="font-size:13px;margin-bottom:20px;">Academic course information</p>
                    <div style="margin-bottom:16px;">
                        <div style="display:flex;justify-content:space-between;margin-bottom:6px;">
                            <span class="small">Progress</span><span class="small fw-bold">50%</span>
                        </div>
                        <div class="progress-bar-wrap"><div class="progress-bar-fill" style="width:50%;"></div></div>
                    </div>
                    <div style="display:flex;align-items:center;gap:8px;">
                        <div class="stat-icon teal" style="width:32px;height:32px;border-radius:8px;font-size:12px;"><i class="fas fa-clock"></i></div>
                        <span class="small text-muted">@(second.NgayDangKi?.ToString("dd/MM/yyyy") ?? "TBD")</span>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="card-plain" style="padding:32px;">
                <div class="empty-state"><i class="fas fa-book"></i><p>No active courses</p></div>
            </div>
        }
    </div>
</div>

<!-- Completed Courses Table -->
<div class="card-plain" style="padding:0;">
    <div class="card-header-plain">
        <div style="display:flex;align-items:center;gap:12px;">
            <span class="chip chip-gray">Completed</span>
            <h5>Course History</h5>
        </div>
    </div>
    <table class="data-table">
        <thead>
            <tr>
                <th>Course Name</th>
                <th>Instructor</th>
                <th>Duration</th>
                <th>Enrollment Date</th>
                <th>Grade</th>
                <th style="text-align:right;">Certificate</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                @foreach (var dk in Model)
                {
                    <tr>
                        <td>
                            <div class="user-name">@(dk.MaKhoaHocNavigation?.TenKhoaHoc ?? "—")</div>
                            <div class="user-sub">@(dk.MaKhoaHoc ?? "—")</div>
                        </td>
                        <td>—</td>
                        <td>@(dk.MaKhoaHocNavigation?.ThoiLuong ?? 0) weeks</td>
                        <td class="user-sub">@(dk.NgayDangKi?.ToString("MMM dd, yyyy") ?? "—")</td>
                        <td><span class="chip chip-green">A</span></td>
                        <td style="text-align:right;">
                            <button class="btn-icon btn-outline btn-sm" title="Download Certificate">
                                <i class="fas fa-download"></i>
                            </button>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr><td colspan="6"><div class="empty-state"><i class="fas fa-certificate"></i><p>No course history</p></div></td></tr>
            }
        </tbody>
    </table>
</div>
