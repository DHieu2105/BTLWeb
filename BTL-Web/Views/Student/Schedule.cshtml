@model IEnumerable<BTL_Web.Models.LopHoc>
@{
    ViewData["Title"] = "My Schedule";
}

<div class="page-header">
    <div>
        <h2>My Schedule</h2>
        <p>Your weekly class timetable and upcoming sessions</p>
    </div>
    <div class="page-actions">
        <button class="btn-outline"><i class="fas fa-download"></i> Export</button>
        <button class="btn-primary"><i class="fas fa-calendar-plus"></i> Request Session</button>
    </div>
</div>

<!-- Stats -->
<div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:16px;margin-bottom:24px;">
    <div class="card-plain" style="padding:20px;border-left:4px solid var(--primary);">
        <div class="stat-label">Classes This Week</div>
        <div class="stat-value" style="margin-top:4px;">@(Model?.Count() ?? 0)</div>
    </div>
    <div class="card-plain" style="padding:20px;border-left:4px solid #0891b2;">
        <div class="stat-label">Credits</div>
        <div class="stat-value" style="margin-top:4px;">45.0</div>
    </div>
    <div class="card-plain" style="padding:20px;background:var(--sidebar-bg);color:white;">
        <div class="stat-label" style="color:rgba(255,255,255,0.6);">Next Exam</div>
        <div class="stat-value" style="color:white;font-size:16px;margin-top:4px;">Phonetics Lab</div>
        <div class="smaller" style="color:rgba(255,255,255,0.6);margin-top:4px;">March 22nd • 10:00 AM</div>
    </div>
</div>

<!-- Weekly Calendar -->
<div class="card-plain" style="padding:0;margin-bottom:24px;">
    <div style="padding:20px 24px;border-bottom:1px solid var(--surface-low);display:flex;align-items:center;justify-content:space-between;">
        <div style="display:flex;align-items:center;gap:12px;">
            <button class="btn-icon btn-outline"><i class="fas fa-chevron-left"></i></button>
            <h5>@DateTime.Now.ToString("MMMM yyyy")</h5>
            <button class="btn-icon btn-outline"><i class="fas fa-chevron-right"></i></button>
        </div>
        <div style="background:var(--surface-high);border-radius:8px;padding:4px;display:flex;gap:4px;">
            <button class="filter-btn active">Week</button>
            <button class="filter-btn">Month</button>
        </div>
    </div>

    <!-- Day Headers -->
    <div style="display:grid;grid-template-columns:80px repeat(5,1fr);border-bottom:1px solid var(--surface-low);">
        <div></div>
        @{
            var days = new[] { "Monday", "Tuesday", "Wednesday", "Thursday", "Friday" };
            var today = (int)DateTime.Now.DayOfWeek - 1;
        }
        @for (int i = 0; i < 5; i++)
        {
            var isToday = today == i;
            <div style="padding:12px;text-align:center;@(isToday ? "background:rgba(43,84,191,0.05);" : "")">
                <div class="smaller text-muted">@days[i].Substring(0,3).ToUpper()</div>
                <div style="font-size:20px;font-weight:800;color:@(isToday ? "var(--primary)" : "var(--on-surface)");">
                    @DateTime.Now.AddDays(i - today).Day
                </div>
            </div>
        }
    </div>

    <!-- Time Slots -->
    @{
        var slots = new[] { "08:00", "09:00", "10:00", "11:00", "12:00", "13:00", "14:00", "15:00" };
        var classList = Model?.ToList() ?? new List<BTL_Web.Models.LopHoc>();
    }
    @foreach (var slot in slots)
    {
        <div style="display:grid;grid-template-columns:80px repeat(5,1fr);border-bottom:1px solid var(--surface-low);min-height:64px;">
            <div style="padding:8px 12px;font-size:12px;color:var(--outline);text-align:right;padding-top:12px;">@slot</div>
            @for (int d = 0; d < 5; d++)
            {
                var isToday = today == d;
                var showClass = classList.Count > d && slot == "09:00";
                <div style="padding:4px;@(isToday ? "background:rgba(43,84,191,0.03);" : "")border-left:1px solid var(--surface-low);">
                    @if (showClass)
                    {
                        var lop = classList[d % classList.Count];
                        var color = isToday ? "var(--primary)" : "#0891b2";
                        <div style="background:rgba(43,84,191,0.08);border-left:3px solid @color;border-radius:4px;padding:8px;height:100%;">
                            <div class="user-name" style="font-size:11px;">@(lop.TenLop ?? lop.MaLop)</div>
                            <div class="user-sub" style="font-size:10px;">@(lop.MaGvNavigation?.Ten ?? "—")</div>
                            <div class="user-sub" style="font-size:10px;">@(lop.MaPhongNavigation?.TenPhong ?? "—")</div>
                        </div>
                    }
                </div>
            }
        </div>
    }
</div>

<!-- Tutors + Progress -->
<div style="display:grid;grid-template-columns:1fr 2fr;gap:24px;">
    <div class="card-plain" style="padding:24px;">
        <div class="section-heading">
            <h5><i class="fas fa-chalkboard-teacher" style="color:var(--primary);margin-right:8px;"></i>My Tutors</h5>
        </div>
        @foreach (var lop in (Model ?? new List<BTL_Web.Models.LopHoc>()).Take(3))
        {
            var gvName = lop.MaGvNavigation?.Ten ?? "—";
            var ini = string.Join("", gvName.Split(' ').Take(2).Select(w => w.FirstOrDefault().ToString().ToUpper()));
            <div style="display:flex;align-items:center;justify-content:space-between;padding:10px;background:var(--surface-low);border-radius:8px;margin-bottom:8px;">
                <div class="user-row">
                    <div class="avatar avatar-sm">@ini</div>
                    <div>
                        <div class="user-name" style="font-size:13px;">@gvName</div>
                        <div class="user-sub">@(lop.MaKhoaHocNavigation?.TenKhoaHoc ?? "—")</div>
                    </div>
                </div>
                <button class="btn-icon btn-outline btn-sm"><i class="fas fa-comment"></i></button>
            </div>
        }
        @if (!(Model?.Any() ?? false))
        {
            <div class="empty-state" style="padding:16px;"><i class="fas fa-chalkboard-teacher"></i><p>No tutors assigned</p></div>
        }
    </div>

    <div class="card-plain" style="padding:24px;">
        <div class="section-heading">
            <h5>Learning Progress</h5>
            <a href="/Student/Results">View Results</a>
        </div>
        <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:12px;">
            <div style="padding:16px;background:var(--surface-low);border-radius:8px;text-align:center;">
                <div class="stat-label">Attendance</div>
                <div class="stat-value" style="font-size:22px;margin-top:4px;">94%</div>
                <div class="progress-bar-wrap" style="margin-top:8px;"><div class="progress-bar-fill" style="width:94%;"></div></div>
            </div>
            <div style="padding:16px;background:var(--surface-low);border-radius:8px;text-align:center;">
                <div class="stat-label">Credits</div>
                <div class="stat-value" style="font-size:22px;margin-top:4px;">45</div>
                <div class="progress-bar-wrap" style="margin-top:8px;"><div class="progress-bar-fill" style="width:75%;"></div></div>
            </div>
            <div style="padding:16px;background:var(--sidebar-bg);border-radius:8px;text-align:center;position:relative;overflow:hidden;">
                <div class="stat-label" style="color:rgba(255,255,255,0.6);">Next Exam</div>
                <div class="stat-value" style="font-size:16px;color:white;margin-top:4px;">Phonetics</div>
                <div class="smaller" style="color:rgba(255,255,255,0.6);margin-top:4px;">Mar 22</div>
                <i class="fas fa-calendar" style="position:absolute;right:-10px;bottom:-10px;font-size:50px;color:rgba(255,255,255,0.05);"></i>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
document.querySelectorAll('.filter-btn').forEach(btn => {
    btn.addEventListener('click', function() {
        this.closest('div').querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
        this.classList.add('active');
    });
});
</script>
}
