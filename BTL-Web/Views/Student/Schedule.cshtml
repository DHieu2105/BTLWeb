@model IEnumerable<BTL_Web.Models.LichHoc>
@{
    ViewData["Title"] = "My Schedule";

    var sessions = (Model ?? Enumerable.Empty<BTL_Web.Models.LichHoc>())
        .OrderBy(s => s.NgayHoc)
        .ThenBy(s => s.GioBatDau)
        .ToList();

    var today = DateOnly.FromDateTime(DateTime.Now);
    var weekStart = today.AddDays(-(int)today.DayOfWeek + ((int)today.DayOfWeek == 0 ? -6 : 1));
    var weekEnd = weekStart.AddDays(6);
    var todayCount = sessions.Count(s => s.NgayHoc == today);
    var weekCount = sessions.Count(s => s.NgayHoc.HasValue && s.NgayHoc.Value >= weekStart && s.NgayHoc.Value <= weekEnd);
    var monthCount = sessions.Count(s => s.NgayHoc.HasValue && s.NgayHoc.Value.Month == today.Month && s.NgayHoc.Value.Year == today.Year);
    var nextSession = sessions.FirstOrDefault(s => s.NgayHoc.HasValue && s.NgayHoc.Value >= today);
    var timetableDays = Enumerable.Range(0, 5).Select(offset => weekStart.AddDays(offset)).ToList();
    var timetableSlots = Enumerable.Range(8, 10).ToList();
}

<div class="page-header">
    <div>
        <h2>My Schedule</h2>
        <p>Your class timetable and upcoming sessions</p>
    </div>
    <div class="page-actions">
        <button class="btn-outline"><i class="fas fa-download"></i> Export</button>
        <button class="btn-primary"><i class="fas fa-calendar-plus"></i> Request Session</button>
    </div>
</div>

<!-- Stats -->
<div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:16px;margin-bottom:24px;">
    <div class="card-plain" style="padding:20px;border-left:4px solid var(--primary);">
        <div class="stat-label">Today</div>
        <div class="stat-value" style="margin-top:4px;">@todayCount</div>
        <div class="smaller text-muted">sessions</div>
    </div>
    <div class="card-plain" style="padding:20px;border-left:4px solid #0891b2;">
        <div class="stat-label">This Week</div>
        <div class="stat-value" style="margin-top:4px;">@weekCount</div>
        <div class="smaller text-muted">sessions</div>
    </div>
    <div class="card-plain" style="padding:20px;background:var(--sidebar-bg);color:white;">
        <div class="stat-label" style="color:rgba(255,255,255,0.6);">Next Session</div>
        <div class="stat-value" style="color:white;font-size:16px;margin-top:4px;">
            @(nextSession?.MaLopNavigation?.TenLop ?? nextSession?.MaLop ?? "No upcoming session")
        </div>
        <div class="smaller" style="color:rgba(255,255,255,0.6);margin-top:4px;">
            @(nextSession?.NgayHoc?.ToString("dd/MM/yyyy") ?? "No date")
            @(nextSession?.GioBatDau != null ? $" • {nextSession.GioBatDau:HH\\:mm}" : string.Empty)
        </div>
    </div>
</div>

<!-- Weekly Calendar -->
<div class="card-plain" style="padding:0;margin-bottom:24px;">
    <div style="padding:20px 24px;border-bottom:1px solid var(--surface-low);display:flex;align-items:center;justify-content:space-between;">
        <div style="display:flex;align-items:center;gap:12px;">
            <button class="btn-icon btn-outline"><i class="fas fa-chevron-left"></i></button>
            <h5>@DateTime.Now.ToString("MMMM yyyy")</h5>
            <button class="btn-icon btn-outline"><i class="fas fa-chevron-right"></i></button>
        </div>
        <div style="background:var(--surface-high);border-radius:8px;padding:4px;display:flex;gap:4px;">
            <button class="filter-btn active" data-filter="week">Week</button>
            <button class="filter-btn" data-filter="month">Month</button>
            <button class="filter-btn" data-filter="list">List</button>
        </div>
    </div>

    <!-- Day Headers -->
    <div style="display:grid;grid-template-columns:80px repeat(5,minmax(160px,1fr));border-bottom:1px solid var(--surface-low);">
        <div></div>
        @foreach (var day in timetableDays)
        {
            var isToday = day == today;
            <div style="padding:12px;text-align:center;@(isToday ? "background:rgba(43,84,191,0.05);" : "")">
                <div class="smaller text-muted">@day.ToString("ddd").ToUpper()</div>
                <div style="font-size:20px;font-weight:800;color:@(isToday ? "var(--primary)" : "var(--on-surface)");">
                    @day.Day
                </div>
            </div>
        }
    </div>

    <!-- Time Slots -->
    @foreach (var hour in timetableSlots)
    {
        <div style="display:grid;grid-template-columns:80px repeat(5,minmax(160px,1fr));border-bottom:1px solid var(--surface-low);min-height:72px;">
            <div style="padding:8px 12px;font-size:12px;color:var(--outline);text-align:right;padding-top:16px;">@($"{hour:00}:00")</div>
            @foreach (var day in timetableDays)
            {
                var isToday = day == today;
                var daySessions = sessions.Where(s => s.NgayHoc == day && s.GioBatDau?.Hour == hour).ToList();
                <div style="padding:6px;border-left:1px solid var(--surface-low);@(isToday ? "background:rgba(43,84,191,0.03);" : "")">
                    @if (daySessions.Any())
                    {
                        @foreach (var session in daySessions)
                        {
                            <div style="background:rgba(43,84,191,0.08);border-left:3px solid var(--primary);border-radius:8px;padding:8px 10px;margin-bottom:6px;">
                                <div class="user-name" style="font-size:12px;line-height:1.3;">@(session.MaLopNavigation?.TenLop ?? session.MaLop ?? "-")</div>
                                <div class="user-sub" style="font-size:11px;line-height:1.3;">@(session.GioBatDau?.ToString(@"HH\:mm") ?? "--:--") - @(session.GioKetThuc?.ToString(@"HH\:mm") ?? "--:--")</div>
                                <div class="user-sub" style="font-size:11px;line-height:1.3;">@(session.MaPhongNavigation?.TenPhong ?? "-")</div>
                            </div>
                        }
                    }
                </div>
            }
        </div>
    }
</div>

<!-- Schedule List -->
<div class="card-plain" style="padding:0;">
    <div class="card-header-plain">
        <h5>Schedule List</h5>
        <div style="display:flex;gap:8px;">
            <button class="filter-btn active" data-filter="week">Week</button>
            <button class="filter-btn" data-filter="month">Month</button>
            <button class="filter-btn" data-filter="list">List</button>
        </div>
    </div>
    <table class="data-table">
        <thead>
            <tr>
                <th>Date</th>
                <th>Time</th>
                <th>Class</th>
                <th>Course</th>
                <th>Room</th>
                <th>Status</th>
            </tr>
        </thead>
        <tbody>
            @if (sessions.Any())
            {
                @foreach (var session in sessions)
                {
                    <tr class="session-row" data-date="@(session.NgayHoc?.ToString("yyyy-MM-dd") ?? "")">
                        <td>@(session.NgayHoc?.ToString("dd/MM/yyyy") ?? "-")</td>
                        <td>@(session.GioBatDau?.ToString(@"HH\:mm") ?? "--:--") - @(session.GioKetThuc?.ToString(@"HH\:mm") ?? "--:--")</td>
                        <td>@(session.MaLopNavigation?.TenLop ?? session.MaLop ?? "-")</td>
                        <td>@(session.MaLopNavigation?.MaKhoaHocNavigation?.TenKhoaHoc ?? "-")</td>
                        <td>@(session.MaPhongNavigation?.TenPhong ?? "-")</td>
                        <td><span class="chip chip-green">Scheduled</span></td>
                    </tr>
                }
                <tr id="filterEmptyRow" style="display:none;">
                    <td colspan="6">
                        <div class="empty-state"><i class="fas fa-calendar-times"></i><p>No sessions match this view</p></div>
                    </td>
                </tr>
            }
            else
            {
                <tr>
                    <td colspan="6">
                        <div class="empty-state"><i class="fas fa-calendar"></i><p>No schedule found</p></div>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <div class="pagination-bar">
        <span class="pagination-info" id="scheduleCount">Showing @sessions.Count sessions</span>
        <div class="pagination-btns">
            <button type="button" class="page-btn" id="prevPageBtn"><i class="fas fa-chevron-left" style="font-size:10px;"></i></button>
            <div id="paginationNumbers" style="display:flex;gap:6px;"></div>
            <button type="button" class="page-btn" id="nextPageBtn"><i class="fas fa-chevron-right" style="font-size:10px;"></i></button>
        </div>
    </div>
</div>

@section Scripts {
<script>
document.addEventListener('DOMContentLoaded', function () {
    const filterButtons = document.querySelectorAll('.filter-btn');
    const rows = document.querySelectorAll('.session-row');
    const emptyRow = document.getElementById('filterEmptyRow');
    const scheduleCount = document.getElementById('scheduleCount');
    const prevPageBtn = document.getElementById('prevPageBtn');
    const nextPageBtn = document.getElementById('nextPageBtn');
    const paginationNumbers = document.getElementById('paginationNumbers');

    const pageSize = 8;
    let currentFilter = 'week';
    let currentPage = 1;

    function getWeekRange(now) {
        const day = now.getDay();
        const mondayOffset = day === 0 ? -6 : 1 - day;
        const start = new Date(now);
        start.setDate(now.getDate() + mondayOffset);
        start.setHours(0, 0, 0, 0);

        const end = new Date(start);
        end.setDate(start.getDate() + 6);
        end.setHours(23, 59, 59, 999);
        return { start, end };
    }

    function getMonthRange(now) {
        const start = new Date(now.getFullYear(), now.getMonth(), 1, 0, 0, 0, 0);
        const end = new Date(now.getFullYear(), now.getMonth() + 1, 0, 23, 59, 59, 999);
        return { start, end };
    }

    function getFilteredRows() {
        const now = new Date();
        const week = getWeekRange(now);
        const month = getMonthRange(now);
        const filtered = [];

        rows.forEach(row => {
            const dateStr = row.dataset.date;
            const date = dateStr ? new Date(dateStr + 'T00:00:00') : null;
            let visible = true;

            if (currentFilter === 'week') {
                visible = !!date && date >= week.start && date <= week.end;
            } else if (currentFilter === 'month') {
                visible = !!date && date >= month.start && date <= month.end;
            }

            if (visible) {
                filtered.push(row);
            }
        });

        return filtered;
    }

    function setButtonState(btn, disabled) {
        if (!btn) return;
        btn.disabled = disabled;
        btn.style.opacity = disabled ? '0.5' : '1';
        btn.style.cursor = disabled ? 'not-allowed' : 'pointer';
    }

    function renderPagination(totalPages) {
        if (!paginationNumbers) return;

        paginationNumbers.innerHTML = '';
        for (let page = 1; page <= totalPages; page++) {
            const btn = document.createElement('button');
            btn.type = 'button';
            btn.className = 'page-btn' + (page === currentPage ? ' active' : '');
            btn.textContent = page;
            btn.addEventListener('click', function () {
                if (currentPage === page) return;
                currentPage = page;
                applyView(false);
            });
            paginationNumbers.appendChild(btn);
        }

        setButtonState(prevPageBtn, currentPage <= 1);
        setButtonState(nextPageBtn, currentPage >= totalPages);
    }

    function applyView(resetPage) {
        const filteredRows = getFilteredRows();
        const totalItems = filteredRows.length;
        const totalPages = Math.max(1, Math.ceil(totalItems / pageSize));

        if (resetPage) {
            currentPage = 1;
        } else if (currentPage > totalPages) {
            currentPage = totalPages;
        }

        rows.forEach(r => r.style.display = 'none');

        const startIndex = (currentPage - 1) * pageSize;
        const endIndex = Math.min(startIndex + pageSize, totalItems);
        for (let i = startIndex; i < endIndex; i++) {
            filteredRows[i].style.display = '';
        }

        renderPagination(totalPages);

        if (scheduleCount) {
            scheduleCount.textContent = totalItems === 0
                ? 'Showing 0 sessions'
                : 'Showing ' + (startIndex + 1) + '-' + endIndex + ' of ' + totalItems + ' sessions';
        }

        if (emptyRow) {
            emptyRow.style.display = totalItems === 0 ? '' : 'none';
        }
    }

    filterButtons.forEach(btn => {
        btn.addEventListener('click', function () {
            filterButtons.forEach(b => b.classList.remove('active'));
            this.classList.add('active');
            currentFilter = this.dataset.filter || 'list';
            applyView(true);
        });
    });

    if (prevPageBtn) {
        prevPageBtn.addEventListener('click', function () {
            if (currentPage <= 1) return;
            currentPage -= 1;
            applyView(false);
        });
    }

    if (nextPageBtn) {
        nextPageBtn.addEventListener('click', function () {
            const totalItems = getFilteredRows().length;
            const totalPages = Math.max(1, Math.ceil(totalItems / pageSize));
            if (currentPage >= totalPages) return;
            currentPage += 1;
            applyView(false);
        });
    }

    applyView(true);
});
</script>
}
