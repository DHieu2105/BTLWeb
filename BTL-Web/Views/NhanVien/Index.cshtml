@model IEnumerable<BTL_Web.Models.NhanVien>

@{
    ViewData["Title"] = "Quản lý nhân viên";
    var isAdmin = User.IsInRole(BTL_Web.Constants.AppRoles.Admin);
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="mb-0">Quản lý nhân viên</h2>
        @if (isAdmin)
        {
            <a asp-action="Create" class="btn btn-primary">
                <i class="fas fa-plus me-1"></i>Thêm nhân viên
            </a>
        }
    </div>

    @if (TempData["Success"] is string success)
    {
        <div class="alert alert-success">@success</div>
    }

    @if (TempData["Error"] is string error)
    {
        <div class="alert alert-danger">@error</div>
    }

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Mã NV</th>
                            <th>Họ và tên</th>
                            <th>Chức vụ</th>
                            <th>Giới tính</th>
                            <th>Trung tâm</th>
                            <th>Tài khoản</th>
                            <th class="text-end">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            var account = item.TaiKhoans.FirstOrDefault();
                            <tr>
                                <td>@item.MaNv</td>
                                <td>@item.HoVaTen</td>
                                <td>@item.ChucVu</td>
                                <td>@item.GioiTinh</td>
                                <td>@(item.MaTrungTamNavigation?.TenTrungTam ?? item.MaTrungTam)</td>
                                <td>@(account?.Username ?? "Chưa gán")</td>
                                <td class="text-end">
                                    <a asp-action="Details" asp-route-id="@item.MaNv" class="btn btn-sm btn-outline-info">Chi tiết</a>
                                    @if (isAdmin)
                                    {
                                        <a asp-action="Edit" asp-route-id="@item.MaNv" class="btn btn-sm btn-outline-primary">Sửa</a>
                                        <a asp-action="Delete" asp-route-id="@item.MaNv" class="btn btn-sm btn-outline-danger">Xóa</a>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
