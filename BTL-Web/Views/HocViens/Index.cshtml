@using X.PagedList.Mvc.Core;
@using X.PagedList;
@model IPagedList<BTL_Web.Models.HocVien>

@{
	ViewData["Title"] = "Danh sách Học viên";
}

<h1 class="mt-4">Quản lý Học viên</h1>

<p>
	<a asp-action="Create" class="btn btn-success">Thêm học viên mới</a>
</p>

<form asp-action="Index" method="get" class="mb-3 mt-3">
	<div class="row">
		<div class="col-md-6">
			<div class="input-group">
				<input type="text" name="searchString" value="@ViewData["CurrentFilter"]"
					   class="form-control" placeholder="Tìm kiếm theo Tên hoặc Mã học viên..." />
				<button type="submit" class="btn btn-primary">Tìm kiếm</button>
				<a asp-action="Index" class="btn btn-outline-secondary">Xóa lọc</a>
			</div>
		</div>
	</div>
</form>

<table class="table table-striped table-hover mt-3">
	<thead>
		<tr>
			<th>
				@Html.DisplayNameFor(model => model.FirstOrDefault().HoVaTen)
			</th>
			<th>
				@Html.DisplayNameFor(model => model.FirstOrDefault().Sdt)
			</th>
			<th>
				@Html.DisplayNameFor(model => model.FirstOrDefault().NgayDangKi)
			</th>
			<th>
				@Html.DisplayNameFor(model => model.FirstOrDefault().GioiTinh)
			</th>
			<th>Thao tác</th>
		</tr>
	</thead>
	<tbody>
		@foreach (var item in Model)
		{
			<tr>
				<td>
					@Html.DisplayFor(modelItem => item.HoVaTen)
				</td>
				<td>
					@Html.DisplayFor(modelItem => item.Sdt)
				</td>
				<td>
					@Html.DisplayFor(modelItem => item.NgayDangKi)
				</td>
				<td>
					@Html.DisplayFor(modelItem => item.GioiTinh)
				</td>
				<td>
					<a asp-action="Edit" asp-route-id="@item.MaHocVien" class="btn btn-sm btn-info">Sửa</a>
					<a asp-action="Details" asp-route-id="@item.MaHocVien" class="btn btn-sm btn-warning">Xem</a>
					<a asp-action="Delete" asp-route-id="@item.MaHocVien" class="btn btn-sm btn-danger">Xóa</a>
				</td>
			</tr>
		}
	</tbody>
</table>

<div class="d-flex justify-content-center mt-4">
	@Html.PagedListPager(Model, page => Url.Action("Index",
		new { page, searchString = ViewData["CurrentFilter"] }),
		new PagedListRenderOptions
		{
			LiElementClasses = new string[] { "page-item" },
			PageClasses = new string[] { "page-link" }
		})
</div>
