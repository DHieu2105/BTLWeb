@model BTL_Web.Models.HocVien

<h5 style="margin-bottom:20px;">Student Information</h5>
<form asp-action="Create" method="post" id="addHocVienForm">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="ModelOnly" class="text-danger" style="padding:12px;background:#fee;border-radius:8px;margin-bottom:16px;">
    </div>

    <div class="form-group" style="margin-bottom:16px;">
        <label asp-for="MaHocVien" class="form-label">Student ID</label>
        <input asp-for="MaHocVien" class="form-control" placeholder="Example: HV001" />
        <span asp-validation-for="MaHocVien" class="text-danger" style="font-size:12px;"></span>
    </div>

    <div class="form-group" style="margin-bottom:16px;">
        <label asp-for="HoVaTen" class="form-label">Full Name</label>
        <input asp-for="HoVaTen" class="form-control" placeholder="Enter full name" />
        <span asp-validation-for="HoVaTen" class="text-danger" style="font-size:12px;"></span>
    </div>

    <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:16px;">
        <div class="form-group">
            <label asp-for="Sdt" class="form-label">Phone Number</label>
            <input asp-for="Sdt" class="form-control" placeholder="0123456789" />
            <span asp-validation-for="Sdt" class="text-danger" style="font-size:12px;"></span>
        </div>
        <div class="form-group">
            <label asp-for="GioiTinh" class="form-label">Gender</label>
            <select asp-for="GioiTinh" class="form-control form-select">
                <option value="">-- Select Gender --</option>
                <option value="Nam">Nam (Male)</option>
                <option value="Nu">Nữ (Female)</option>
            </select>
            <span asp-validation-for="GioiTinh" class="text-danger" style="font-size:12px;"></span>
        </div>
    </div>

    <div class="form-group" style="margin-bottom:16px;">
        <label asp-for="NgayDangKi" class="form-label">Registration Date</label>
        <input asp-for="NgayDangKi" class="form-control" type="date" />
        <span asp-validation-for="NgayDangKi" class="text-danger" style="font-size:12px;"></span>
    </div>

    <div class="form-group" style="margin-bottom:24px;">
        <label asp-for="MaNv" class="form-label">Staff In Charge</label>
        <select asp-for="MaNv" class="form-control form-select" asp-items="ViewBag.MaNv">
            <option value="">-- Select Staff --</option>
        </select>
        <span asp-validation-for="MaNv" class="text-danger" style="font-size:12px;"></span>
    </div>

    <div style="display:flex;gap:12px;justify-content:flex-end;">
        <button type="button" class="btn-outline" data-bs-dismiss="modal">Cancel</button>
        <button type="submit" class="btn-primary">
            <i class="fas fa-save"></i> Add Student
        </button>
    </div>

    @section Scripts {
        @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    }
</form>