@model BTL_Web.ViewModels.GiaoVienFormViewModel

@{
    ViewData["Title"] = "Thêm Giáo viên";
}

<div class="container py-4">
    <h2 class="mb-3">Thêm Giáo viên</h2>

    <form asp-action="Create" method="post" class="card p-3 shadow-sm">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>

        <div class="row g-3">
            <div class="col-md-4">
                <label asp-for="MaGv" class="form-label"></label>
                <input asp-for="MaGv" class="form-control" />
                <span asp-validation-for="MaGv" class="text-danger"></span>
            </div>
            <div class="col-md-8">
                <label asp-for="Ten" class="form-label"></label>
                <input asp-for="Ten" class="form-control" />
                <span asp-validation-for="Ten" class="text-danger"></span>
            </div>

            <div class="col-md-4">
                <label asp-for="Sdt" class="form-label"></label>
                <input asp-for="Sdt" class="form-control" />
                <span asp-validation-for="Sdt" class="text-danger"></span>
            </div>
            <div class="col-md-4">
                <label asp-for="GioiTinh" class="form-label"></label>
                <select asp-for="GioiTinh" class="form-select">
                    <option value="">-- Chọn --</option>
                    <option>Nam</option>
                    <option>Nữ</option>
                </select>
                <span asp-validation-for="GioiTinh" class="text-danger"></span>
            </div>
            <div class="col-md-4">
                <label asp-for="ChuyenMon" class="form-label"></label>
                <input asp-for="ChuyenMon" class="form-control" />
                <span asp-validation-for="ChuyenMon" class="text-danger"></span>
            </div>

            <div class="col-md-6">
                <label asp-for="MaKhoaHoc" class="form-label"></label>
                <select asp-for="MaKhoaHoc" asp-items="Model.KhoaHocOptions" class="form-select">
                    <option value="">-- Chọn khóa học --</option>
                </select>
                <span asp-validation-for="MaKhoaHoc" class="text-danger"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="MaTrungTam" class="form-label"></label>
                <select asp-for="MaTrungTam" asp-items="Model.TrungTamOptions" class="form-select">
                    <option value="">-- Chọn trung tâm --</option>
                </select>
                <span asp-validation-for="MaTrungTam" class="text-danger"></span>
            </div>
        </div>

        <div class="mt-3">
            <button type="submit" class="btn btn-primary">Lưu</button>
            <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
