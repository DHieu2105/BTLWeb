@model IEnumerable<BTL_Web.Models.GiaoVien>

@{
    ViewData["Title"] = "Quản lý Giáo viên";
}

<div class="container py-4">
    <h2 class="mb-3">Quản lý Giáo viên</h2>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    <div class="d-flex justify-content-between align-items-center mb-3">
        <form method="get" class="d-flex" style="max-width: 360px;">
            <input class="form-control me-2" name="keyword" value="@ViewBag.Keyword" placeholder="Tìm theo mã, tên, số điện thoại" />
            <button class="btn btn-outline-primary" type="submit">Tìm</button>
        </form>
        <a asp-action="Create" class="btn btn-primary">Thêm giáo viên</a>
    </div>

    <div class="table-responsive">
        <table class="table table-bordered table-hover align-middle">
            <thead class="table-light">
                <tr>
                    <th>Mã GV</th>
                    <th>Tên</th>
                    <th>SĐT</th>
                    <th>Chuyên môn</th>
                    <th>Khóa học</th>
                    <th>Trung tâm</th>
                    <th>Giới tính</th>
                    <th style="width: 220px;">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.MaGv</td>
                        <td>@item.Ten</td>
                        <td>@item.Sdt</td>
                        <td>@item.ChuyenMon</td>
                        <td>@(item.MaKhoaHocNavigation?.TenKhoaHoc ?? item.MaKhoaHoc)</td>
                        <td>@(item.MaTrungTamNavigation?.TenTrungTam ?? item.MaTrungTam)</td>
                        <td>@item.GioiTinh</td>
                        <td>
                            <a asp-action="Details" asp-route-id="@item.MaGv" class="btn btn-sm btn-info">Chi tiết</a>
                            <a asp-action="Edit" asp-route-id="@item.MaGv" class="btn btn-sm btn-warning">Sửa</a>
                            <a asp-action="Delete" asp-route-id="@item.MaGv" class="btn btn-sm btn-danger">Xóa</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
