@model BTL_Web.Models.GiaoVien

@{
    ViewData["Title"] = "Chi tiết Giáo viên";
}

<div class="container py-4">
    <h2 class="mb-3">Chi tiết Giáo viên</h2>

    <div class="card shadow-sm">
        <div class="card-body">
            <dl class="row mb-0">
                <dt class="col-sm-3">Mã giáo viên</dt>
                <dd class="col-sm-9">@Model.MaGv</dd>

                <dt class="col-sm-3">Tên giáo viên</dt>
                <dd class="col-sm-9">@Model.Ten</dd>

                <dt class="col-sm-3">Số điện thoại</dt>
                <dd class="col-sm-9">@Model.Sdt</dd>

                <dt class="col-sm-3">Chuyên môn</dt>
                <dd class="col-sm-9">@Model.ChuyenMon</dd>

                <dt class="col-sm-3">Giới tính</dt>
                <dd class="col-sm-9">@Model.GioiTinh</dd>

                <dt class="col-sm-3">Khóa học</dt>
                <dd class="col-sm-9">@(Model.MaKhoaHocNavigation?.TenKhoaHoc ?? Model.MaKhoaHoc)</dd>

                <dt class="col-sm-3">Trung tâm</dt>
                <dd class="col-sm-9">@(Model.MaTrungTamNavigation?.TenTrungTam ?? Model.MaTrungTam)</dd>
            </dl>
        </div>
    </div>

    <div class="mt-3">
        <a asp-action="Edit" asp-route-id="@Model.MaGv" class="btn btn-warning">Sửa</a>
        <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
    </div>
</div>
