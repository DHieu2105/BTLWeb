@model BTL_Web.Models.GiaoVien

@{
    ViewData["Title"] = "Xóa Giáo viên";
}

<div class="container py-4">
    <h2 class="mb-3 text-danger">Xóa Giáo viên</h2>

    <div class="alert alert-warning">
        Bạn có chắc chắn muốn xóa giáo viên này không?
    </div>

    <div class="card shadow-sm">
        <div class="card-body">
            <dl class="row mb-0">
                <dt class="col-sm-3">Mã giáo viên</dt>
                <dd class="col-sm-9">@Model.MaGv</dd>

                <dt class="col-sm-3">Tên giáo viên</dt>
                <dd class="col-sm-9">@Model.Ten</dd>

                <dt class="col-sm-3">Khóa học</dt>
                <dd class="col-sm-9">@(Model.MaKhoaHocNavigation?.TenKhoaHoc ?? Model.MaKhoaHoc)</dd>

                <dt class="col-sm-3">Trung tâm</dt>
                <dd class="col-sm-9">@(Model.MaTrungTamNavigation?.TenTrungTam ?? Model.MaTrungTam)</dd>
            </dl>
        </div>
    </div>

    <form asp-action="Delete" method="post" class="mt-3">
        <input type="hidden" name="id" value="@Model.MaGv" />
        <button type="submit" class="btn btn-danger">Xác nhận xóa</button>
        <a asp-action="Index" class="btn btn-secondary">Hủy</a>
    </form>
</div>
