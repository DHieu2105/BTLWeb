@model BTL_Web.Models.KetQua

@{
    ViewData["Title"] = "Delete Score";
}

<div class="page-header">
    <div>
        <a href="/KetQuas/Index" style="font-size:13px;color:var(--primary);text-decoration:none;display:flex;align-items:center;gap:4px;margin-bottom:8px;">
            <i class="fas fa-arrow-left"></i> Back to List
        </a>
        <h2>Delete Score Record</h2>
        <p>Are you sure you want to delete this record?</p>
    </div>
</div>

<div style="display:grid;grid-template-columns:2fr 1fr;gap:24px;">
    <div class="card-plain" style="padding:32px;">
        <div style="background:#fef3cd;border-left:4px solid #ffc107;padding:16px;border-radius:8px;margin-bottom:24px;">
            <strong><i class="fas fa-exclamation-triangle"></i> Warning:</strong> This action cannot be undone!
        </div>

        <h5 style="margin-bottom:20px;">Record Information</h5>
        <dl class="row">
            <dt class="col-sm-4">Student ID:</dt>
            <dd class="col-sm-8">@Html.DisplayFor(model => model.MaHocVien)</dd>

            <dt class="col-sm-4">Student Name:</dt>
            <dd class="col-sm-8">@Html.DisplayFor(model => model.MaHocVienNavigation.HoVaTen)</dd>

            <dt class="col-sm-4">Course:</dt>
            <dd class="col-sm-8">@Html.DisplayFor(model => model.MaKhoaHoc)</dd>

            <dt class="col-sm-4">Listening Score:</dt>
            <dd class="col-sm-8">@Html.DisplayFor(model => model.DiemListening)/100</dd>

            <dt class="col-sm-4">Reading Score:</dt>
            <dd class="col-sm-8">@Html.DisplayFor(model => model.DiemReading)/100</dd>

            <dt class="col-sm-4">Total Score:</dt>
            <dd class="col-sm-8"><strong>@Html.DisplayFor(model => model.DiemTong)</strong></dd>
        </dl>

        <form asp-action="Delete" method="post" style="margin-top:32px;display:flex;gap:12px;">
            <input type="hidden" asp-for="MaHocVien" />
            <input type="hidden" asp-for="MaKhoaHoc" />
            <button type="submit" class="btn-danger"><i class="fas fa-trash"></i> Delete</button>
            <a asp-action="Index" class="btn-outline"><i class="fas fa-times"></i> Cancel</a>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
