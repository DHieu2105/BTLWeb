@model BTL_Web.Models.KetQua

@{
    ViewData["Title"] = "Edit Score";
}

<div class="page-header">
    <div>
        <a href="/KetQuas/Index" style="font-size:13px;color:var(--primary);text-decoration:none;display:flex;align-items:center;gap:4px;margin-bottom:8px;">
            <i class="fas fa-arrow-left"></i> Back to List
        </a>
        <h2>Edit Score</h2>
        <p>Update student score for @Model?.MaKhoaHocNavigation?.TenKhoaHoc</p>
    </div>
</div>

<div style="display:grid;grid-template-columns:2fr 1fr;gap:24px;">
    <div class="card-plain" style="padding:32px;">
        <h5 style="margin-bottom:20px;">Score Information</h5>
        <form asp-action="Edit" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger" style="padding:12px;background:#fee;border-radius:8px;margin-bottom:16px;"></div>

            <input type="hidden" asp-for="MaHocVien" />
            <input type="hidden" asp-for="MaKhoaHoc" />

            <div class="form-group" style="margin-bottom:16px;">
                <label class="form-label">Student Name</label>
                <input type="text" class="form-control" value="@(Model?.MaHocVienNavigation?.HoVaTen ?? Model?.MaHocVien)" disabled />
                <span style="font-size:12px;color:var(--on-surface-variant);">@Model?.MaHocVien</span>
            </div>

            <div class="form-group" style="margin-bottom:16px;">
                <label class="form-label">Course</label>
                <input type="text" class="form-control" value="@(Model?.MaKhoaHocNavigation?.TenKhoaHoc ?? Model?.MaKhoaHoc)" disabled />
            </div>

            <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:16px;">
                <div class="form-group">
                    <label asp-for="DiemListening" class="form-label">Listening Score</label>
                    <input asp-for="DiemListening" class="form-control" type="number" min="0" />
                    <span asp-validation-for="DiemListening" class="text-danger" style="font-size:12px;"></span>
                </div>
                <div class="form-group">
                    <label asp-for="DiemReading" class="form-label">Reading Score</label>
                    <input asp-for="DiemReading" class="form-control" type="number" min="0" />
                    <span asp-validation-for="DiemReading" class="text-danger" style="font-size:12px;"></span>
                </div>
            </div>

            <div class="form-group" style="margin-bottom:24px;">
                <label class="form-label">Total Score (Auto-calculated)</label>
                <div style="padding:12px;background:var(--surface-low);border-radius:8px;font-size:18px;font-weight:600;color:var(--primary);">
                    <span id="DiemTong">@(((Model?.DiemListening ?? 0) + (Model?.DiemReading ?? 0)))</span>
                </div>
            </div>

            <div style="display:flex;gap:12px;justify-content:flex-end;">
                <a href="/KetQuas/Index" class="btn-outline">Cancel</a>
                <button type="submit" class="btn-primary">
                    <i class="fas fa-save"></i> Save Changes
                </button>
            </div>
        </form>
    </div>

    <!-- Sidebar Info -->
    <div style="display:flex;flex-direction:column;gap:16px;">
        <div class="card-plain" style="padding:24px;">
            <div class="stat-label" style="margin-bottom:16px;"><i class="fas fa-info-circle"></i> Information</div>
            <div style="font-size:13px;color:var(--on-surface-variant);line-height:2;">
                <div><strong>Listening:</strong> <span id="ListeningDisplay">@(Model?.DiemListening ?? 0)</span></div>
                <div><strong>Reading:</strong> <span id="ReadingDisplay">@(Model?.DiemReading ?? 0)</span></div>
                <div style="margin-top:12px;padding-top:12px;border-top:1px solid var(--outline);"><strong style="font-size:16px;color:var(--primary);">Total:</strong> <span id="TotalDisplay" style="font-size:16px;font-weight:600;color:var(--primary);">@(Model?.DiemTong ?? 0)</span></div>
            </div>
        </div>

        <div class="card-plain" style="padding:24px;">
            <div class="stat-label" style="margin-bottom:12px;"><i class="fas fa-edit"></i> Edit Guide</div>
            <p style="font-size:13px;color:var(--on-surface-variant);line-height:1.6;">
                Update listening and reading scores. Total score will be calculated automatically by the system.
            </p>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}

    <script>
        $(document).ready(function () {
            function updateTotal() {
                let listening = parseInt($("#DiemListening").val()) || 0;
                let reading = parseInt($("#DiemReading").val()) || 0;
                let total = listening + reading;

                $("#DiemTong").text(total);
                $("#ListeningDisplay").text(listening);
                $("#ReadingDisplay").text(reading);
                $("#TotalDisplay").text(total);
            }

            $("#DiemListening, #DiemReading").on("input", function () {
                updateTotal();
            });
        });
    </script>
}
