@model IEnumerable<BTL_Web.Models.LichHoc>
@{
    ViewData["Title"] = "Quản lý lịch học";
}

<div class="page-header">
    <div>
        <h2>Quản lý lịch học</h2>
        <p>Quản lý và điều phối toàn bộ lịch và buổi học của lớp</p>
    </div>
    <div class="page-actions">
        <button class="btn-outline"><i class="fas fa-calendar-week"></i> Xem theo tuần</button>
        <button class="btn-primary" onclick="openAddScheduleModal()">
            <i class="fas fa-plus"></i> Thêm lịch học
        </button>
    </div>
</div>

<!-- Stats -->
<div class="stats-grid" style="grid-template-columns:repeat(3,1fr);margin-bottom:24px;">
    <div class="stat-card blue">
        <div class="stat-card-header">
            <div class="stat-icon blue"><i class="fas fa-calendar-check"></i></div><span
            class="stat-badge blue">Trực tiếp</span>
        </div>
        <div class="stat-label">Buổi học đang hoạt động</div>
        <div class="stat-value">@(Model?.Count() ?? 0)</div>
    </div>
    <div class="stat-card teal">
        <div class="stat-card-header">
            <div class="stat-icon teal"><i class="fas fa-door-open"></i></div>
        </div>
        <div class="stat-label">Mức sử dụng phòng</div>
        <div class="stat-value">75%</div>
    </div>
    <div class="stat-card orange">
        <div class="stat-card-header">
            <div class="stat-icon orange"><i class="fas fa-exclamation-triangle"></i></div>
        </div>
        <div class="stat-label">Yêu cầu chờ xử lý</div>
        <div class="stat-value">24</div>
    </div>
</div>

<!-- Schedule Table -->
<div class="card-plain" style="padding:0;">
    <div class="card-header-plain">
        <h5>Danh sách lịch học</h5>
        <div style="display:flex;gap:8px;">
            <button class="filter-btn active" data-filter="all">Tất cả</button>
            <button class="filter-btn" data-filter="today">Hôm nay</button>
            <button class="filter-btn" data-filter="week">Tuần này</button>
        </div>
    </div>
    <table class="data-table">
        <thead>
            <tr>
                <th>Ngày</th>
                <th>Giờ</th>
                <th>Lớp</th>
                <th>Phòng</th>
                <th>Trạng thái</th>
                <th style="text-align:right;">Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                @foreach (var lh in Model)
                {
                    <tr class="schedule-row" data-schedule-date="@(lh.NgayHoc?.ToString("yyyy-MM-dd") ?? "")">
                        <td>@(lh.NgayHoc?.ToString("dd/MM/yyyy") ?? "—")</td>
                        <td>
                            <div class="user-name">@(lh.GioBatDau?.ToString(@"HH\:mm") ?? "—")</div>
                            <div class="user-sub">@(lh.GioKetThuc?.ToString(@"HH\:mm") ?? "—")</div>
                        </td>
                        <td>@(lh.MaLopNavigation?.TenLop ?? lh.MaLop ?? "—")</td>
                        <td>@(lh.MaPhongNavigation?.TenPhong ?? "—")</td>
                        <td><span class="chip chip-green">Đang hoạt động</span></td>
                        <td style="text-align:right;">
                            <div style="display:flex;gap:4px;justify-content:flex-end;">
                                <button type="button" class="btn-icon btn-outline btn-sm edit-schedule-btn"
                                        data-id="@lh.MaLichHoc" data-date="@(lh.NgayHoc?.ToString("yyyy-MM-dd") ?? "")"
                                        data-start="@(lh.GioBatDau?.ToString(@"HH\:mm") ?? "")"
                                        data-end="@(lh.GioKetThuc?.ToString(@"HH\:mm") ?? "")" data-class="@lh.MaLop">
                                    <i class="fas fa-edit"></i>
                                </button>
                                <button class="btn-icon btn-outline btn-sm" onclick="deleteSched('@lh.MaLichHoc')"><i
                                    class="fas fa-trash" style="color:#ef4444;"></i></button>
                                </div>
                            </td>
                        </tr>
                    }
                    <tr id="filterEmptyRow" style="display:none;">
                        <td colspan="6">
                            <div class="empty-state"><i class="fas fa-calendar-times"></i>
                                <p>Không có lịch nào khớp với bộ lọc này</p>
                            </div>
                        </td>
                    </tr>
                }
            else
                {
                    <tr>
                        <td colspan="6">
                            <div class="empty-state"><i class="fas fa-calendar-alt"></i>
                                <p>Không tìm thấy lịch học nào</p>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        <div class="pagination-bar">
            <span class="pagination-info" id="scheduleCount">Đang hiển thị @(Model?.Count() ?? 0) buổi học</span>
            <div class="pagination-btns">
                <button type="button" class="page-btn" id="prevPageBtn"><i class="fas fa-chevron-left"
                                                                               style="font-size:10px;"></i></button>
                    <div id="paginationNumbers" style="display:flex;gap:6px;"></div>
                    <button type="button" class="page-btn" id="nextPageBtn"><i class="fas fa-chevron-right"
                                                                                   style="font-size:10px;"></i></button>
                    </div>
                </div>
            </div>

            <!-- Add Modal -->
            <div id="addModal"
                 style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.4);z-index:2000;align-items:center;justify-content:center;">
                <div style="background:white;border-radius:12px;padding:32px;width:520px;max-width:90vw;">
                    <h4 style="margin-bottom:24px;">Thêm lịch học</h4>
                    <form method="post" action="/Staff/AddSchedule" id="scheduleForm">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="MaLichHoc" id="scheduleId" value="">
                        <div style="display:grid;grid-template-columns:1fr;gap:16px;margin-bottom:16px;">
                            <div class="form-group">
                                <label class="form-label">Lớp</label>
                                <select id="classSelect" name="MaLop" class="form-control form-select">
                                    @if (ViewBag.LopHocs != null)
                                    {
                                        @foreach (var lop in (IEnumerable<BTL_Web.Models.LopHoc>)ViewBag.LopHocs)
                                        {
                                            <option value="@lop.MaLop" data-class-name="@(lop.TenLop ?? lop.MaLop)"
                                                    data-teacher-name="@(lop.MaGvNavigation?.Ten ?? "—")"
                                                    data-course-name="@(lop.MaKhoaHocNavigation?.TenKhoaHoc ?? "—")">
                                                @(lop.TenLop ?? lop.MaLop)
                                            </option>
                                        }
                                    }
                                </select>
                            </div>
                        </div>
                        <div class="card-plain" style="padding:16px;margin-bottom:16px;background:var(--surface-low);">
                            <div class="section-heading" style="margin-bottom:12px;">
                                <h5 style="margin:0;">Thông tin lớp đã chọn</h5>
                            </div>
                            <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
                                <div>
                                    <div class="stat-label">Tên lớp</div>
                                    <div id="modalClassName" class="user-name" style="font-size:14px;">—</div>
                                </div>
                                <div>
                                    <div class="stat-label">Giáo viên</div>
                                    <div id="modalTeacherName" class="user-name" style="font-size:14px;">—</div>
                                </div>
                            </div>
                            <div style="margin-top:12px;">
                                <div class="stat-label">Khóa học</div>
                                <div id="modalCourseName" class="user-name" style="font-size:14px;">—</div>
                            </div>
                        </div>
                        <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;">
                            <div class="form-group">
                                <label class="form-label">Ngày</label>
                                <input type="date" name="NgayHoc" class="form-control">
                            </div>
                            <div class="form-group">
                                <label class="form-label">Phòng</label>
                                <input type="text" class="form-control" value="Tự động lấy từ lớp đã chọn" readonly>
                            </div>
                        </div>
                        <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;">
                            <div class="form-group">
                                <label class="form-label">Bắt đầu</label>
                                <input type="time" name="GioBatDau" class="form-control">
                            </div>
                            <div class="form-group">
                                <label class="form-label">Kết thúc</label>
                                <input type="time" name="GioKetThuc" class="form-control">
                            </div>
                        </div>
                        <div style="display:flex;gap:12px;justify-content:flex-end;margin-top:24px;">
                            <button type="button" class="btn-outline"
                                    onclick="document.getElementById('addModal').style.display='none'">Hủy</button>
                            <button type="submit" id="scheduleSubmitBtn" class="btn-primary">Thêm lịch học</button>
                        </div>
                    </form>
                </div>
            </div>

            @section Scripts {
                <script>
                    document.addEventListener('DOMContentLoaded', function () {
                        const classSelect = document.getElementById('classSelect');
                        const scheduleForm = document.getElementById('scheduleForm');
                        const scheduleId = document.getElementById('scheduleId');
                        const scheduleSubmitBtn = document.getElementById('scheduleSubmitBtn');
                        const dateInput = document.querySelector('input[name="NgayHoc"]');
                        const startInput = document.querySelector('input[name="GioBatDau"]');
                        const endInput = document.querySelector('input[name="GioKetThuc"]');
                        const modalClassName = document.getElementById('modalClassName');
                        const modalTeacherName = document.getElementById('modalTeacherName');
                        const modalCourseName = document.getElementById('modalCourseName');
                        const modalTitle = document.querySelector('#addModal h4');
                        const filterButtons = document.querySelectorAll('.filter-btn');
                        const scheduleRows = document.querySelectorAll('.schedule-row');
                        const scheduleCount = document.getElementById('scheduleCount');
                        const filterEmptyRow = document.getElementById('filterEmptyRow');
                        const prevPageBtn = document.getElementById('prevPageBtn');
                        const nextPageBtn = document.getElementById('nextPageBtn');
                        const paginationNumbers = document.getElementById('paginationNumbers');
                        const pageSize = 8;
                        let currentFilter = 'all';
                        let currentPage = 1;

                        function isSameDay(a, b) {
                            return a.getFullYear() === b.getFullYear()
                                && a.getMonth() === b.getMonth()
                                && a.getDate() === b.getDate();
                        }

                        function getWeekRange(today) {
                            const day = today.getDay();
                            const mondayOffset = day === 0 ? -6 : 1 - day;
                            const start = new Date(today);
                            start.setDate(today.getDate() + mondayOffset);
                            start.setHours(0, 0, 0, 0);

                            const end = new Date(start);
                            end.setDate(start.getDate() + 6);
                            end.setHours(23, 59, 59, 999);

                            return { start, end };
                        }

                        function getFilteredRows(filterKey) {
                            const today = new Date();
                            today.setHours(0, 0, 0, 0);
                            const weekRange = getWeekRange(today);
                            const filteredRows = [];

                            scheduleRows.forEach(row => {
                                const dateStr = row.dataset.scheduleDate;
                                const scheduleDate = dateStr ? new Date(dateStr + 'T00:00:00') : null;
                                let isVisible = true;

                                if (filterKey === 'today') {
                                    isVisible = !!scheduleDate && isSameDay(scheduleDate, today);
                                } else if (filterKey === 'week') {
                                    isVisible = !!scheduleDate && scheduleDate >= weekRange.start && scheduleDate <= weekRange.end;
                                }

                                if (isVisible) {
                                    filteredRows.push(row);
                                }
                            });

                            return filteredRows;
                        }

                        function setPageButtonState(button, disabled) {
                            if (!button) {
                                return;
                            }

                            button.disabled = disabled;
                            button.style.opacity = disabled ? '0.5' : '1';
                            button.style.cursor = disabled ? 'not-allowed' : 'pointer';
                        }

                        function renderPagination(totalPages) {
                            if (!paginationNumbers) {
                                return;
                            }

                            paginationNumbers.innerHTML = '';
                            for (let page = 1; page <= totalPages; page++) {
                                const pageBtn = document.createElement('button');
                                pageBtn.type = 'button';
                                pageBtn.className = 'page-btn' + (page === currentPage ? ' active' : '');
                                pageBtn.textContent = page;
                                pageBtn.addEventListener('click', function () {
                                    if (page === currentPage) {
                                        return;
                                    }

                                    currentPage = page;
                                    applyFilterAndPagination(false);
                                });
                                paginationNumbers.appendChild(pageBtn);
                            }

                            setPageButtonState(prevPageBtn, currentPage <= 1);
                            setPageButtonState(nextPageBtn, currentPage >= totalPages);
                        }

                        function applyFilterAndPagination(resetPage) {
                            const filteredRows = getFilteredRows(currentFilter);
                            const totalItems = filteredRows.length;
                            const totalPages = Math.max(1, Math.ceil(totalItems / pageSize));

                            if (resetPage) {
                                currentPage = 1;
                            } else if (currentPage > totalPages) {
                                currentPage = totalPages;
                            }

                            scheduleRows.forEach(row => {
                                row.style.display = 'none';
                            });

                            const startIndex = (currentPage - 1) * pageSize;
                            const endIndex = Math.min(startIndex + pageSize, totalItems);
                            for (let i = startIndex; i < endIndex; i++) {
                                filteredRows[i].style.display = '';
                            }

                            renderPagination(totalPages);

                            if (scheduleCount) {
                                if (totalItems === 0) {
                                        scheduleCount.textContent = 'Đang hiển thị 0 buổi học';
                                } else {
                                        scheduleCount.textContent = 'Đang hiển thị ' + (startIndex + 1) + '-' + endIndex + ' trên ' + totalItems + ' buổi học';
                                }
                            }

                            if (filterEmptyRow) {
                                filterEmptyRow.style.display = totalItems === 0 ? '' : 'none';
                            }
                        }

                        function updateClassInfo() {
                            if (!classSelect || !modalClassName || !modalTeacherName || !modalCourseName) {
                                return;
                            }

                            const selected = classSelect.options[classSelect.selectedIndex];
                            if (!selected) {
                                modalClassName.textContent = '—';
                                modalTeacherName.textContent = '—';
                                modalCourseName.textContent = '—';
                                return;
                            }

                            modalClassName.textContent = selected.dataset.className || selected.textContent.trim() || '—';
                            modalTeacherName.textContent = selected.dataset.teacherName || '—';
                            modalCourseName.textContent = selected.dataset.courseName || '—';
                        }

                        filterButtons.forEach(btn => {
                            btn.addEventListener('click', function () {
                                filterButtons.forEach(b => b.classList.remove('active'));
                                this.classList.add('active');
                                currentFilter = this.dataset.filter || 'all';
                                applyFilterAndPagination(true);
                            });
                        });

                        if (prevPageBtn) {
                            prevPageBtn.addEventListener('click', function () {
                                if (currentPage <= 1) {
                                    return;
                                }

                                currentPage -= 1;
                                applyFilterAndPagination(false);
                            });
                        }

                        if (nextPageBtn) {
                            nextPageBtn.addEventListener('click', function () {
                                const totalItems = getFilteredRows(currentFilter).length;
                                const totalPages = Math.max(1, Math.ceil(totalItems / pageSize));
                                if (currentPage >= totalPages) {
                                    return;
                                }

                                currentPage += 1;
                                applyFilterAndPagination(false);
                            });
                        }

                        applyFilterAndPagination(true);

                        if (classSelect) {
                            classSelect.addEventListener('change', updateClassInfo);
                            updateClassInfo();
                        }

                        window.openAddScheduleModal = function () {
                            if (!classSelect || !scheduleForm || !scheduleId || !scheduleSubmitBtn || !dateInput || !startInput || !endInput || !modalTitle) {
                                return;
                            }

                            scheduleForm.action = '/Staff/AddSchedule';
                            scheduleId.value = '';
                            dateInput.value = '';
                            startInput.value = '';
                            endInput.value = '';

                            if (classSelect.options.length > 0) {
                                classSelect.selectedIndex = 0;
                            }

                            scheduleSubmitBtn.textContent = 'Thêm lịch học';
                            modalTitle.textContent = 'Thêm lịch học';
                            updateClassInfo();
                            document.getElementById('addModal').style.display = 'flex';
                        };

                        document.querySelectorAll('.edit-schedule-btn').forEach(btn => {
                            btn.addEventListener('click', function () {
                                if (!classSelect || !scheduleForm || !scheduleId || !scheduleSubmitBtn || !dateInput || !startInput || !endInput || !modalTitle) {
                                    return;
                                }

                                scheduleForm.action = '/Staff/EditSchedule';
                                scheduleId.value = this.dataset.id || '';
                                dateInput.value = this.dataset.date || '';
                                startInput.value = this.dataset.start || '';
                                endInput.value = this.dataset.end || '';
                                classSelect.value = this.dataset.class || '';
                                scheduleSubmitBtn.textContent = 'Save Changes';
                                modalTitle.textContent = 'Edit Schedule';
                                updateClassInfo();
                                document.getElementById('addModal').style.display = 'flex';
                            });
                        });
                    });

                    function deleteSched(id) {
                        if (confirm('Delete schedule ' + id + '?')) location.href = '/Staff/DeleteSchedule/' + id;
                    }
                </script>
            }
