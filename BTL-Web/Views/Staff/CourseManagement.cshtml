@model IEnumerable<BTL_Web.Models.KhoaHoc>
@{
    ViewData["Title"] = "Course Management";
}

<div class="page-header">
    <div>
        <h2>Course Management</h2>
        <p>Manage course catalog and student enrollments</p>
    </div>
    <div class="page-actions">
        <a href="/Staff/RegisterStudent" class="btn-primary">
            <i class="fas fa-user-plus"></i> Register Student
        </a>
    </div>
</div>

<!-- Stats -->
<div class="stats-grid" style="grid-template-columns:repeat(4,1fr);margin-bottom:24px;">
    <div class="stat-card blue">
        <div class="stat-card-header"><div class="stat-icon blue"><i class="fas fa-book"></i></div></div>
        <div class="stat-label">Active Courses</div>
        <div class="stat-value">@(Model?.Count() ?? 0)</div>
    </div>
    <div class="stat-card teal">
        <div class="stat-card-header"><div class="stat-icon teal"><i class="fas fa-users"></i></div></div>
        <div class="stat-label">Total Staff</div>
        <div class="stat-value">58</div>
    </div>
    <div class="stat-card orange">
        <div class="stat-card-header"><div class="stat-icon orange"><i class="fas fa-dollar-sign"></i></div></div>
        <div class="stat-label">Avg. Tuition</div>
        <div class="stat-value">$1,450</div>
    </div>
    <div class="stat-card green">
        <div class="stat-card-header"><div class="stat-icon blue"><i class="fas fa-chart-line"></i></div></div>
        <div class="stat-label">Revenue</div>
        <div class="stat-value">$2.4M</div>
    </div>
</div>

<!-- Course Table -->
<div class="card-plain" style="padding:0;">
    <div class="card-header-plain">
        <h5>Course Catalog</h5>
        <div style="display:flex;gap:8px;">
            <button class="btn-outline btn-sm"><i class="fas fa-filter"></i> Filter</button>
            <a href="/Staff/RegisterStudent" class="btn-primary btn-sm"><i class="fas fa-user-plus"></i> Enroll</a>
        </div>
    </div>
    <table class="data-table">
        <thead>
            <tr>
                <th>Course</th>
                <th>Duration</th>
                <th>Fee</th>
                <th>Enrolled</th>
                <th>Classes</th>
                <th style="text-align:right;">Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                @foreach (var kh in Model)
                {
                    <tr>
                        <td>
                            <div style="display:flex;align-items:center;gap:12px;">
                                <div class="avatar" style="background:rgba(219,225,255,0.3);color:var(--primary);">
                                    <i class="fas fa-book"></i>
                                </div>
                                <div>
                                    <div class="user-name">@kh.TenKhoaHoc</div>
                                    <div class="user-sub">@kh.MaKhoaHoc</div>
                                </div>
                            </div>
                        </td>
                        <td class="user-name">@(kh.ThoiLuong ?? 0) weeks</td>
                        <td class="user-name">@(kh.HocPhi?.ToString("N0") ?? "—") VND</td>
                        <td><span class="chip chip-blue">@kh.DangKis.Count students</span></td>
                        <td><span class="chip chip-gray">@kh.LopHocs.Count classes</span></td>
                        <td style="text-align:right;">
                            <a href="/Staff/RegisterStudent?courseId=@kh.MaKhoaHoc" class="btn-outline btn-sm">
                                <i class="fas fa-user-plus"></i> Enroll
                            </a>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr><td colspan="6"><div class="empty-state"><i class="fas fa-book"></i><p>No courses found</p></div></td></tr>
            }
        </tbody>
    </table>
    <div class="pagination-bar">
        <span class="pagination-info">Showing @(Model?.Count() ?? 0) courses</span>
        <div class="pagination-btns">
            <button class="page-btn"><i class="fas fa-chevron-left" style="font-size:10px;"></i></button>
            <button class="page-btn active">1</button>
            <button class="page-btn"><i class="fas fa-chevron-right" style="font-size:10px;"></i></button>
        </div>
    </div>
</div>
