@model IEnumerable<BTL_Web.Models.KhoaHoc>
@{
    ViewData["Title"] = "Quản lý khóa học";
}

<div class="page-header">
    <div>
        <h2>Quản lý khóa học</h2>
        <p>Quản lý danh mục khóa học và việc ghi danh của học viên</p>
    </div>
    <div class="page-actions">
        <a href="/Staff/RegisterStudent" class="btn-primary">
            <i class="fas fa-user-plus"></i> Ghi danh học viên
        </a>
    </div>
</div>

<!-- Stats -->
<div class="stats-grid" style="grid-template-columns:repeat(4,1fr);margin-bottom:24px;">
    <div class="stat-card blue">
        <div class="stat-card-header"><div class="stat-icon blue"><i class="fas fa-book"></i></div></div>
        <div class="stat-label">Khóa học đang mở</div>
        <div class="stat-value">@(Model?.Count() ?? 0)</div>
    </div>
    <div class="stat-card teal">
        <div class="stat-card-header"><div class="stat-icon teal"><i class="fas fa-users"></i></div></div>
        <div class="stat-label">Tổng số nhân sự</div>
        <div class="stat-value">58</div>
    </div>
    <div class="stat-card orange">
        <div class="stat-card-header"><div class="stat-icon orange"><i class="fas fa-dollar-sign"></i></div></div>
        <div class="stat-label">Học phí trung bình</div>
        <div class="stat-value">$1,450</div>
    </div>
    <div class="stat-card green">
        <div class="stat-card-header"><div class="stat-icon blue"><i class="fas fa-chart-line"></i></div></div>
        <div class="stat-label">Doanh thu</div>
        <div class="stat-value">$2.4M</div>
    </div>
</div>

<!-- Course Table -->
<div class="card-plain" style="padding:0;">
    <div class="card-header-plain">
        <h5>Danh mục khóa học</h5>
        <div style="display:flex;gap:8px;">
            <button type="button" class="btn-outline btn-sm" onclick="toggleStaffCourseFilter()"><i class="fas fa-filter"></i> Lọc</button>
            <a href="/Staff/RegisterStudent" class="btn-primary btn-sm"><i class="fas fa-user-plus"></i> Ghi danh</a>
        </div>
    </div>
    <div id="staffCourseFilterPanel" style="display:none;padding:12px 16px;border-bottom:1px solid var(--surface-low);background:var(--surface);">
        <div style="display:grid;grid-template-columns:1fr auto;gap:8px;align-items:end;">
            <div class="form-group" style="margin:0;">
                <label class="form-label">Bộ lọc nhanh</label>
                <input id="staffCourseFilterInput" type="text" class="form-control" placeholder="Lọc theo mã khóa học, tên khóa học..." oninput="applyStaffCourseFilter()">
            </div>
            <button type="button" class="btn-outline" onclick="clearStaffCourseFilter()">Xóa lọc</button>
        </div>
    </div>
    <table class="data-table">
        <thead>
            <tr>
                <th>Khóa học</th>
                <th>Thời lượng</th>
                <th>Học phí</th>
                <th>Đã ghi danh</th>
                <th>Lớp học</th>
                <th style="text-align:right;">Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                @foreach (var kh in Model)
                {
                    <tr class="staff-course-row">
                        <td>
                            <div style="display:flex;align-items:center;gap:12px;">
                                <div class="avatar" style="background:rgba(219,225,255,0.3);color:var(--primary);">
                                    <i class="fas fa-book"></i>
                                </div>
                                <div>
                                    <div class="user-name">@kh.TenKhoaHoc</div>
                                    <div class="user-sub">@kh.MaKhoaHoc</div>
                                </div>
                            </div>
                        </td>
                        <td class="user-name">@(kh.ThoiLuong ?? 0) tuần</td>
                        <td class="user-name">@(kh.HocPhi?.ToString("N0") ?? "—") VND</td>
                        <td><span class="chip chip-blue">@kh.DangKis.Count học viên</span></td>
                        <td><span class="chip chip-gray">@kh.LopHocs.Count lớp</span></td>
                        <td style="text-align:right;">
                            <a href="/Staff/RegisterStudent?courseId=@kh.MaKhoaHoc" class="btn-outline btn-sm">
                                <i class="fas fa-user-plus"></i> Ghi danh
                            </a>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr><td colspan="6"><div class="empty-state"><i class="fas fa-book"></i><p>Không tìm thấy khóa học nào</p></div></td></tr>
            }
            <tr id="staffCourseFilterEmptyRow" style="display:none;"><td colspan="6"><div class="empty-state"><i class="fas fa-filter"></i><p>Không có khóa học nào khớp với bộ lọc hiện tại</p></div></td></tr>
        </tbody>
    </table>
    <div class="pagination-bar">
        <span class="pagination-info">Đang hiển thị @(Model?.Count() ?? 0) khóa học</span>
        <div class="pagination-btns">
            <button class="page-btn"><i class="fas fa-chevron-left" style="font-size:10px;"></i></button>
            <button class="page-btn active">1</button>
            <button class="page-btn"><i class="fas fa-chevron-right" style="font-size:10px;"></i></button>
        </div>
    </div>
</div>

@section Scripts {
<script>
function toggleStaffCourseFilter() {
    const panel = document.getElementById('staffCourseFilterPanel');
    if (!panel) return;
    panel.style.display = panel.style.display === 'none' || panel.style.display === '' ? 'block' : 'none';
}

function applyStaffCourseFilter() {
    const query = (document.getElementById('staffCourseFilterInput')?.value || '').trim().toLowerCase();
    const rows = document.querySelectorAll('.staff-course-row');
    let visible = 0;

    rows.forEach(row => {
        const text = (row.textContent || '').toLowerCase();
        const show = !query || text.includes(query);
        row.style.display = show ? '' : 'none';
        if (show) visible++;
    });

    const emptyRow = document.getElementById('staffCourseFilterEmptyRow');
    if (emptyRow) emptyRow.style.display = visible === 0 ? '' : 'none';
}

function clearStaffCourseFilter() {
    const input = document.getElementById('staffCourseFilterInput');
    if (input) input.value = '';
    applyStaffCourseFilter();
}
</script>
}
