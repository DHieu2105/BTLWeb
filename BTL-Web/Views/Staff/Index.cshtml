@{
    ViewData["Title"] = "Bảng điều khiển nhân viên";
}

<div class="page-header">
    <div>
        <h2>Chào mừng trở lại!</h2>
        <p>Hôm nay là @DateTime.Now.ToString("dddd, dd/MM/yyyy")</p>
    </div>
    <div class="page-actions">
        <a href="/Staff/TeacherAssignment" class="btn-primary">
            <i class="fas fa-people-arrows"></i> Phân công giáo viên
        </a>
    </div>
</div>

<div class="stats-grid" style="grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); margin-bottom: 24px;">
    <div class="stat-card blue">
        <div class="stat-card-header"><div class="stat-icon blue"><i class="fas fa-users"></i></div></div>
        <div class="stat-label">Tổng học viên</div>
        <div class="stat-value">@(ViewBag.TotalStudents ?? 0)</div>
    </div>
    <div class="stat-card teal">
        <div class="stat-card-header"><div class="stat-icon teal"><i class="fas fa-chalkboard-teacher"></i></div></div>
        <div class="stat-label">Tổng giáo viên</div>
        <div class="stat-value">@(ViewBag.TotalTeachers ?? 0)</div>
    </div>
    <div class="stat-card orange">
        <div class="stat-card-header"><div class="stat-icon orange"><i class="fas fa-door-open"></i></div></div>
        <div class="stat-label">Tổng lớp học</div>
        <div class="stat-value">@(ViewBag.TotalClasses ?? 0)</div>
    </div>
    <div class="stat-card purple">
        <div class="stat-card-header"><div class="stat-icon purple"><i class="fas fa-book"></i></div></div>
        <div class="stat-label">Khóa học</div>
        <div class="stat-value">@(ViewBag.TotalCourses ?? 0)</div>
    </div>
</div>

<div class="card-plain">
    <div class="card-header-plain">
        <h5>Thao tác quản lý</h5>
    </div>
    <div style="padding: 24px; display: grid; grid-template-columns: repeat(auto-fill, minmax(250px, 1fr)); gap: 16px;">
        <a href="/Staff/StudentManagement" class="btn-outline" style="justify-content: flex-start; padding: 16px;">
            <i class="fas fa-user-graduate" style="margin-right: 12px;"></i> Quản lý học viên
        </a>
        <a href="/Staff/ClassManagement" class="btn-outline" style="justify-content: flex-start; padding: 16px;">
            <i class="fas fa-chalkboard" style="margin-right: 12px;"></i> Quản lý lớp học
        </a>
        <a href="/Staff/TeacherAssignment" class="btn-outline" style="justify-content: flex-start; padding: 16px;">
            <i class="fas fa-people-arrows" style="margin-right: 12px;"></i> Phân công giáo viên
        </a>
        <a href="/Staff/ScheduleManagement" class="btn-outline" style="justify-content: flex-start; padding: 16px;">
            <i class="fas fa-calendar-alt" style="margin-right: 12px;"></i> Quản lý lịch học
        </a>
        <a href="/Staff/ResultManagement" class="btn-outline" style="justify-content: flex-start; padding: 16px;">
            <i class="fas fa-poll" style="margin-right: 12px;"></i> Kết quả học tập
        </a>
    </div>
</div>
