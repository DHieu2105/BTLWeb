@model IEnumerable<BTL_Web.Models.PhongHoc>
@{
    ViewData["Title"] = "Quản lý phòng học";
}

<div class="page-header">
    <div>
        <h2>Quản lý phòng học</h2>
        <p>Quản lý phân công phòng và trạng thái trống, đang sử dụng</p>
    </div>
    <div class="page-actions">
        <button type="button" class="btn-outline" onclick="toggleStaffRoomFilterPanel()"><i class="fas fa-filter"></i> Lọc</button>
    </div>
</div>

<div id="staffRoomFilterPanel" class="card-plain" style="display:none;padding:12px 16px;margin-bottom:16px;">
    <div style="display:grid;grid-template-columns:1fr auto;gap:8px;align-items:end;">
        <div class="form-group" style="margin:0;">
            <label class="form-label">Bộ lọc nhanh</label>
            <input id="staffRoomFilterInput" type="text" class="form-control" placeholder="Lọc theo phòng, trung tâm, giáo viên..." oninput="applyStaffRoomFilter()">
        </div>
        <button type="button" class="btn-outline" onclick="clearStaffRoomFilter()">Xóa lọc</button>
    </div>
</div>

<!-- Stats -->
<div class="stats-grid" style="grid-template-columns:repeat(4,1fr);margin-bottom:24px;">
    <div class="stat-card blue">
        <div class="stat-card-header"><div class="stat-icon blue"><i class="fas fa-door-open"></i></div></div>
        <div class="stat-label">Tổng số phòng</div>
        <div class="stat-value">@(Model?.Count() ?? 0)</div>
    </div>
    <div class="stat-card teal">
        <div class="stat-card-header"><div class="stat-icon teal"><i class="fas fa-check-circle"></i></div></div>
        <div class="stat-label">Phòng trống</div>
        <div class="stat-value">@(Model?.Count() ?? 0)</div>
    </div>
    <div class="stat-card orange">
        <div class="stat-card-header"><div class="stat-icon orange"><i class="fas fa-tools"></i></div></div>
        <div class="stat-label">Việc chờ xử lý</div>
        <div class="stat-value">3</div>
    </div>
    <div class="stat-card green">
        <div class="stat-card-header"><div class="stat-icon blue"><i class="fas fa-chart-pie"></i></div></div>
        <div class="stat-label">Mức sử dụng</div>
        <div class="stat-value">78%</div>
    </div>
</div>

<!-- Room Cards Grid -->
<div style="margin-bottom:24px;">
    <div class="section-heading">
        <h4>Tổng quan phòng</h4>
        <div style="display:flex;gap:8px;">
            <span class="chip chip-green">Trống</span>
            <span class="chip chip-yellow">Đang dùng</span>
        </div>
    </div>
    <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:16px;">
        @if (Model != null && Model.Any())
        {
            @foreach (var ph in Model)
            {
                var inUse = ph.LopHocs.Any();
                <div class="card-plain staff-room-card" style="padding:20px;border-left:4px solid @(inUse ? "#f97316" : "#10b981");">
                    <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:12px;">
                        <div>
                            <div class="user-name">@ph.TenPhong</div>
                            <div class="user-sub">@ph.MaPhong</div>
                        </div>
                        <span class="chip @(inUse ? "chip-yellow" : "chip-green")" style="font-size:10px;">
                            @(inUse ? "Đang dùng" : "Trống")
                        </span>
                    </div>
                    <div class="user-sub" style="margin-bottom:8px;">
                        <i class="fas fa-building" style="margin-right:4px;"></i>
                        @(ph.MaTrungTamNavigation?.TenTrungTam ?? "—")
                    </div>
                    <div class="user-sub">
                        <i class="fas fa-graduation-cap" style="margin-right:4px;"></i>
                        @ph.LopHocs.Count lớp
                    </div>
                    <div style="display:flex;gap:8px;margin-top:12px;">
                        <button class="btn-outline btn-sm" style="flex:1;justify-content:center;">
                            <i class="fas fa-calendar"></i> Lịch phòng
                        </button>
                    </div>
                </div>
            }
        }
        else
        {
            <div style="grid-column:1/-1;"><div class="empty-state"><i class="fas fa-door-open"></i><p>Không tìm thấy phòng học nào</p></div></div>
        }
    </div>
</div>

<!-- Staff Table -->
<div class="card-plain" style="padding:0;">
    <div class="card-header-plain">
        <h5>Phân công phòng - nhân sự</h5>
        <div style="display:flex;gap:8px;align-items:center;">
            <span class="small text-muted">Lọc theo:</span>
            <select class="form-control form-select" style="width:140px;padding:6px 12px;font-size:13px;">
                <option>Tất cả phòng</option>
            </select>
        </div>
    </div>
    <table class="data-table">
        <thead>
            <tr>
                <th>Nhân sự</th>
                <th>Phòng được phân công</th>
                <th>Lịch</th>
                <th>Sức chứa</th>
                <th>Trạng thái</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                @foreach (var ph in Model.Take(5))
                {
                    @foreach (var lop in ph.LopHocs.Take(1))
                    {
                        var gvName = lop.MaGvNavigation?.Ten ?? "—";
                        var ini = string.Join("", gvName.Split(' ').Take(2).Select(w => w.FirstOrDefault().ToString().ToUpper()));
                        <tr class="staff-room-assignment-row">
                            <td>
                                <div class="user-row">
                                    <div class="avatar">@ini</div>
                                    <div>
                                        <div class="user-name">@gvName</div>
                                        <div class="user-sub">@(lop.TenLop ?? lop.MaLop)</div>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <div class="user-name">@ph.TenPhong</div>
                                <div class="user-sub">@ph.MaPhong</div>
                            </td>
                            <td class="user-sub">Mon / Wed / Fri</td>
                            <td>
                                <div class="progress-bar-wrap" style="width:80px;margin-bottom:4px;">
                                    <div class="progress-bar-fill" style="width:70%;"></div>
                                </div>
                                <span class="smaller text-muted">@lop.MaHocViens.Count học viên</span>
                            </td>
                            <td><span class="chip chip-green">Đang hoạt động</span></td>
                        </tr>
                    }

                    @section Scripts {
                    <script>
                    function toggleStaffRoomFilterPanel() {
                        const panel = document.getElementById('staffRoomFilterPanel');
                        if (!panel) return;
                        panel.style.display = panel.style.display === 'none' || panel.style.display === '' ? 'block' : 'none';
                    }

                    function applyStaffRoomFilter() {
                        const query = (document.getElementById('staffRoomFilterInput')?.value || '').trim().toLowerCase();

                        document.querySelectorAll('.staff-room-card').forEach(card => {
                            const text = (card.textContent || '').toLowerCase();
                            card.style.display = !query || text.includes(query) ? '' : 'none';
                        });

                        document.querySelectorAll('.staff-room-assignment-row').forEach(row => {
                            const text = (row.textContent || '').toLowerCase();
                            row.style.display = !query || text.includes(query) ? '' : 'none';
                        });
                    }

                    function clearStaffRoomFilter() {
                        const input = document.getElementById('staffRoomFilterInput');
                        if (input) input.value = '';
                        applyStaffRoomFilter();
                    }
                    </script>
                    }
                }
            }
            @if (Model == null || !Model.Any(p => p.LopHocs.Any()))
            {
                <tr><td colspan="5"><div class="empty-state"><i class="fas fa-users-cog"></i><p>Không tìm thấy phân công nào</p></div></td></tr>
            }
        </tbody>
    </table>
</div>
