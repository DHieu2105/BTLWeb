@model IEnumerable<BTL_Web.Models.HocVien>
@{
    ViewData["Title"] = "Student Management";
}

<div class="page-header">
    <div>
        <h2>Student Management</h2>
        <p>Manage enrolled students and their course assignments</p>
    </div>
    <div class="page-actions">
        <button class="btn-outline"><i class="fas fa-filter"></i> Filter</button>
        <a href="/Staff/RegisterStudent" class="btn-primary">
            <i class="fas fa-plus"></i> Register Student
        </a>
    </div>
</div>

<!-- Stats -->
<div class="stats-grid" style="grid-template-columns:repeat(3,1fr);margin-bottom:24px;">
    <div class="stat-card blue">
        <div class="stat-card-header"><div class="stat-icon blue"><i class="fas fa-users"></i></div><span class="stat-badge blue">+8%</span></div>
        <div class="stat-label">Total Students</div>
        <div class="stat-value">@(Model?.Count() ?? 0)</div>
    </div>
    <div class="stat-card teal">
        <div class="stat-card-header"><div class="stat-icon teal"><i class="fas fa-user-clock"></i></div></div>
        <div class="stat-label">Pending Trials</div>
        <div class="stat-value">42</div>
    </div>
    <div class="stat-card orange">
        <div class="stat-card-header"><div class="stat-icon orange"><i class="fas fa-chart-pie"></i></div></div>
        <div class="stat-label">Staff Utilization</div>
        <div class="stat-value">94%</div>
    </div>
</div>

<!-- Table -->
<div class="card-plain" style="padding:0;">
    <div class="card-header-plain">
        <h5>Student Records</h5>
        <div style="display:flex;gap:8px;">
            <button class="btn-outline btn-sm"><i class="fas fa-filter"></i> Filter</button>
            <a href="/Staff/RegisterStudent" class="btn-primary btn-sm"><i class="fas fa-plus"></i> Register</a>
        </div>
    </div>
    <table class="data-table">
        <thead>
            <tr>
                <th>Student</th>
                <th>Enrolled Course</th>
                <th>Class</th>
                <th>Progress</th>
                <th>Status</th>
                <th style="text-align:right;">Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                @foreach (var sv in Model)
                {
                    var initials = string.Join("", (sv.HoVaTen ?? "?").Split(' ').Take(2).Select(w => w.FirstOrDefault().ToString().ToUpper()));
                    var dk = sv.DangKis?.FirstOrDefault();
                    <tr>
                        <td>
                            <div class="user-row">
                                <div class="avatar">@initials</div>
                                <div>
                                    <div class="user-name">@sv.HoVaTen</div>
                                    <div class="user-sub">@sv.MaHocVien</div>
                                </div>
                            </div>
                        </td>
                        <td>
                            <div class="user-name">@(dk?.MaKhoaHocNavigation?.TenKhoaHoc ?? "—")</div>
                            <div class="user-sub">@(dk?.MaKhoaHoc ?? "—")</div>
                        </td>
                        <td>—</td>
                        <td>
                            <div class="progress-bar-wrap" style="width:80px;margin-bottom:4px;">
                                <div class="progress-bar-fill" style="width:65%;"></div>
                            </div>
                            <span class="smaller text-muted">65%</span>
                        </td>
                        <td><span class="chip chip-green">Active</span></td>
                        <td style="text-align:right;">
                            <div style="display:flex;gap:4px;justify-content:flex-end;">
                                <button class="btn-icon btn-outline btn-sm" title="View"><i class="fas fa-eye"></i></button>
                                <a href="/Staff/AddStudentToClass?studentId=@sv.MaHocVien" class="btn-icon btn-outline btn-sm" title="Add to Class">
                                    <i class="fas fa-chalkboard"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr><td colspan="6"><div class="empty-state"><i class="fas fa-users"></i><p>No students found</p></div></td></tr>
            }
        </tbody>
    </table>
    <div class="pagination-bar">
        <span class="pagination-info">Showing @(Model?.Count() ?? 0) students</span>
        <div class="pagination-btns">
            <button class="page-btn"><i class="fas fa-chevron-left" style="font-size:10px;"></i></button>
            <button class="page-btn active">1</button>
            <button class="page-btn">2</button>
            <button class="page-btn"><i class="fas fa-chevron-right" style="font-size:10px;"></i></button>
        </div>
    </div>
</div>
