@model IEnumerable<BTL_Web.Models.HocVien>
@{
    ViewData["Title"] = "Quản lý học viên";
    int page = ViewBag.Page ?? 1;
    int totalPages = ViewBag.TotalPages ?? 1;
    int pageSize = ViewBag.PageSize ?? 10;
    int totalItems = ViewBag.TotalItems ?? (Model?.Count() ?? 0);

    int startPage = Math.Max(1, page - 1);
    int endPage = Math.Min(totalPages, startPage + 2);
    startPage = Math.Max(1, endPage - 2);
}

<div class="page-header">
    <div>
        <h2>Quản lý học viên</h2>
        <p>Quản lý học viên đã ghi danh và phân công khóa học của họ</p>
    </div>
    <div class="page-actions">
        <button type="button" class="btn-outline" onclick="toggleStaffStudentFilter()"><i class="fas fa-filter"></i> Lọc</button>
        <a href="/Staff/RegisterStudent" class="btn-primary">
            <i class="fas fa-plus"></i> Ghi danh học viên
        </a>
    </div>
</div>

<div id="staffStudentFilterPanel" class="card-plain" style="display:none;padding:12px 16px;margin-bottom:16px;">
    <div style="display:grid;grid-template-columns:1fr auto;gap:8px;align-items:end;">
        <div class="form-group" style="margin:0;">
            <label class="form-label">Bộ lọc nhanh</label>
            <input id="staffStudentFilterInput" type="text" class="form-control" placeholder="Lọc theo học viên, khóa học, lớp..." oninput="applyStaffStudentFilter()">
        </div>
        <button type="button" class="btn-outline" onclick="clearStaffStudentFilter()">Xóa lọc</button>
    </div>
</div>

<div class="stats-grid" style="grid-template-columns:repeat(3,1fr);margin-bottom:24px;">
    <div class="stat-card blue">
        <div class="stat-card-header"><div class="stat-icon blue"><i class="fas fa-users"></i></div><span class="stat-badge blue">+8%</span></div>
        <div class="stat-label">Tổng học viên</div>
        <div class="stat-value">@(Model?.Count() ?? 0)</div>
    </div>
    <div class="stat-card teal">
        <div class="stat-card-header"><div class="stat-icon teal"><i class="fas fa-user-clock"></i></div></div>
        <div class="stat-label">Học thử đang chờ</div>
        <div class="stat-value">42</div>
    </div>
    <div class="stat-card orange">
        <div class="stat-card-header"><div class="stat-icon orange"><i class="fas fa-chart-pie"></i></div></div>
        <div class="stat-label">Hiệu suất nhân sự</div>
        <div class="stat-value">94%</div>
    </div>
</div>

<div class="card-plain" style="padding:0;">
    <div class="card-header-plain">
        <h5>Danh sách học viên</h5>
        <div style="display:flex;gap:8px;">
            <button type="button" class="btn-outline btn-sm" onclick="toggleStaffStudentFilter()"><i class="fas fa-filter"></i> Lọc</button>
            <a href="/Staff/RegisterStudent" class="btn-primary btn-sm"><i class="fas fa-plus"></i> Ghi danh</a>
        </div>
    </div>
    <table class="data-table">
        <thead>
            <tr>
                <th>Học viên</th>
                <th>Khóa học đã ghi danh</th>
                <th>Lớp</th>
                <th>Tiến độ</th>
                <th>Trạng thái</th>
                <th style="text-align:right;">Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                @foreach (var sv in Model)
                {
                    var initials = string.Join("", (sv.HoVaTen ?? "?").Split(' ').Take(2).Select(w => w.FirstOrDefault().ToString().ToUpper()));
                    var dk = sv.DangKis?.FirstOrDefault();
                    <tr class="staff-student-row">
                        <td>
                            <div class="user-row">
                                <div class="avatar">@initials</div>
                                <div>
                                    <div class="user-name">@sv.HoVaTen</div>
                                    <div class="user-sub">@sv.MaHocVien</div>
                                </div>
                            </div>
                        </td>
                        <td>
                            <div class="user-name">@(dk?.MaKhoaHocNavigation?.TenKhoaHoc ?? "—")</div>
                            <div class="user-sub">@(dk?.MaKhoaHoc ?? "—")</div>
                        </td>
                        <td>—</td>
                        <td>
                            <div class="progress-bar-wrap" style="width:80px;margin-bottom:4px;">
                                <div class="progress-bar-fill" style="width:65%;"></div>
                            </div>
                            <span class="smaller text-muted">65%</span>
                        </td>
                        <td><span class="chip chip-green">Đang hoạt động</span></td>
                        <td style="text-align:right;">
                            <div style="display:flex;gap:4px;justify-content:flex-end;">
                                <button class="btn-icon btn-outline btn-sm" title="Xem"><i class="fas fa-eye"></i></button>
                                <button class="btn-icon btn-outline btn-sm" title="Chỉnh sửa" onclick="openEditStudent('@sv.MaHocVien','@Html.Raw((sv.HoVaTen ?? "").Replace("'", "\\'"))','@Html.Raw((sv.Sdt ?? "").Replace("'", "\\'"))','@sv.GioiTinh')">
                                    <i class="fas fa-pen"></i>
                                </button>
                                <a href="/Staff/AddStudentToClass?studentId=@sv.MaHocVien" class="btn-icon btn-outline btn-sm" title="Thêm vào lớp">
                                    <i class="fas fa-chalkboard"></i>
                                </a>
                                <button class="btn-icon btn-outline btn-sm" title="Xóa" onclick="deleteStudent('@sv.MaHocVien')">
                                    <i class="fas fa-trash" style="color:#ef4444;"></i>
                                </button>
                            </div>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr><td colspan="6"><div class="empty-state"><i class="fas fa-users"></i><p>Không tìm thấy học viên nào</p></div></td></tr>
            }
            <tr id="staffStudentFilterEmptyRow" style="display:none;"><td colspan="6"><div class="empty-state"><i class="fas fa-filter"></i><p>Không có học viên nào khớp với bộ lọc hiện tại</p></div></td></tr>
        </tbody>
    </table>
    <div class="pagination-bar">
        <span class="pagination-info">Đang hiển thị @(Model?.Count() ?? 0) / @totalItems học viên</span>
        <div class="pagination-btns">
            <a class="page-btn" href="/Staff/StudentManagement?page=@Math.Max(1, page - 1)&pageSize=@pageSize"><i class="fas fa-chevron-left" style="font-size:10px;"></i></a>
            @for (int p = startPage; p <= endPage; p++)
            {
                if (p == page)
                {
                    <span class="page-btn active">@p</span>
                }
                else
                {
                    <a class="page-btn" href="/Staff/StudentManagement?page=@p&pageSize=@pageSize">@p</a>
                }
            }
            <a class="page-btn" href="/Staff/StudentManagement?page=@Math.Min(totalPages, page + 1)&pageSize=@pageSize"><i class="fas fa-chevron-right" style="font-size:10px;"></i></a>
        </div>
    </div>
</div>

<div id="editModal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.4);z-index:2000;align-items:center;justify-content:center;">
    <div style="background:white;border-radius:12px;padding:32px;width:480px;max-width:90vw;">
        <h4 style="margin-bottom:24px;">Chỉnh sửa học viên</h4>
        <form method="post" action="/Staff/EditStudent">
            @Html.AntiForgeryToken()
            <input type="hidden" name="MaHocVien" id="editMaHocVien">
            <div class="form-group">
                <label class="form-label">Mã học viên</label>
                <input type="text" id="editMaHocVienReadonly" class="form-control" readonly>
            </div>
            <div class="form-group">
                <label class="form-label">Họ và tên</label>
                <input type="text" name="HoVaTen" id="editHoVaTen" class="form-control" required>
            </div>
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;">
                <div class="form-group">
                    <label class="form-label">Số điện thoại</label>
                    <input type="text" name="Sdt" id="editSdt" class="form-control">
                </div>
                <div class="form-group">
                    <label class="form-label">Giới tính</label>
                    <select name="GioiTinh" id="editGioiTinh" class="form-control form-select">
                        <option value="Nam">Nam</option>
                        <option value="Nu">Nữ</option>
                    </select>
                </div>
            </div>
            <div style="display:flex;gap:12px;justify-content:flex-end;margin-top:24px;">
                <button type="button" class="btn-outline" onclick="document.getElementById('editModal').style.display='none'">Hủy</button>
                <button type="submit" class="btn-primary">Lưu thay đổi</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
<script>
function toggleStaffStudentFilter() {
    const panel = document.getElementById('staffStudentFilterPanel');
    if (!panel) return;
    panel.style.display = panel.style.display === 'none' || panel.style.display === '' ? 'block' : 'none';
}

function applyStaffStudentFilter() {
    const query = (document.getElementById('staffStudentFilterInput')?.value || '').trim().toLowerCase();
    const rows = document.querySelectorAll('.staff-student-row');
    let visible = 0;

    rows.forEach(row => {
        const text = (row.textContent || '').toLowerCase();
        const show = !query || text.includes(query);
        row.style.display = show ? '' : 'none';
        if (show) visible++;
    });

    const emptyRow = document.getElementById('staffStudentFilterEmptyRow');
    if (emptyRow) emptyRow.style.display = visible === 0 ? '' : 'none';
}

function clearStaffStudentFilter() {
    const input = document.getElementById('staffStudentFilterInput');
    if (input) input.value = '';
    applyStaffStudentFilter();
}

function openEditStudent(id, name, phone, gender) {
    document.getElementById('editMaHocVien').value = id;
    document.getElementById('editMaHocVienReadonly').value = id;
    document.getElementById('editHoVaTen').value = name || '';
    document.getElementById('editSdt').value = phone || '';
    document.getElementById('editGioiTinh').value = gender || 'Nam';
    document.getElementById('editModal').style.display = 'flex';
}

function deleteStudent(id) {
    if (!confirm('Xóa học viên ' + id + '?')) return;

    const tokenInput = document.querySelector('input[name="__RequestVerificationToken"]');
    const form = document.createElement('form');
    form.method = 'post';
    form.action = '/Staff/DeleteStudent';
    form.innerHTML = '<input type="hidden" name="maHocVien" value="' + id + '" />' +
        '<input type="hidden" name="__RequestVerificationToken" value="' + (tokenInput ? tokenInput.value : '') + '" />';
    document.body.appendChild(form);
    form.submit();
}
</script>
}
