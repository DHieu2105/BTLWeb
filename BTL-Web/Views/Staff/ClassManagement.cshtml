@model IEnumerable<BTL_Web.Models.LopHoc>
@{
    ViewData["Title"] = "Class Management";
}

<div class="page-header">
    <div>
        <h2>Class Management</h2>
        <p>Manage and monitor all active class sessions</p>
    </div>
    <div class="page-actions">
        <button class="btn-outline"><i class="fas fa-filter"></i> Filter</button>
        <button class="btn-primary" onclick="document.getElementById('addModal').style.display='flex'">
            <i class="fas fa-plus"></i> New Class
        </button>
    </div>
</div>

<!-- Stats -->
<div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:24px;">
    <div class="card-plain" style="padding:20px;display:flex;align-items:center;gap:16px;">
        <div class="stat-icon blue" style="width:56px;height:56px;border-radius:12px;flex-shrink:0;"><i class="fas fa-graduation-cap" style="font-size:20px;"></i></div>
        <div>
            <div class="stat-label">Total Classes</div>
            <div class="stat-value">@(Model?.Count() ?? 0)</div>
        </div>
    </div>
    <div class="card-plain" style="padding:20px;display:flex;align-items:center;gap:16px;">
        <div class="stat-icon teal" style="width:56px;height:56px;border-radius:12px;flex-shrink:0;"><i class="fas fa-users" style="font-size:20px;"></i></div>
        <div>
            <div class="stat-label">Total Enrolled</div>
            <div class="stat-value">@(Model?.Sum(l => l.MaHocViens?.Count ?? 0) ?? 0)</div>
        </div>
    </div>
</div>

<!-- Filter + Table -->
<div class="card-plain" style="padding:0;">
    <div style="padding:16px 24px;border-bottom:1px solid var(--surface-low);display:flex;align-items:center;gap:8px;">
        <select class="form-control form-select" style="width:160px;padding:6px 12px;font-size:13px;">
            <option>All Courses</option>
        </select>
        <select class="form-control form-select" style="width:160px;padding:6px 12px;font-size:13px;">
            <option>All Teachers</option>
        </select>
        <select class="form-control form-select" style="width:160px;padding:6px 12px;font-size:13px;">
            <option>Current Semester</option>
        </select>
        <button class="btn-primary btn-sm" style="margin-left:auto;" onclick="document.getElementById('addModal').style.display='flex'">
            <i class="fas fa-plus"></i> New Class
        </button>
    </div>
    <table class="data-table">
        <thead>
            <tr>
                <th>Class</th>
                <th>Teacher</th>
                <th>Schedule</th>
                <th>Capacity</th>
                <th>Status</th>
                <th style="text-align:right;">Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                @foreach (var lh in Model)
                {
                    <tr>
                        <td>
                            <div>
                                <div class="user-name">@(lh.TenLop ?? lh.MaLop)</div>
                                <div class="user-sub">@(lh.MaKhoaHocNavigation?.TenKhoaHoc ?? lh.MaKhoaHoc)</div>
                            </div>
                        </td>
                        <td>
                            <div class="user-row">
                                <div class="avatar avatar-sm">@(lh.MaGvNavigation?.Ten?.Substring(0,2).ToUpper() ?? "?")</div>
                                <div class="user-name" style="font-size:13px;">@(lh.MaGvNavigation?.Ten ?? "—")</div>
                            </div>
                        </td>
                        <td>
                            <div class="user-name">@(lh.MaPhongNavigation?.TenPhong ?? "TBD")</div>
                            <div class="user-sub">@(lh.MaGvNavigation?.Ten ?? "—")</div>
                        </td>
                        <td>
                            <div class="progress-bar-wrap" style="width:80px;margin-bottom:4px;">
                                <div class="progress-bar-fill" style="width:100%;"></div>
                            </div>
                            <span class="smaller text-muted">@(lh.MaHocViens?.Count ?? 0) students</span>
                        </td>
                        <td><span class="chip chip-green">Active</span></td>
                        <td style="text-align:right;">
                            <div style="display:flex;gap:4px;justify-content:flex-end;">
                                <a href="/Staff/ClassDetail/@lh.MaLop" class="btn-icon btn-outline btn-sm"><i class="fas fa-eye"></i></a>
                                <button class="btn-icon btn-outline btn-sm"><i class="fas fa-edit"></i></button>
                            </div>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr><td colspan="6"><div class="empty-state"><i class="fas fa-chalkboard"></i><p>No classes found</p></div></td></tr>
            }
        </tbody>
    </table>
    <div class="pagination-bar">
        <span class="pagination-info">Showing @(Model?.Count() ?? 0) classes</span>
        <div class="pagination-btns">
            <button class="page-btn"><i class="fas fa-chevron-left" style="font-size:10px;"></i></button>
            <button class="page-btn active">1</button>
            <button class="page-btn">2</button>
            <button class="page-btn"><i class="fas fa-chevron-right" style="font-size:10px;"></i></button>
        </div>
    </div>
</div>

<!-- Add Modal -->
<div id="addModal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.4);z-index:2000;align-items:center;justify-content:center;">
    <div style="background:white;border-radius:12px;padding:32px;width:480px;max-width:90vw;">
        <h4 style="margin-bottom:24px;">Create New Class</h4>
        <form method="post" action="/Staff/AddClass">
            @Html.AntiForgeryToken()
            <div class="form-group">
                <label class="form-label">Class Name</label>
                <input type="text" name="TenLop" class="form-control" required>
            </div>
            <div style="display:flex;gap:12px;justify-content:flex-end;margin-top:24px;">
                <button type="button" class="btn-outline" onclick="document.getElementById('addModal').style.display='none'">Cancel</button>
                <button type="submit" class="btn-primary">Create</button>
            </div>
        </form>
    </div>
</div>
