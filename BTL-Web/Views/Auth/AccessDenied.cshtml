@{
    ViewData["Title"] = "Từ chối truy cập";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                <div class="card-body text-center p-5">
                    <div class="mb-4">
                        <i class="fas fa-shield-alt" style="font-size: 5rem; color: #dc3545; opacity: 0.8;"></i>
                    </div>

                    <h2 class="fw-bold mb-2" style="color: #dc3545;">Từ chối truy cập</h2>

                    <p class="lead text-muted mb-3">Bạn không có quyền truy cập vào trang này.</p>
                    <p class="text-muted mb-5">Nếu bạn cho rằng đây là nhầm lẫn, hãy liên hệ quản trị viên hệ thống.</p>

                    <div class="d-flex gap-2 justify-content-center flex-wrap">
                        <a href="/Home/Index" class="btn btn-primary btn-lg rounded-3">
                            <i class="fas fa-home me-2"></i>Trang chủ
                        </a>
                        <a href="/Auth/Profile" class="btn btn-outline-secondary btn-lg rounded-3">
                            <i class="fas fa-user me-2"></i>Hồ sơ của tôi
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
