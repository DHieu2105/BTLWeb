@{
    ViewData["Title"] = "Truy Cập Bị Từ Chối";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                <div class="card-body text-center p-5">
                    <!-- Icon -->
                    <div class="mb-4">
                        <i class="fas fa-shield-alt" style="font-size: 5rem; color: #dc3545; opacity: 0.8;"></i>
                    </div>

                    <!-- Title -->
                    <h2 class="fw-bold mb-2" style="color: #dc3545;">Truy Cập Bị Từ Chối</h2>
                    
                    <!-- Message -->
                    <p class="lead text-muted mb-3">Bạn không có các quyền hạn cần thiết để truy cập vào trang này.</p>
                    <p class="text-muted mb-5">Nếu bạn cho rằng đây là một lỗi, vui lòng liên hệ với quản trị viên của hệ thống.</p>

                    <!-- Action Buttons -->
                    <div class="d-flex gap-2 justify-content-center flex-wrap">
                        <a href="/Home/Index" class="btn btn-primary btn-lg rounded-3">
                            <i class="fas fa-home me-2"></i>Trang Chủ
                        </a>
                        <a href="/Auth/Profile" class="btn btn-outline-secondary btn-lg rounded-3">
                            <i class="fas fa-user me-2"></i>Hồ Sơ Cá Nhân
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
