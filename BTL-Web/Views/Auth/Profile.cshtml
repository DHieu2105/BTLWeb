@{
    ViewData["Title"] = "Thông tin cá nhân";
    var profileImageUrl = ViewBag.ProfileImageUrl as string;
    var username = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
    var fullName = User.FindFirst(System.Security.Claims.ClaimTypes.Name)?.Value;
    var userRole = User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value;
}

<div class="container py-5">
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <strong>Thành công!</strong> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <strong>Lỗi!</strong> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="row mb-5">
        <div class="col-12">
            <div class="d-flex align-items-center">
                <div>
                    <h1 class="mb-1 fw-bold"><i class="fas fa-user-circle me-3" style="color: #667eea;"></i>Hồ sơ cá nhân</h1>
                    <p class="text-muted mb-0">Quản lý thông tin tài khoản của bạn</p>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-body p-4 text-center">
                    @if (!string.IsNullOrWhiteSpace(profileImageUrl))
                    {
                        <img src="@profileImageUrl" alt="Ảnh hồ sơ" class="img-fluid mb-3" style="width:140px;height:140px;border-radius:24px;object-fit:cover;border:1px solid #dee2e6;">
                    }
                    else
                    {
                        <div class="d-inline-flex align-items-center justify-content-center mb-3" style="width:140px;height:140px;border-radius:24px;background:linear-gradient(135deg,#667eea 0%,#764ba2 100%);color:white;font-size:56px;font-weight:700;">
                            @((fullName ?? username ?? "U").Substring(0, 1).ToUpper())
                        </div>
                    }

                    <h4 class="fw-bold mb-1">@(fullName ?? "Chưa cập nhật")</h4>
                    <p class="text-muted mb-3">@username</p>
                    <span class="badge bg-primary-subtle text-primary-emphasis px-3 py-2 rounded-pill">
                        @(userRole switch
                        {
                            "Admin" => "Quản trị viên",
                            "GiaoVien" => "Giáo viên",
                            "HocVien" => "Học viên",
                            "NhanVien" => "Nhân viên",
                            _ => userRole ?? "Người dùng"
                        })
                    </span>

                    <form method="post" action="@Url.Action("UploadProfileImage", "Auth")" enctype="multipart/form-data" class="mt-4 text-start">
                        @Html.AntiForgeryToken()
                        <label class="form-label fw-semibold">Ảnh hồ sơ</label>
                        <input type="file" name="image" class="form-control" accept=".jpg,.jpeg,.png,.webp" required>
                        <div class="form-text">Dung lượng tối đa 2MB. Định dạng: JPG, JPEG, PNG, WEBP.</div>
                        <button type="submit" class="btn btn-outline-primary mt-3 rounded-3 w-100">
                            <i class="fas fa-upload me-2"></i>Cập nhật ảnh
                        </button>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-4 h-100 overflow-hidden">
                <div class="card-header text-white p-4" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
                    <h5 class="mb-0 fw-bold"><i class="fas fa-id-card me-2"></i>Thông tin tài khoản</h5>
                </div>
                <div class="card-body p-4">
                    <div class="row g-4">
                        <div class="col-md-6">
                            <div class="p-3 rounded-3 bg-light h-100">
                                <div class="text-muted small mb-1"><i class="fas fa-user me-2 text-primary"></i>Tên đăng nhập</div>
                                <div class="fw-bold fs-5">@username</div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="p-3 rounded-3 bg-light h-100">
                                <div class="text-muted small mb-1"><i class="fas fa-badge me-2 text-primary"></i>Vai trò</div>
                                <div class="fw-bold fs-5">@(userRole ?? "—")</div>
                            </div>
                        </div>
                        <div class="col-12">
                            <div class="p-3 rounded-3 bg-light h-100">
                                <div class="text-muted small mb-1"><i class="fas fa-address-card me-2 text-primary"></i>Họ tên</div>
                                <div class="fw-bold fs-5">@(fullName ?? "Chưa cập nhật")</div>
                            </div>
                        </div>
                    </div>

                    @if (Model != null)
                    {
                        var model = (dynamic)Model;
                        var account = (dynamic?)model.Account;
                        var accountType = account?.Role?.ToString() ?? "";
                        var linkedCode = User.FindFirst("MaNV")?.Value
                            ?? User.FindFirst("MaGV")?.Value
                            ?? User.FindFirst("MaHocVien")?.Value
                            ?? "Chưa cập nhật";

                        <div class="mt-4 pt-4 border-top">
                            <h6 class="fw-bold mb-3">Thông tin mở rộng</h6>
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <div class="p-3 rounded-3 border h-100">
                                        <div class="text-muted small mb-1">Loại tài khoản</div>
                                        <div class="fw-semibold">@(accountType == "" ? "Chưa xác định" : accountType)</div>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="p-3 rounded-3 border h-100">
                                        <div class="text-muted small mb-1">Mã tài khoản</div>
                                        <div class="fw-semibold">@(account?.Username ?? "Chưa xác định")</div>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="p-3 rounded-3 border h-100">
                                        <div class="text-muted small mb-1">Mã liên kết</div>
                                        <div class="fw-semibold">@linkedCode</div>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="p-3 rounded-3 border h-100">
                                        <div class="text-muted small mb-1">Trạng thái</div>
                                        <div class="fw-semibold">@(string.IsNullOrWhiteSpace(accountType) ? "Chưa cập nhật" : "Đã liên kết")</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
