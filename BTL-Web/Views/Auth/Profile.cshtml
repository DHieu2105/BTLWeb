@{
    ViewData["Title"] = "Thông Tin Cá Nhân";
}

<div class="container py-5">
    <!-- Header -->
    <div class="row mb-5">
        <div class="col-12">
            <div class="d-flex align-items-center">
                <div>
                    <h1 class="mb-1 fw-bold"><i class="fas fa-user-circle me-3" style="color: #667eea;"></i>Hồ Sơ Cá Nhân</h1>
                    <p class="text-muted mb-0">Quản lý thông tin tài khoản của bạn</p>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <!-- Profile Info Card -->
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                <div class="card-header text-white p-4" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
                    <h5 class="mb-0 fw-bold"><i class="fas fa-id-card me-2"></i>Thông Tin Tài Khoản</h5>
                </div>
                <div class="card-body p-4">
                    @if (Model != null)
                    {
                        var username = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
                        var fullName = User.FindFirst(System.Security.Claims.ClaimTypes.Name)?.Value;
                        var userRole = User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value;

                        <!-- Username and Role -->
                        <div class="row mb-4 pb-3 border-bottom">
                            <div class="col-md-6">
                                <h6 class="text-muted mb-2"><i class="fas fa-user me-2 text-primary"></i>Tên Đăng Nhập</h6>
                                <p class="h5 fw-bold">@username</p>
                            </div>
                            <div class="col-md-6">
                                <h6 class="text-muted mb-2"><i class="fas fa-badge me-2 text-primary"></i>Vai Trò</h6>
                                <p>
                                    @{
                                        string roleBadgeClass = userRole switch
                                        {
                                            "Admin" => "danger",
                                            "GiaoVien" => "success",
                                            "HocVien" => "info",
                                            "NhanVien" => "warning",
                                            _ => "secondary"
                                        };
                                    }
                                    <span class="badge bg-@roleBadgeClass p-2 fs-6">
                                        @(userRole switch
                                        {
                                            "Admin" => "👑 Quản Trị Viên",
                                            "GiaoVien" => "👨‍🏫 Giáo Viên",
                                            "HocVien" => "👨‍🎓 Học Viên",
                                            "NhanVien" => "👔 Nhân Viên",
                                            _ => userRole
                                        })
                                    </span>
                                </p>
                            </div>
                        </div>

                        <!-- Full Name -->
                        <div class="row mb-4 pb-3 border-bottom">
                            <div class="col-12">
                                <h6 class="text-muted mb-2"><i class="fas fa-address-card me-2 text-primary"></i>Họ Tên</h6>
                                <p class="h5 fw-bold">@(fullName ?? "Chưa cập nhật")</p>
                            </div>
                        </div>

                        @if (Model?.Account != null)
                        {
                            var account = (dynamic)Model.Account;
                            <div class="row mb-4 pb-3 border-bottom">
                                @if (account.Sdt != null)
                                {
                                    <div class="col-md-6 mb-3 mb-md-0">
                                        <h6 class="text-muted mb-2"><i class="fas fa-phone me-2 text-primary"></i>Số Điện Thoại</h6>
                                        <p class="h6 fw-semibold">@account.Sdt</p>
                                    </div>
                                }

                                @if (account.GioiTinh != null)
                                {
                                    <div class="col-md-6">
                                        <h6 class="text-muted mb-2"><i class="fas fa-venus-mars me-2 text-primary"></i>Giới Tính</h6>
                                        <p class="h6 fw-semibold">@account.GioiTinh</p>
                                    </div>
                                }
                            </div>

                            @if (account.ChucVu != null || account.ChuyenMon != null || account.MaTrungTam != null)
                            {
                                <div class="row mb-4 pb-3 border-bottom">
                                    @if (account.ChucVu != null)
                                    {
                                        <div class="col-md-6 mb-3 mb-md-0">
                                            <h6 class="text-muted mb-2"><i class="fas fa-briefcase me-2 text-primary"></i>Chức Vụ</h6>
                                            <p class="h6 fw-semibold">@account.ChucVu</p>
                                        </div>
                                    }

                                    @if (account.ChuyenMon != null)
                                    {
                                        <div class="col-md-6">
                                            <h6 class="text-muted mb-2"><i class="fas fa-graduation-cap me-2 text-primary"></i>Chuyên Môn</h6>
                                            <p class="h6 fw-semibold">@account.ChuyenMon</p>
                                        </div>
                                    }
                                </div>
                            }

                            @if (account.MaTrungTam != null || account.NgayDangKi != null)
                            {
                                <div class="row">
                                    @if (account.MaTrungTam != null)
                                    {
                                        <div class="col-md-6 mb-3 mb-md-0">
                                            <h6 class="text-muted mb-2"><i class="fas fa-building me-2 text-primary"></i>Trung Tâm</h6>
                                            <p class="h6 fw-semibold">@account.MaTrungTam</p>
                                        </div>
                                    }

                                    @if (account.NgayDangKi != null)
                                    {
                                        <div class="col-md-6">
                                            <h6 class="text-muted mb-2"><i class="fas fa-calendar-alt me-2 text-primary"></i>Ngày Đăng Ký</h6>
                                            <p class="h6 fw-semibold">@((DateTime)account.NgayDangKi).ToString("dd/MM/yyyy")</p>
                                        </div>
                                    }
                                </div>
                            }
                        }

                        <!-- Action Button -->
                        <div class="mt-4 pt-3 border-top">
                            <form method="post" action="/Auth/Logout" style="display:inline;">
                                <button type="submit" class="btn btn-danger btn-lg rounded-3">
                                    <i class="fas fa-sign-out-alt me-2"></i>Đăng Xuất
                                </button>
                            </form>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Sidebar -->
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden mb-4">
                <div class="card-header text-white p-4" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
                    <h5 class="mb-0 fw-bold"><i class="fas fa-info-circle me-2"></i>Thông Tin Vai Trò</h5>
                </div>
                <div class="card-body p-4">
                    <p class="small text-muted mb-3">
                        @{
                            var role = User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value;
                            var roleDescr = role switch
                            {
                                "Admin" => "Bạn có quyền quản lý toàn bộ hệ thống, bao gồm người dùng, khóa học và báo cáo.",
                                "GiaoVien" => "Bạn có quyền quản lý lớp học, điểm số và thông tin học viên.",
                                "HocVien" => "Bạn có quyền xem thông tin khóa học, lịch học và điểm số của mình.",
                                "NhanVien" => "Bạn có quyền quản lý công việc được gán và hỗ trợ quản trị hệ thống.",
                                _ => "Người dùng bình thường"
                            };
                            @roleDescr
                        }
                    </p>
                </div>
            </div>

            <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                <div class="card-header text-white p-4" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
                    <h5 class="mb-0 fw-bold"><i class="fas fa-link me-2"></i>Liên Kết Nhanh</h5>
                </div>
                <div class="card-body p-3">
                    <a href="/Home/Index" class="btn btn-outline-primary w-100 mb-2 rounded-3">
                        <i class="fas fa-home me-2"></i>Trang Chủ
                    </a>
                    @if (User.IsInRole("Admin"))
                    {
                        <a href="/Home/Index" class="btn btn-outline-danger w-100 mb-2 rounded-3">
                            <i class="fas fa-sliders-h me-2"></i>Quản Lý Hệ Thống
                        </a>
                    }
                    @if (User.IsInRole("GiaoVien"))
                    {
                        <a href="/Home/Index" class="btn btn-outline-success w-100 mb-2 rounded-3">
                            <i class="fas fa-chalkboard-user me-2"></i>Quản Lý Lớp Học
                        </a>
                    }
                    <button type="button" class="btn btn-outline-secondary w-100 rounded-3" data-bs-toggle="modal" data-bs-target="#settingsModal">
                        <i class="fas fa-cog me-2"></i>Cài Đặt
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Settings Modal -->
<div class="modal fade" id="settingsModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0">
            <div class="modal-header text-white" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
                <h5 class="modal-title fw-bold"><i class="fas fa-cog me-2"></i>Cài Đặt Tài Khoản</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <p class="text-muted mb-4">Các tùy chọn cài đặt tài khoản sẽ sớm được phát hành:</p>
                <ul class="list-unstyled">
                    <li class="mb-2"><i class="fas fa-lock me-2 text-primary"></i><span>Đổi mật khẩu</span></li>
                    <li class="mb-2"><i class="fas fa-bell me-2 text-primary"></i><span>Cài đặt thông báo</span></li>
                    <li class="mb-2"><i class="fas fa-globe me-2 text-primary"></i><span>Tùy chọn ngôn ngữ</span></li>
                </ul>
            </div>
            <div class="modal-footer border-top">
                <button type="button" class="btn btn-secondary rounded-3" data-bs-dismiss="modal">Đóng</button>
            </div>
        </div>
    </div>
</div>

