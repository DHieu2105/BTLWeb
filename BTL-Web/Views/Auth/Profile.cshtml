@{
    ViewData["Title"] = "Thông Tin Cá Nhân";
}

@functions {
    private static string DisplayValue(object? value)
    {
        return value?.ToString() ?? "Chưa cập nhật";
    }

    private static string FormatDate(object? value)
    {
        if (value is DateOnly dateOnly)
            return dateOnly.ToString("dd/MM/yyyy");

        if (value is DateTime dateTime)
            return dateTime.ToString("dd/MM/yyyy");

        return "Chưa cập nhật";
    }
}

<div class="container py-5">
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <strong>Thành công!</strong> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <strong>Lỗi!</strong> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Header -->
    <div class="row mb-5">
        <div class="col-12">
            <div class="d-flex align-items-center">
                <div>
                    <h1 class="mb-1 fw-bold"><i class="fas fa-user-circle me-3" style="color: #667eea;"></i>Hồ Sơ Cá Nhân</h1>
                    <p class="text-muted mb-0">Quản lý thông tin tài khoản của bạn</p>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <!-- Profile Info Card -->
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                <div class="card-header text-white p-4" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
                    <h5 class="mb-0 fw-bold"><i class="fas fa-id-card me-2"></i>Thông Tin Tài Khoản</h5>
                </div>
                <div class="card-body p-4">
                    @if (Model != null)
                    {
                        var model = (dynamic)Model;
                        var account = (dynamic?)model.Account;
                        var accountType = account?.Type?.ToString() ?? "";
                        var username = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
                        var fullName = User.FindFirst(System.Security.Claims.ClaimTypes.Name)?.Value;
                        var userRole = User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value;

                        <!-- Username and Role -->
                        <div class="row mb-4 pb-3 border-bottom">
                            <div class="col-md-6">
                                <h6 class="text-muted mb-2"><i class="fas fa-user me-2 text-primary"></i>Tên Đăng Nhập</h6>
                                <p class="h5 fw-bold">@username</p>
                            </div>
                            <div class="col-md-6">
                                <h6 class="text-muted mb-2"><i class="fas fa-badge me-2 text-primary"></i>Vai Trò</h6>
                                <p>
                                    @{
                                        string roleBadgeClass = userRole switch
                                        {
                                            "Admin" => "danger",
                                            "GiaoVien" => "success",
                                            "HocVien" => "info",
                                            "NhanVien" => "warning",
                                            _ => "secondary"
                                        };
                                    }
                                    <span class="badge bg-@roleBadgeClass p-2 fs-6">
                                        @(userRole switch
                                        {
                                            "Admin" => "Quản Trị Viên",
                                            "GiaoVien" => "Giáo Viên",
                                            "HocVien" => "Học Viên",
                                            "NhanVien" => "Nhân Viên",
                                            _ => userRole
                                        })
                                    </span>
                                </p>
                            </div>
                        </div>

                        <!-- Full Name -->
                        <div class="row mb-4 pb-3 border-bottom">
                            <div class="col-12">
                                <h6 class="text-muted mb-2"><i class="fas fa-address-card me-2 text-primary"></i>Họ Tên</h6>
                                <p class="h5 fw-bold">@(fullName ?? "Chưa cập nhật")</p>
                            </div>
                        </div>

                        @if (account != null)
                        {
                            <div class="row mb-4 pb-3 border-bottom">
                                @if (accountType == "NhanVien")
                                {
                                    <div class="col-md-6 mb-3 mb-md-0">
                                        <h6 class="text-muted mb-2"><i class="fas fa-id-badge me-2 text-primary"></i>Mã Nhân Viên</h6>
                                        <p class="h6 fw-semibold">@DisplayValue(account.MaNv)</p>
                                    </div>
                                }
                                else if (accountType == "GiaoVien")
                                {
                                    <div class="col-md-6 mb-3 mb-md-0">
                                        <h6 class="text-muted mb-2"><i class="fas fa-id-badge me-2 text-primary"></i>Mã Giáo Viên</h6>
                                        <p class="h6 fw-semibold">@DisplayValue(account.MaGv)</p>
                                    </div>
                                }
                                else if (accountType == "HocVien")
                                {
                                    <div class="col-md-6 mb-3 mb-md-0">
                                        <h6 class="text-muted mb-2"><i class="fas fa-id-badge me-2 text-primary"></i>Mã Học Viên</h6>
                                        <p class="h6 fw-semibold">@DisplayValue(account.MaHocVien)</p>
                                    </div>
                                }

                                <div class="col-md-6">
                                    <h6 class="text-muted mb-2"><i class="fas fa-building me-2 text-primary"></i>Mã Trung Tâm</h6>
                                    <p class="h6 fw-semibold">@DisplayValue(account.MaTrungTam)</p>
                                </div>
                            </div>

                            <div class="row mb-4 pb-3 border-bottom">
                                <div class="col-md-6 mb-3 mb-md-0">
                                    <h6 class="text-muted mb-2"><i class="fas fa-phone me-2 text-primary"></i>Số Điện Thoại</h6>
                                    <p class="h6 fw-semibold">@DisplayValue(account.Sdt)</p>
                                </div>
                                <div class="col-md-6">
                                    <h6 class="text-muted mb-2"><i class="fas fa-venus-mars me-2 text-primary"></i>Giới Tính</h6>
                                    <p class="h6 fw-semibold">@DisplayValue(account.GioiTinh)</p>
                                </div>
                            </div>

                            @if (accountType == "NhanVien" || accountType == "GiaoVien" || accountType == "HocVien")
                            {
                                <div class="row mb-4 pb-3 border-bottom">
                                    @if (accountType == "NhanVien")
                                    {
                                        <div class="col-md-6 mb-3 mb-md-0">
                                            <h6 class="text-muted mb-2"><i class="fas fa-briefcase me-2 text-primary"></i>Chức Vụ</h6>
                                            <p class="h6 fw-semibold">@DisplayValue(account.ChucVu)</p>
                                        </div>
                                    }

                                    @if (accountType == "GiaoVien")
                                    {
                                        <div class="col-md-6">
                                            <h6 class="text-muted mb-2"><i class="fas fa-graduation-cap me-2 text-primary"></i>Chuyên Môn</h6>
                                            <p class="h6 fw-semibold">@DisplayValue(account.ChuyenMon)</p>
                                        </div>
                                    }

                                    @if (accountType == "HocVien")
                                    {
                                        <div class="col-md-6">
                                            <h6 class="text-muted mb-2"><i class="fas fa-user-tie me-2 text-primary"></i>Mã Nhân Viên Quản Lý</h6>
                                            <p class="h6 fw-semibold">@DisplayValue(account.MaNv)</p>
                                        </div>
                                    }
                                </div>
                            }

                            @if (accountType == "GiaoVien" || accountType == "HocVien")
                            {
                                <div class="row">
                                    @if (accountType == "GiaoVien")
                                    {
                                        <div class="col-md-6 mb-3 mb-md-0">
                                            <h6 class="text-muted mb-2"><i class="fas fa-book me-2 text-primary"></i>Mã Khóa Học</h6>
                                            <p class="h6 fw-semibold">@DisplayValue(account.MaKhoaHoc)</p>
                                        </div>
                                    }

                                    @if (accountType == "HocVien")
                                    {
                                        <div class="col-md-6">
                                            <h6 class="text-muted mb-2"><i class="fas fa-calendar-alt me-2 text-primary"></i>Ngày Đăng Ký</h6>
                                            <p class="h6 fw-semibold">@FormatDate(account.NgayDangKi)</p>
                                        </div>
                                    }
                                </div>
                            }
                        }

                        <!-- Action Button -->
                        <div class="mt-4 pt-3 border-top">
                            <form method="post" action="/Auth/Logout" style="display:inline;">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-danger btn-lg rounded-3">
                                    <i class="fas fa-sign-out-alt me-2"></i>Đăng Xuất
                                </button>
                            </form>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Sidebar -->
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden mb-4">
                <div class="card-header text-white p-4" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
                    <h5 class="mb-0 fw-bold"><i class="fas fa-info-circle me-2"></i>Thông Tin Vai Trò</h5>
                </div>
                <div class="card-body p-4">
                    <p class="small text-muted mb-3">
                        @{
                            var role = User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value;
                            var roleDescr = role switch
                            {
                                "Admin" => "Bạn có quyền quản lý toàn bộ hệ thống, bao gồm người dùng, khóa học và báo cáo.",
                                "GiaoVien" => "Bạn có quyền quản lý lớp học, điểm số và thông tin học viên.",
                                "HocVien" => "Bạn có quyền xem thông tin khóa học, lịch học và điểm số của mình.",
                                "NhanVien" => "Bạn có quyền quản lý công việc được gán và hỗ trợ quản trị hệ thống.",
                                _ => "Người dùng bình thường"
                            };
                            @roleDescr
                        }
                    </p>
                </div>
            </div>

            <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                <div class="card-header text-white p-4" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
                    <h5 class="mb-0 fw-bold"><i class="fas fa-link me-2"></i>Liên Kết Nhanh</h5>
                </div>
                <div class="card-body p-3">
                    <a href="/Home/Index" class="btn btn-outline-primary w-100 mb-2 rounded-3">
                        <i class="fas fa-home me-2"></i>Trang Chủ
                    </a>
                    @if (User.IsInRole("Admin"))
                    {
                        <a href="/Home/Index" class="btn btn-outline-danger w-100 mb-2 rounded-3">
                            <i class="fas fa-sliders-h me-2"></i>Quản Lý Hệ Thống
                        </a>
                    }
                    @if (User.IsInRole("GiaoVien"))
                    {
                        <a href="/Home/Index" class="btn btn-outline-success w-100 mb-2 rounded-3">
                            <i class="fas fa-chalkboard-user me-2"></i>Quản Lý Lớp Học
                        </a>
                    }
                    <button type="button" class="btn btn-outline-secondary w-100 rounded-3" data-bs-toggle="collapse" data-bs-target="#changePasswordForm" aria-expanded="false" aria-controls="changePasswordForm">
                        <i class="fas fa-key me-2"></i>Đổi Mật Khẩu
                    </button>
                </div>
            </div>

            <div class="collapse mt-4" id="changePasswordForm">
                <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                    <div class="card-header text-white p-4" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
                        <h5 class="mb-0 fw-bold"><i class="fas fa-lock me-2"></i>Đổi Mật Khẩu</h5>
                    </div>
                    <div class="card-body p-4">
                        <form method="post" action="@Url.Action("ChangePassword", "Auth")">
                            @Html.AntiForgeryToken()
                            <div class="mb-3">
                                <label for="oldPassword" class="form-label fw-semibold">Mật khẩu hiện tại</label>
                                <input type="password" class="form-control" id="oldPassword" name="oldPassword" required>
                            </div>

                            <div class="mb-3">
                                <label for="newPassword" class="form-label fw-semibold">Mật khẩu mới</label>
                                <input type="password" class="form-control" id="newPassword" name="newPassword" required minlength="6">
                                <div class="form-text">Mật khẩu mới tối thiểu 6 ký tự.</div>
                            </div>

                            <div class="mb-3">
                                <label for="confirmPassword" class="form-label fw-semibold">Xác nhận mật khẩu mới</label>
                                <input type="password" class="form-control" id="confirmPassword" name="confirmPassword" required minlength="6">
                            </div>

                            <button type="submit" class="btn btn-primary w-100 rounded-3">
                                <i class="fas fa-save me-2"></i>Cập Nhật Mật Khẩu
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

