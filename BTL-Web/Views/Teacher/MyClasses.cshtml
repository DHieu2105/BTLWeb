@model IEnumerable<BTL_Web.Models.LopHoc>
@{
    ViewData["Title"] = "My Classes";
    var classList = Model?.ToList() ?? new List<BTL_Web.Models.LopHoc>();
}

<div class="page-header">
    <div>
        <p class="small text-muted" style="margin-bottom:4px;">Teaching Portal</p>
        <h2>My Classes</h2>
        <p>All classes assigned to you this semester</p>
    </div>
    <div class="page-actions">
        <button class="btn-outline"><i class="fas fa-filter"></i> Filter</button>
    </div>
</div>

<!-- Stats -->
<div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:24px;">
    <div class="card-plain" style="padding:20px;display:flex;align-items:center;gap:16px;">
        <div class="stat-icon blue" style="width:56px;height:56px;border-radius:12px;flex-shrink:0;"><i
            class="fas fa-graduation-cap" style="font-size:20px;"></i></div>
            <div>
                <div class="stat-label">Total Classes</div>
                <div class="stat-value">@(Model?.Count() ?? 0)</div>
            </div>
        </div>
        <div class="card-plain" style="padding:20px;display:flex;align-items:center;gap:16px;">
            <div class="stat-icon teal" style="width:56px;height:56px;border-radius:12px;flex-shrink:0;"><i
                class="fas fa-users" style="font-size:20px;"></i></div>
                <div>
                    <div class="stat-label">Total Students</div>
                    <div class="stat-value">@(Model?.Sum(l => l.MaHocViens?.Count ?? 0) ?? 0)</div>
                </div>
            </div>
        </div>

        @{
            var featured = classList.FirstOrDefault();
        }
        @if (featured != null)
        {
            <div class="card-plain"
                 style="padding:0;margin-bottom:24px;display:grid;grid-template-columns:1fr 1fr;overflow:hidden;">
                <div style="padding:32px;border-left:6px solid var(--primary);">
                    <div style="display:flex;gap:8px;margin-bottom:16px;">
                        <span class="chip chip-green">Active</span>
                        <span id="featuredCourse" class="chip chip-blue">@(featured.MaKhoaHocNavigation?.TenKhoaHoc ?? "—")</span>
                    </div>
                    <h3 id="featuredTitle" style="font-size:22px;margin-bottom:8px;">@(featured.TenLop ?? featured.MaLop)</h3>
                    <p class="text-muted" style="margin-bottom:20px;font-size:14px;">Advanced course with focus on structural
                        analysis and professional communication.</p>
                        <div style="display:flex;gap:24px;margin-bottom:20px;">
                            <div>
                                <div class="stat-label">Teacher</div>
                                <div id="featuredTeacher" class="user-name" style="font-size:14px;">@(featured.MaGvNavigation?.Ten ??
                                                                           "—")</div>
                                </div>
                                <div>
                                    <div class="stat-label">Room</div>
                                    <div id="featuredRoom" class="user-name" style="font-size:14px;">@(featured.MaPhongNavigation?.TenPhong
                                                                                                    ?? "TBD")</div>
                                    </div>
                                    <div>
                                        <div class="stat-label">Students</div>
                                        <div id="featuredStudents" class="user-name" style="font-size:14px;">@featured.MaHocViens.Count</div>
                                    </div>
                                </div>
                                <div style="display:flex;gap:8px;">
                                    <a href="/Student/Schedule" class="btn-primary btn-sm"><i class="fas fa-calendar"></i> View Schedule</a>
                                    <a href="/Student/Results" class="btn-outline btn-sm"><i class="fas fa-poll-h"></i> My Results</a>
                                </div>
                            </div>
                            <div
                                style="background:linear-gradient(135deg,var(--sidebar-bg),var(--primary));display:flex;align-items:center;justify-content:center;position:relative;overflow:hidden;">
                                <i class="fas fa-graduation-cap" style="font-size:100px;color:rgba(255,255,255,0.1);"></i>
                            </div>
                        </div>
                    }

                    <!-- All Classes Table -->
                    <div class="card-plain" style="padding:0;">
                        <div class="card-header-plain">
                            <h5>All My Classes</h5>
                            <div style="display:flex;gap:8px;">
                                <button class="filter-btn active">All</button>
                                <button class="filter-btn">Active</button>
                                <button class="filter-btn">Completed</button>
                            </div>
                        </div>
                        <table class="data-table">
                            <thead>
                                <tr>
                                    <th>Class Name</th>
                                    <th>Course</th>
                                    <th>Schedule</th>
                                    <th>Students</th>
                                    <th>Status</th>
                                    <th style="text-align:right;">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (classList.Any())
                                {
                                    @for (int i = 0; i < classList.Count; i++)
                                    {
                                        var lop = classList[i];
                                        <tr>
                                            <td>
                                                <div class="user-name">@(lop.TenLop ?? lop.MaLop)</div>
                                            </td>
                                            <td>
                                                <div class="user-name">@(lop.MaKhoaHocNavigation?.TenKhoaHoc ?? "—")</div>
                                                <div class="user-sub">@lop.MaLop</div>
                                            </td>
                                            <td>
                                                <div class="user-name">@(lop.MaPhongNavigation?.TenPhong ?? "TBD")</div>
                                                <div class="user-sub">@(lop.MaGvNavigation?.Ten ?? "—")</div>
                                            </td>
                                            <td>
                                                <div class="user-name">@(lop.MaHocViens?.Count ?? 0)</div>
                                                <div class="progress-bar-wrap" style="width:60px;margin-top:4px;">
                                                    <div class="progress-bar-fill" style="width:100%;"></div>
                                                </div>
                                            </td>
                                            <td><span class="chip chip-green">Active</span></td>
                                            <td style="text-align:right;">
                                                <div style="display:flex;gap:8px;justify-content:flex-end;">
                                                    <button type="button" class="btn-outline btn-sm feature-btn"
                                                            data-title="@(lop.TenLop ?? lop.MaLop)"
                                                            data-course="@(lop.MaKhoaHocNavigation?.TenKhoaHoc ?? "—")"
                                                            data-teacher="@(lop.MaGvNavigation?.Ten ?? "—")"
                                                            data-room="@(lop.MaPhongNavigation?.TenPhong ?? "TBD")"
                                                            data-students="@lop.MaHocViens.Count">
                                                        <i class="fas fa-star"></i> Show
                                                    </button>
                                                    <a href="/Teacher/ClassDetail/@lop.MaLop" class="btn-outline btn-sm">
                                                        <i class="fas fa-eye"></i> View
                                                    </a>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="6">
                                            <div class="empty-state"><i class="fas fa-graduation-cap"></i>
                                                <p>No classes assigned</p>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                        <div class="pagination-bar">
                            <span class="pagination-info">Showing @(Model?.Count() ?? 0) classes</span>
                            <div class="pagination-btns">
                                <button class="page-btn"><i class="fas fa-chevron-left" style="font-size:10px;"></i></button>
                                <button class="page-btn active">1</button>
                                <button class="page-btn"><i class="fas fa-chevron-right" style="font-size:10px;"></i></button>
                            </div>
                        </div>
                    </div>

                    @section Scripts {
                        <script>
                            document.addEventListener('DOMContentLoaded', function () {
                                const featuredTitle = document.getElementById('featuredTitle');
                                const featuredCourse = document.getElementById('featuredCourse');
                                const featuredTeacher = document.getElementById('featuredTeacher');
                                const featuredRoom = document.getElementById('featuredRoom');
                                const featuredStudents = document.getElementById('featuredStudents');

                                document.querySelectorAll('.filter-btn').forEach(btn => {
                                    btn.addEventListener('click', function () {
                                        document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
                                        this.classList.add('active');
                                    });
                                });

                                document.addEventListener('click', function (event) {
                                    const button = event.target.closest('.feature-btn');
                                    if (!button) {
                                        return;
                                    }

                                    if (!featuredTitle || !featuredCourse || !featuredTeacher || !featuredRoom || !featuredStudents) {
                                        return;
                                    }

                                    featuredTitle.textContent = button.dataset.title || '—';
                                    featuredCourse.textContent = button.dataset.course || '—';
                                    featuredTeacher.textContent = button.dataset.teacher || '—';
                                    featuredRoom.textContent = button.dataset.room || 'TBD';
                                    featuredStudents.textContent = button.dataset.students || '0';
                                });
                            });
                        </script>
                    }
