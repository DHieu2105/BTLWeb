@model IEnumerable<BTL_Web.Models.LopHoc>
@{
    ViewData["Title"] = "My Classes";
}

<div class="page-header">
    <div>
        <p class="small text-muted" style="margin-bottom:4px;">Teaching Portal</p>
        <h2>My Classes</h2>
        <p>All classes assigned to you this semester</p>
    </div>
    <div class="page-actions">
        <button class="btn-outline"><i class="fas fa-filter"></i> Filter</button>
    </div>
</div>

<!-- Stats -->
<div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:24px;">
    <div class="card-plain" style="padding:20px;display:flex;align-items:center;gap:16px;">
        <div class="stat-icon blue" style="width:56px;height:56px;border-radius:12px;flex-shrink:0;"><i class="fas fa-graduation-cap" style="font-size:20px;"></i></div>
        <div>
            <div class="stat-label">Total Classes</div>
            <div class="stat-value">@(Model?.Count() ?? 0)</div>
        </div>
    </div>
    <div class="card-plain" style="padding:20px;display:flex;align-items:center;gap:16px;">
        <div class="stat-icon teal" style="width:56px;height:56px;border-radius:12px;flex-shrink:0;"><i class="fas fa-users" style="font-size:20px;"></i></div>
        <div>
            <div class="stat-label">Total Students</div>
            <div class="stat-value">@(Model?.Sum(l => l.MaHocViens?.Count ?? 0) ?? 0)</div>
        </div>
    </div>
</div>

<!-- Featured Class -->
@{
    var featured = Model?.FirstOrDefault();
}
@if (featured != null)
{
    <div class="card-plain" style="padding:0;margin-bottom:24px;display:grid;grid-template-columns:1fr 1fr;overflow:hidden;">
        <div style="padding:32px;">
            <span class="chip chip-green" style="margin-bottom:16px;">Active</span>
            <h3 style="font-size:24px;margin-bottom:12px;">@(featured.TenLop ?? featured.MaLop)</h3>
            <p class="text-muted" style="margin-bottom:24px;">@(featured.MaKhoaHocNavigation?.TenKhoaHoc ?? "—")</p>
            <div style="display:flex;gap:24px;margin-bottom:24px;">
                <div>
                    <div class="stat-label">Students</div>
                    <div class="stat-value" style="font-size:20px;">@(featured.MaHocViens?.Count ?? 0)</div>
                </div>
                <div>
                    <div class="stat-label">Schedule</div>
                    <div class="stat-value" style="font-size:16px;">@(featured.MaPhongNavigation?.TenPhong ?? "TBD")</div>
                </div>
            </div>
            <a href="/Teacher/ClassDetail/@featured.MaLop" class="btn-primary">
                <i class="fas fa-arrow-right"></i> View Class Details
            </a>
        </div>
        <div style="background:linear-gradient(135deg,var(--sidebar-bg),var(--primary));display:flex;align-items:center;justify-content:center;">
            <i class="fas fa-graduation-cap" style="font-size:80px;color:rgba(255,255,255,0.2);"></i>
        </div>
    </div>
}

<!-- All Classes Table -->
<div class="card-plain" style="padding:0;">
    <div class="card-header-plain">
        <h5>All My Classes</h5>
        <div style="display:flex;gap:8px;">
            <button class="filter-btn active">All</button>
            <button class="filter-btn">Active</button>
            <button class="filter-btn">Completed</button>
        </div>
    </div>
    <table class="data-table">
        <thead>
            <tr>
                <th>Class Name</th>
                <th>Course</th>
                <th>Schedule</th>
                <th>Students</th>
                <th>Status</th>
                <th style="text-align:right;">Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                @foreach (var lh in Model)
                {
                    <tr>
                        <td><div class="user-name">@(lh.TenLop ?? lh.MaLop)</div></td>
                        <td>
                            <div class="user-name">@(lh.MaKhoaHocNavigation?.TenKhoaHoc ?? "—")</div>
                            <div class="user-sub">@lh.MaLop</div>
                        </td>
                        <td>
                            <div class="user-name">@(lh.MaPhongNavigation?.TenPhong ?? "TBD")</div>
                            <div class="user-sub">@(lh.MaGvNavigation?.Ten ?? "—")</div>
                        </td>
                        <td>
                            <div class="user-name">@(lh.MaHocViens?.Count ?? 0)</div>
                            <div class="progress-bar-wrap" style="width:60px;margin-top:4px;">
                                <div class="progress-bar-fill" style="width:100%;"></div>
                            </div>
                        </td>
                        <td><span class="chip chip-green">Active</span></td>
                        <td style="text-align:right;">
                            <a href="/Teacher/ClassDetail/@lh.MaLop" class="btn-outline btn-sm">
                                <i class="fas fa-eye"></i> View
                            </a>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr><td colspan="6"><div class="empty-state"><i class="fas fa-graduation-cap"></i><p>No classes assigned</p></div></td></tr>
            }
        </tbody>
    </table>
    <div class="pagination-bar">
        <span class="pagination-info">Showing @(Model?.Count() ?? 0) classes</span>
        <div class="pagination-btns">
            <button class="page-btn"><i class="fas fa-chevron-left" style="font-size:10px;"></i></button>
            <button class="page-btn active">1</button>
            <button class="page-btn"><i class="fas fa-chevron-right" style="font-size:10px;"></i></button>
        </div>
    </div>
</div>

@section Scripts {
<script>
document.querySelectorAll('.filter-btn').forEach(btn => {
    btn.addEventListener('click', function() {
        document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
        this.classList.add('active');
    });
});
</script>
}
