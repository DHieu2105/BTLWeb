@model IEnumerable<BTL_Web.Models.LopHoc>
@{
    ViewData["Title"] = "My Schedule";
}

<div class="page-header">
    <div>
        <h2>My Schedule</h2>
        <p>Your weekly teaching schedule and upcoming sessions</p>
    </div>
    <div class="page-actions">
        <div style="background:var(--surface-high);border-radius:8px;padding:4px;display:flex;gap:4px;">
            <button class="filter-btn active">Week</button>
            <button class="filter-btn">Month</button>
            <button class="filter-btn">List</button>
        </div>
    </div>
</div>

<!-- Stats -->
<div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:16px;margin-bottom:24px;">
    <div class="card-plain" style="padding:20px;border-left:4px solid var(--primary);">
        <div class="stat-label">Today's Load</div>
        <div style="display:flex;align-items:baseline;gap:8px;margin-top:4px;">
            <div class="stat-value">@(Model?.Count() ?? 0)</div>
            <span class="small text-muted">classes</span>
        </div>
        <div style="display:flex;gap:-4px;margin-top:8px;">
            @foreach (var lop in (Model ?? new List<BTL_Web.Models.LopHoc>()).Take(3))
            {
                var n = lop.MaGvNavigation?.Ten ?? "?";
                var ini = string.Join("", n.Split(' ').Take(2).Select(w => w.FirstOrDefault().ToString().ToUpper()));
                <div class="avatar avatar-sm" style="margin-right:-6px;border:2px solid white;">@ini</div>
            }
        </div>
    </div>
    <div class="card-plain" style="padding:20px;border-left:4px solid #0891b2;">
        <div class="stat-label">Room Occupancy</div>
        <div class="stat-value" style="margin-top:4px;">75%</div>
        <div class="progress-bar-wrap" style="margin-top:8px;"><div class="progress-bar-fill" style="width:75%;background:#0891b2;"></div></div>
    </div>
    <div class="card-plain" style="padding:20px;background:var(--sidebar-bg);color:white;">
        <div class="stat-label" style="color:rgba(255,255,255,0.6);">Next Session</div>
        @{
            var nextClass = Model?.FirstOrDefault();
        }
        <div class="stat-value" style="color:white;font-size:16px;margin-top:4px;">
            @(nextClass?.TenLop ?? "No upcoming class")
        </div>
        <button class="btn-outline btn-sm" style="margin-top:12px;background:rgba(255,255,255,0.15);color:white;border:none;">
            View Details
        </button>
    </div>
</div>

<!-- Weekly Calendar -->
<div class="card-plain" style="padding:0;margin-bottom:24px;">
    <div style="padding:24px 32px;border-bottom:1px solid var(--surface-low);display:flex;align-items:center;justify-content:space-between;">
        <div style="display:flex;align-items:center;gap:16px;">
            <button class="btn-icon btn-outline"><i class="fas fa-chevron-left"></i></button>
            <h5>@DateTime.Now.ToString("MMMM yyyy")</h5>
            <button class="btn-icon btn-outline"><i class="fas fa-chevron-right"></i></button>
            <button class="btn-outline btn-sm">Today</button>
        </div>
        <div style="display:flex;gap:8px;">
            <button class="btn-primary btn-sm"><i class="fas fa-plus"></i> Add Session</button>
        </div>
    </div>

    <!-- Day Headers -->
    <div style="display:grid;grid-template-columns:80px repeat(5,1fr);border-bottom:1px solid var(--surface-low);">
        <div style="padding:12px;"></div>
        @{
            var days = new[] { "Monday", "Tuesday", "Wednesday", "Thursday", "Friday" };
            var today = DateTime.Now.DayOfWeek;
        }
        @for (int i = 0; i < 5; i++)
        {
            var isToday = (int)today - 1 == i;
            <div style="padding:12px;text-align:center;@(isToday ? "background:rgba(43,84,191,0.05);" : "")">
                <div class="smaller text-muted">@days[i].Substring(0,3).ToUpper()</div>
                <div style="font-size:20px;font-weight:800;color:@(isToday ? "var(--primary)" : "var(--on-surface)");">
                    @DateTime.Now.AddDays(i - (int)today + 1).Day
                </div>
            </div>
        }
    </div>

    <!-- Time Slots -->
    @{
        var timeSlots = new[] { "08:00", "09:00", "10:00", "11:00", "12:00", "13:00", "14:00", "15:00" };
        var classList = Model?.ToList() ?? new List<BTL_Web.Models.LopHoc>();
    }
    @foreach (var time in timeSlots)
    {
        <div style="display:grid;grid-template-columns:80px repeat(5,1fr);border-bottom:1px solid var(--surface-low);min-height:64px;">
            <div style="padding:8px 12px;font-size:12px;color:var(--outline);text-align:right;padding-top:12px;">@time</div>
            @for (int d = 0; d < 5; d++)
            {
                var isToday = (int)today - 1 == d;
                var classForSlot = classList.Any() ? classList.Skip(d % classList.Count).Take(1).FirstOrDefault() : null;
                var showClass = classForSlot != null && time == "09:00" && d == 0;
                <div style="padding:4px;@(isToday ? "background:rgba(43,84,191,0.03);" : "")border-left:1px solid var(--surface-low);">
                    @if (showClass && classForSlot != null)
                    {
                        <div style="background:rgba(43,84,191,0.1);border-left:3px solid var(--primary);border-radius:4px;padding:8px;height:100%;">
                            <div class="user-name" style="font-size:12px;">@(classForSlot.TenLop ?? classForSlot.MaLop)</div>
                            <div class="user-sub" style="font-size:10px;">@(classForSlot.MaPhongNavigation?.TenPhong ?? "—")</div>
                        </div>
                    }
                </div>
            }
        </div>
    }
</div>

<!-- Upcoming Events -->
<div class="card-plain" style="padding:32px;">
    <div class="section-heading">
        <h4>Upcoming Sessions</h4>
        <a href="/Teacher/MyClasses">View All</a>
    </div>
    <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:16px;">
        @foreach (var lop in (Model ?? new List<BTL_Web.Models.LopHoc>()).Take(4))
        {
            <div class="card-plain" style="padding:16px;border:1px solid var(--surface-high);">
                <div class="activity-icon blue" style="margin-bottom:12px;"><i class="fas fa-graduation-cap"></i></div>
                <div class="user-name" style="margin-bottom:4px;">@(lop.TenLop ?? lop.MaLop)</div>
                <div class="user-sub">@(lop.MaKhoaHocNavigation?.TenKhoaHoc ?? "—")</div>
                <div class="user-sub" style="margin-top:4px;">
                    <i class="fas fa-map-marker-alt" style="font-size:10px;"></i>
                    @(lop.MaPhongNavigation?.TenPhong ?? "TBD")
                </div>
            </div>
        }
        @if (!(Model?.Any() ?? false))
        {
            <div style="grid-column:1/-1;"><div class="empty-state"><i class="fas fa-calendar"></i><p>No upcoming sessions</p></div></div>
        }
    </div>
</div>

@section Scripts {
<script>
document.querySelectorAll('.filter-btn').forEach(btn => {
    btn.addEventListener('click', function() {
        this.closest('div').querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
        this.classList.add('active');
    });
});
</script>
}
