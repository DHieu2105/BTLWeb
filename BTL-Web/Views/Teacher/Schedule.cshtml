@model IEnumerable<BTL_Web.Models.LichHoc>
@{
    ViewData["Title"] = "Lịch giảng dạy của tôi";

    var sessions = (Model ?? Enumerable.Empty<BTL_Web.Models.LichHoc>())
        .OrderBy(s => s.NgayHoc)
        .ThenBy(s => s.GioBatDau)
        .ToList();

    var today = DateOnly.FromDateTime(DateTime.Now);
    var todayCount = sessions.Count(s => s.NgayHoc == today);
    var weekStart = today.AddDays(-(int)today.DayOfWeek + ((int)today.DayOfWeek == 0 ? -6 : 1));
    var weekEnd = weekStart.AddDays(6);
    var weekCount = sessions.Count(s => s.NgayHoc.HasValue && s.NgayHoc.Value >= weekStart && s.NgayHoc.Value <= weekEnd);
    var monthCount = sessions.Count(s => s.NgayHoc.HasValue && s.NgayHoc.Value.Month == today.Month && s.NgayHoc.Value.Year == today.Year);
    var nextSession = sessions.FirstOrDefault(s => s.NgayHoc.HasValue && s.NgayHoc.Value >= today);
    var clientSessions = sessions.Select(s => new
    {
        date = s.NgayHoc?.ToString("yyyy-MM-dd"),
        start = s.GioBatDau?.ToString(@"HH\:mm"),
        end = s.GioKetThuc?.ToString(@"HH\:mm"),
        className = s.MaLopNavigation?.TenLop ?? s.MaLop ?? "-",
        courseName = s.MaLopNavigation?.MaKhoaHocNavigation?.TenKhoaHoc ?? "-",
        roomName = s.MaPhongNavigation?.TenPhong ?? "-"
    }).ToList();
}

<div class="page-header">
    <div>
        <h2>Lịch giảng dạy của tôi</h2>
        <p>Lịch giảng dạy hằng tuần và các buổi học sắp tới</p>
    </div>
</div>

<!-- Stats -->
<div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:16px;margin-bottom:24px;">
    <div class="card-plain" style="padding:20px;border-left:4px solid var(--primary);">
        <div class="stat-label">Khối lượng hôm nay</div>
        <div style="display:flex;align-items:baseline;gap:8px;margin-top:4px;">
            <div class="stat-value">@todayCount</div>
            <span class="small text-muted">buổi</span>
        </div>
        <div class="user-sub" style="margin-top:8px;">@weekCount buổi trong tuần này</div>
    </div>
    <div class="card-plain" style="padding:20px;border-left:4px solid #0891b2;">
        <div class="stat-label">Tháng này</div>
        <div class="stat-value" style="margin-top:4px;">@monthCount</div>
        <div class="user-sub" style="margin-top:8px;">các buổi đã lên lịch</div>
    </div>
    <div class="card-plain" style="padding:20px;background:var(--sidebar-bg);color:white;">
        <div class="stat-label" style="color:rgba(255,255,255,0.6);">Next Session</div>
        <div class="stat-value" style="color:white;font-size:16px;margin-top:4px;">
            @(nextSession?.MaLopNavigation?.TenLop ?? nextSession?.MaLop ?? "No upcoming session")
        </div>
        <div class="user-sub" style="margin-top:8px;color:rgba(255,255,255,0.7);">
            @if (nextSession?.NgayHoc != null)
            {
                @(nextSession.NgayHoc?.ToString("dd/MM/yyyy"))
                @: - @(nextSession.GioBatDau?.ToString(@"HH\:mm") ?? "--:--")
            }
            else
            {
                @:No date available
            }
        </div>
    </div>
</div>

<div class="card-plain" style="padding:0;margin-bottom:24px;overflow:hidden;">
    <div style="padding:20px 24px;border-bottom:1px solid var(--surface-low);display:flex;align-items:center;justify-content:space-between;gap:16px;">
        <div style="display:flex;align-items:center;gap:12px;">
            <button type="button" class="btn-icon btn-outline" id="calendarPrevBtn"><i class="fas fa-chevron-left"></i></button>
            <h5 id="calendarTitle" style="margin:0;">@($"Tháng {DateTime.Now.Month} {DateTime.Now.Year}")</h5>
            <button type="button" class="btn-icon btn-outline" id="calendarNextBtn"><i class="fas fa-chevron-right"></i></button>
        </div>
        <div class="schedule-view-switch" role="group" aria-label="Teacher schedule view mode">
            <button type="button" class="calendar-view-btn filter-btn active" data-calendar-view="week">Tuần</button>
            <button type="button" class="calendar-view-btn filter-btn" data-calendar-view="month">Month</button>
            <button type="button" class="calendar-view-btn filter-btn" data-calendar-view="list">List</button>
        </div>
    </div>

    <div id="teacherCalendarBody"></div>
</div>

<div class="card-plain" style="padding:0;">
    <div class="card-header-plain">
        <h5>Schedule List</h5>
        <div class="schedule-list-filter" style="display:flex;gap:8px;">
            <button type="button" class="filter-btn active" data-filter="week">Tuần</button>
            <button type="button" class="filter-btn" data-filter="month">Month</button>
            <button type="button" class="filter-btn" data-filter="list">List</button>
        </div>
    </div>
    <table class="data-table">
        <thead>
            <tr>
                <th>Date</th>
                <th>Time</th>
                <th>Class</th>
                <th>Course</th>
                <th>Room</th>
                <th>Status</th>
            </tr>
        </thead>
        <tbody>
            @if (sessions.Any())
            {
                @foreach (var s in sessions)
                {
                    <tr class="session-row" data-date="@(s.NgayHoc?.ToString("yyyy-MM-dd") ?? "")">
                        <td>@(s.NgayHoc?.ToString("dd/MM/yyyy") ?? "-")</td>
                        <td>
                            @(s.GioBatDau?.ToString(@"HH\:mm") ?? "--:--")
                            -
                            @(s.GioKetThuc?.ToString(@"HH\:mm") ?? "--:--")
                        </td>
                        <td>@(s.MaLopNavigation?.TenLop ?? s.MaLop ?? "-")</td>
                        <td>@(s.MaLopNavigation?.MaKhoaHocNavigation?.TenKhoaHoc ?? "-")</td>
                        <td>@(s.MaPhongNavigation?.TenPhong ?? "-")</td>
                        <td><span class="chip chip-green">Scheduled</span></td>
                    </tr>
                }
                <tr id="filterEmptyRow" style="display:none;">
                    <td colspan="6">
                        <div class="empty-state"><i class="fas fa-calendar-times"></i><p>Không có buổi học nào trong chế độ xem này</p></div>
                    </td>
                </tr>
            }
            else
            {
                <tr>
                    <td colspan="6">
                        <div class="empty-state"><i class="fas fa-calendar"></i><p>No schedule found</p></div>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <div class="pagination-bar">
        <span class="pagination-info" id="scheduleCount">Đang hiển thị @sessions.Count buổi học</span>
        <div class="pagination-btns">
            <button type="button" class="page-btn" id="prevPageBtn"><i class="fas fa-chevron-left" style="font-size:10px;"></i></button>
            <div id="paginationNumbers" style="display:flex;gap:6px;"></div>
            <button type="button" class="page-btn" id="nextPageBtn"><i class="fas fa-chevron-right" style="font-size:10px;"></i></button>
        </div>
    </div>
</div>

@section Scripts {
<script>
document.addEventListener('DOMContentLoaded', function () {
    const filterButtons = document.querySelectorAll('.schedule-list-filter .filter-btn');
    const calendarViewButtons = document.querySelectorAll('.calendar-view-btn');
    const rows = document.querySelectorAll('.session-row');
    const emptyRow = document.getElementById('filterEmptyRow');
    const scheduleCount = document.getElementById('scheduleCount');
    const prevPageBtn = document.getElementById('prevPageBtn');
    const nextPageBtn = document.getElementById('nextPageBtn');
    const paginationNumbers = document.getElementById('paginationNumbers');
    const calendarBody = document.getElementById('teacherCalendarBody');
    const calendarTitle = document.getElementById('calendarTitle');
    const calendarPrevBtn = document.getElementById('calendarPrevBtn');
    const calendarNextBtn = document.getElementById('calendarNextBtn');

    const calendarSessions = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(clientSessions));

    const pageSize = 8;
    let currentFilter = 'week';
    let currentPage = 1;
    let currentCalendarView = 'week';
    let calendarAnchorDate = new Date();

    function normalizeDate(date) {
        const d = new Date(date);
        d.setHours(0, 0, 0, 0);
        return d;
    }

    function parseSessionDate(value) {
        if (!value) {
            return null;
        }

        const parsed = new Date(value + 'T00:00:00');
        return Number.isNaN(parsed.getTime()) ? null : parsed;
    }

    function startOfWeek(date) {
        const normalized = normalizeDate(date);
        const day = normalized.getDay();
        const mondayOffset = day === 0 ? -6 : 1 - day;
        const start = new Date(normalized);
        start.setDate(normalized.getDate() + mondayOffset);
        return start;
    }

    function isSameDay(a, b) {
        return a.getFullYear() === b.getFullYear()
            && a.getMonth() === b.getMonth()
            && a.getDate() === b.getDate();
    }

    function titleForView() {
        if (!calendarTitle) {
            return;
        }

        if (currentCalendarView === 'week') {
            const start = startOfWeek(calendarAnchorDate);
            const end = new Date(start);
            end.setDate(start.getDate() + 6);

            const formatter = new Intl.DateTimeFormat('vi-VN', { day: '2-digit', month: '2-digit', year: 'numeric' });
            calendarTitle.textContent = formatter.format(start) + ' - ' + formatter.format(end);
            return;
        }

        if (currentCalendarView === 'month') {
            calendarTitle.textContent = 'Tháng ' + (calendarAnchorDate.getMonth() + 1) + ' ' + calendarAnchorDate.getFullYear();
            return;
        }

        calendarTitle.textContent = 'Danh sách lịch dạy';
    }

    function renderWeekView() {
        if (!calendarBody) {
            return;
        }

        const start = startOfWeek(calendarAnchorDate);
        const days = [];
        for (let i = 0; i < 7; i++) {
            const d = new Date(start);
            d.setDate(start.getDate() + i);
            days.push(d);
        }

        const today = normalizeDate(new Date());
        let html = '<div style="display:grid;grid-template-columns:80px repeat(7,minmax(120px,1fr));border-bottom:1px solid var(--surface-low);">';
        html += '<div></div>';
        days.forEach(function (day) {
            const isToday = isSameDay(day, today);
            const dayLabel = new Intl.DateTimeFormat('vi-VN', { weekday: 'short' }).format(day).toUpperCase();
            html += '<div style="padding:12px;text-align:center;' + (isToday ? 'background:rgba(43,84,191,0.05);' : '') + '">';
            html += '<div class="smaller text-muted">' + dayLabel + '</div>';
            html += '<div style="font-size:20px;font-weight:800;color:' + (isToday ? 'var(--primary)' : 'var(--on-surface)') + ';">' + day.getDate() + '</div>';
            html += '</div>';
        });
        html += '</div>';

        for (let hour = 8; hour <= 17; hour++) {
            html += '<div style="display:grid;grid-template-columns:80px repeat(7,minmax(120px,1fr));border-bottom:1px solid var(--surface-low);min-height:72px;">';
            html += '<div style="padding:8px 12px;font-size:12px;color:var(--outline);text-align:right;padding-top:16px;">' + String(hour).padStart(2, '0') + ':00</div>';

            days.forEach(function (day) {
                const isToday = isSameDay(day, today);
                const daySessions = calendarSessions.filter(function (s) {
                    const d = parseSessionDate(s.date);
                    if (!d || !s.start) {
                        return false;
                    }
                    const startHour = parseInt(s.start.split(':')[0], 10);
                    return startHour === hour && isSameDay(d, day);
                });

                html += '<div style="padding:6px;border-left:1px solid var(--surface-low);' + (isToday ? 'background:rgba(43,84,191,0.03);' : '') + '">';
                daySessions.forEach(function (session) {
                    html += '<div style="background:rgba(43,84,191,0.1);border-left:3px solid var(--primary);border-radius:8px;padding:8px 10px;margin-bottom:6px;">';
                    html += '<div class="user-name" style="font-size:12px;line-height:1.3;">' + session.className + '</div>';
                    html += '<div class="user-sub" style="font-size:11px;line-height:1.3;">' + (session.start || '--:--') + ' - ' + (session.end || '--:--') + '</div>';
                    html += '<div class="user-sub" style="font-size:11px;line-height:1.3;">' + session.roomName + '</div>';
                    html += '</div>';
                });
                html += '</div>';
            });

            html += '</div>';
        }

        calendarBody.innerHTML = html;
    }

    function renderMonthView() {
        if (!calendarBody) {
            return;
        }

        const today = normalizeDate(new Date());
        const year = calendarAnchorDate.getFullYear();
        const month = calendarAnchorDate.getMonth();
        const firstDay = new Date(year, month, 1);
        const firstWeekday = (firstDay.getDay() + 6) % 7;
        const daysInMonth = new Date(year, month + 1, 0).getDate();

        let html = '<div style="display:grid;grid-template-columns:repeat(7,minmax(120px,1fr));border-bottom:1px solid var(--surface-low);">';
        ['T2', 'T3', 'T4', 'T5', 'T6', 'T7', 'CN'].forEach(function (label) {
            html += '<div style="padding:12px;text-align:center;font-weight:700;color:var(--on-surface-variant);">' + label + '</div>';
        });
        html += '</div>';

        html += '<div style="display:grid;grid-template-columns:repeat(7,minmax(120px,1fr));">';
        for (let i = 0; i < firstWeekday; i++) {
            html += '<div style="min-height:92px;border-right:1px solid var(--surface-low);border-bottom:1px solid var(--surface-low);background:var(--surface-low);"></div>';
        }

        for (let day = 1; day <= daysInMonth; day++) {
            const date = new Date(year, month, day);
            const isToday = isSameDay(date, today);
            const count = calendarSessions.filter(function (s) {
                const d = parseSessionDate(s.date);
                return !!d && isSameDay(d, date);
            }).length;

            html += '<div style="min-height:92px;border-right:1px solid var(--surface-low);border-bottom:1px solid var(--surface-low);padding:8px;' + (isToday ? 'background:rgba(43,84,191,0.08);' : '') + '">';
            html += '<div style="font-weight:700;margin-bottom:6px;' + (isToday ? 'color:var(--primary);' : '') + '">' + day + '</div>';
            if (count > 0) {
                html += '<span class="chip chip-blue">' + count + ' buổi</span>';
            }
            html += '</div>';
        }

        html += '</div>';
        calendarBody.innerHTML = html;
    }

    function renderListView() {
        if (!calendarBody) {
            return;
        }

        const sorted = calendarSessions
            .filter(function (s) { return !!s.date; })
            .slice()
            .sort(function (a, b) { return a.date.localeCompare(b.date) || (a.start || '').localeCompare(b.start || ''); });

        if (sorted.length === 0) {
            calendarBody.innerHTML = '<div class="empty-state" style="padding:24px;"><i class="fas fa-calendar"></i><p>No schedule found</p></div>';
            return;
        }

        let html = '<div style="padding:12px 16px;display:grid;gap:10px;">';
        sorted.forEach(function (s) {
            const d = parseSessionDate(s.date);
            const dateLabel = d ? new Intl.DateTimeFormat('vi-VN').format(d) : '-';
            html += '<div style="border:1px solid var(--surface-low);border-radius:10px;padding:12px 14px;">';
            html += '<div class="user-name" style="margin-bottom:4px;">' + s.className + '</div>';
            html += '<div class="user-sub">' + dateLabel + ' • ' + (s.start || '--:--') + ' - ' + (s.end || '--:--') + '</div>';
            html += '<div class="user-sub">' + s.courseName + ' • ' + s.roomName + '</div>';
            html += '</div>';
        });
        html += '</div>';

        calendarBody.innerHTML = html;
    }

    function renderCalendar() {
        titleForView();

        if (currentCalendarView === 'week') {
            renderWeekView();
            return;
        }

        if (currentCalendarView === 'month') {
            renderMonthView();
            return;
        }

        renderListView();
    }

    function getWeekRange(now) {
        const day = now.getDay();
        const mondayOffset = day === 0 ? -6 : 1 - day;
        const start = new Date(now);
        start.setDate(now.getDate() + mondayOffset);
        start.setHours(0, 0, 0, 0);

        const end = new Date(start);
        end.setDate(start.getDate() + 6);
        end.setHours(23, 59, 59, 999);
        return { start, end };
    }

    function getMonthRange(now) {
        const start = new Date(now.getFullYear(), now.getMonth(), 1, 0, 0, 0, 0);
        const end = new Date(now.getFullYear(), now.getMonth() + 1, 0, 23, 59, 59, 999);
        return { start, end };
    }

    function getFilteredRows() {
        const now = new Date();
        const week = getWeekRange(now);
        const month = getMonthRange(now);

        const filtered = [];
        rows.forEach(row => {
            const dateStr = row.dataset.date;
            const date = dateStr ? new Date(dateStr + 'T00:00:00') : null;
            let visible = true;

            if (currentFilter === 'week') {
                visible = !!date && date >= week.start && date <= week.end;
            } else if (currentFilter === 'month') {
                visible = !!date && date >= month.start && date <= month.end;
            }

            if (visible) {
                filtered.push(row);
            }
        });

        return filtered;
    }

    function setButtonState(btn, disabled) {
        if (!btn) {
            return;
        }

        btn.disabled = disabled;
        btn.style.opacity = disabled ? '0.5' : '1';
        btn.style.cursor = disabled ? 'not-allowed' : 'pointer';
    }

    function renderPagination(totalPages) {
        if (!paginationNumbers) {
            return;
        }

        paginationNumbers.innerHTML = '';
        for (let page = 1; page <= totalPages; page++) {
            const btn = document.createElement('button');
            btn.type = 'button';
            btn.className = 'page-btn' + (page === currentPage ? ' active' : '');
            btn.textContent = page;
            btn.addEventListener('click', function () {
                if (currentPage === page) {
                    return;
                }

                currentPage = page;
                applyView(false);
            });
            paginationNumbers.appendChild(btn);
        }

        setButtonState(prevPageBtn, currentPage <= 1);
        setButtonState(nextPageBtn, currentPage >= totalPages);
    }

    function applyView(resetPage) {
        const filteredRows = getFilteredRows();
        const totalItems = filteredRows.length;
        const totalPages = Math.max(1, Math.ceil(totalItems / pageSize));

        if (resetPage) {
            currentPage = 1;
        } else if (currentPage > totalPages) {
            currentPage = totalPages;
        }

        rows.forEach(r => r.style.display = 'none');

        const startIndex = (currentPage - 1) * pageSize;
        const endIndex = Math.min(startIndex + pageSize, totalItems);
        for (let i = startIndex; i < endIndex; i++) {
            filteredRows[i].style.display = '';
        }

        renderPagination(totalPages);

        if (scheduleCount) {
            if (totalItems === 0) {
                scheduleCount.textContent = 'Đang hiển thị 0 buổi học';
            } else {
                scheduleCount.textContent = 'Đang hiển thị ' + (startIndex + 1) + '-' + endIndex + ' / ' + totalItems + ' buổi học';
            }
        }

        if (emptyRow) {
            emptyRow.style.display = totalItems === 0 ? '' : 'none';
        }
    }

    filterButtons.forEach(function (btn) {
        btn.addEventListener('click', function () {
            filterButtons.forEach(b => b.classList.remove('active'));
            this.classList.add('active');
            currentFilter = this.dataset.filter || 'list';
            applyView(true);
        });
    });

    calendarViewButtons.forEach(function (btn) {
        btn.addEventListener('click', function () {
            calendarViewButtons.forEach(function (b) {
                b.classList.remove('active');
            });
            this.classList.add('active');
            currentCalendarView = this.dataset.calendarView || 'week';
            renderCalendar();
        });
    });

    if (calendarPrevBtn) {
        calendarPrevBtn.addEventListener('click', function () {
            if (currentCalendarView === 'month') {
                calendarAnchorDate = new Date(calendarAnchorDate.getFullYear(), calendarAnchorDate.getMonth() - 1, 1);
            } else {
                calendarAnchorDate = new Date(calendarAnchorDate.getFullYear(), calendarAnchorDate.getMonth(), calendarAnchorDate.getDate() - 7);
            }
            renderCalendar();
        });
    }

    if (calendarNextBtn) {
        calendarNextBtn.addEventListener('click', function () {
            if (currentCalendarView === 'month') {
                calendarAnchorDate = new Date(calendarAnchorDate.getFullYear(), calendarAnchorDate.getMonth() + 1, 1);
            } else {
                calendarAnchorDate = new Date(calendarAnchorDate.getFullYear(), calendarAnchorDate.getMonth(), calendarAnchorDate.getDate() + 7);
            }
            renderCalendar();
        });
    }

    if (prevPageBtn) {
        prevPageBtn.addEventListener('click', function () {
            if (currentPage <= 1) {
                return;
            }

            currentPage -= 1;
            applyView(false);
        });
    }

    if (nextPageBtn) {
        nextPageBtn.addEventListener('click', function () {
            const totalItems = getFilteredRows().length;
            const totalPages = Math.max(1, Math.ceil(totalItems / pageSize));
            if (currentPage >= totalPages) {
                return;
            }

            currentPage += 1;
            applyView(false);
        });
    }

    applyView(true);
    renderCalendar();
});
</script>
}
