@model IEnumerable<BTL_Web.Models.KhoaHoc>
@{
    ViewData["Title"] = "Quản lý khóa học";
    var trungTams = ViewBag.TrungTams as IEnumerable<BTL_Web.Models.TrungTam> ?? new List<BTL_Web.Models.TrungTam>();
    var trungTamLookup = trungTams
        .Where(t => !string.IsNullOrWhiteSpace(t.MaTrungTam))
        .ToDictionary(t => t.MaTrungTam!, t => t.TenTrungTam ?? t.MaTrungTam!);
}

<div class="page-header">
    <div>
        <h2>Quản lý khóa học</h2>
        <p>Quản lý chương trình đào tạo và danh mục khóa học</p>
    </div>
    <div class="page-actions">
        <button type="button" class="btn-outline" title="Filter" onclick="toggleCourseFilter()"><i class="fas fa-filter"></i></button>
        <button class="btn-primary" onclick="document.getElementById('addModal').style.display='flex'">
            <i class="fas fa-plus"></i> Thêm khóa học
        </button>
    </div>
</div>

@if (TempData["Success"] is string success)
{
    <div class="alert alert-success" style="margin-bottom:16px;">@success</div>
}
@if (TempData["Error"] is string error)
{
    <div class="alert alert-danger" style="margin-bottom:16px;">@error</div>
}

<div id="courseFilterPanel" class="card-plain" style="display:none;padding:16px 20px;margin-bottom:16px;">
    <div style="display:grid;grid-template-columns:1fr auto;gap:10px;align-items:end;">
        <div class="form-group" style="margin:0;">
            <label class="form-label">Tìm khóa học</label>
            <input id="courseFilterInput" type="text" class="form-control" placeholder="Tên khóa học hoặc mã" />
        </div>
        <button type="button" class="btn-outline" onclick="clearCourseFilter()">Xóa lọc</button>
    </div>
</div>

<div style="display:grid;grid-template-columns:2fr 1fr 1fr;gap:24px;margin-bottom:24px;">
    <div class="card-plain" style="padding:32px;background:var(--sidebar-bg);color:white;position:relative;overflow:hidden;">
        <div style="font-size:12px;font-weight:700;color:rgba(255,255,255,0.6);text-transform:uppercase;letter-spacing:0.6px;margin-bottom:8px;">
            <span style="background:rgba(255,255,255,0.15);padding:4px 10px;border-radius:12px;">Chương trình đang hoạt động</span>
        </div>
        <h3 style="font-size:28px;font-weight:800;color:white;margin-bottom:8px;">Quản lý khóa học học thuật</h3>
        <p style="color:rgba(255,255,255,0.7);font-size:14px;margin-bottom:24px;">Danh mục khóa học đầy đủ với theo dõi ghi danh và phân tích hiệu suất.</p>
        <div style="display:flex;gap:32px;">
            <div>
                <div style="font-size:30px;font-weight:800;color:white;">@(Model?.Count() ?? 0)</div>
                <div style="font-size:12px;color:rgba(255,255,255,0.6);">Tổng khóa học</div>
            </div>
            <div style="width:1px;background:rgba(255,255,255,0.2);"></div>
            <div>
                <div style="font-size:30px;font-weight:800;color:white;">1,248</div>
                <div style="font-size:12px;color:rgba(255,255,255,0.6);">Học viên đã ghi danh</div>
            </div>
            <div style="width:1px;background:rgba(255,255,255,0.2);"></div>
            <div>
                <div style="font-size:30px;font-weight:800;color:white;">86%</div>
                <div style="font-size:12px;color:rgba(255,255,255,0.6);">Sức chứa trung bình</div>
            </div>
        </div>
    </div>
    <div class="stat-card blue">
        <div class="stat-card-header">
            <div class="stat-icon blue"><i class="fas fa-fire"></i></div>
            <span class="stat-badge blue">Nóng</span>
        </div>
        <div class="stat-label">Nhu cầu cao nhất</div>
        <div class="stat-value" style="font-size:20px;">IELTS Intensive</div>
        <div class="smaller text-muted" style="margin-top:4px;">Sức chứa ghế 85%</div>
    </div>
    <div class="card-plain" style="padding:24px;">
        <div class="section-heading" style="margin-bottom:16px;">
            <h4 style="font-size:16px;">Thao tác nhanh</h4>
        </div>
        <div style="display:flex;flex-direction:column;gap:8px;">
            <a href="/Admin/LopHoc" class="btn-outline" style="justify-content:flex-start;">
                <i class="fas fa-user-plus"></i> Quản lý ghi danh lớp
            </a>
            <button class="btn-outline" style="justify-content:flex-start;">
                <i class="fas fa-file-export"></i> Xuất danh mục
            </button>
            <button class="btn-outline" style="justify-content:flex-start;">
                <i class="fas fa-chart-bar"></i> Xem phân tích
            </button>
        </div>
    </div>
</div>

<div class="card-plain" style="padding:0;">
    <div class="card-header-plain">
        <div>
            <h5 style="margin-bottom:4px;">Danh mục khóa học</h5>
            <p class="small text-muted">@(Model?.Count() ?? 0) khóa học khả dụng</p>
        </div>
        <div style="display:flex;gap:8px;">
            <button type="button" class="btn-outline btn-sm" title="Filter" onclick="toggleCourseFilter()"><i class="fas fa-filter"></i></button>
            <button class="btn-primary btn-sm" onclick="document.getElementById('addModal').style.display='flex'">
                <i class="fas fa-plus"></i> Khóa học mới
            </button>
        </div>
    </div>
    <table class="data-table">
        <thead>
            <tr>
                <th>Tên khóa học</th>
                <th>Thời lượng</th>
                <th>Học phí</th>
                <th>Trung tâm</th>
                <th style="text-align:right;">Thao tác</th>
            </tr>
        </thead>
        <tbody id="courseTableBody" data-page-size="10">
            @if (Model != null && Model.Any())
            {
                @foreach (var kh in Model)
                {
                    <tr class="course-row">
                        <td>
                            <div style="display:flex;align-items:center;gap:12px;">
                                <div class="avatar" style="background:rgba(219,225,255,0.3);color:var(--primary);">
                                    <i class="fas fa-book"></i>
                                </div>
                                <div>
                                    <div class="user-name">@kh.TenKhoaHoc</div>
                                    <div class="user-sub">@kh.MaKhoaHoc</div>
                                </div>
                            </div>
                        </td>
                        <td>
                            <div class="user-name">@(kh.ThoiLuong ?? 0) tuần</div>
                            <div class="user-sub">@((kh.ThoiLuong ?? 0) * 6) giờ học</div>
                        </td>
                        <td>
                            @if (kh.HocPhi.HasValue)
                            {
                                <span class="chip chip-blue">@kh.HocPhi.Value.ToString("N0") VNĐ</span>
                            }
                            else
                            {
                                <span class="user-sub">-</span>
                            }
                        </td>
                        <td>
                            <span class="user-sub">@(kh.MaTrungTam != null && trungTamLookup.ContainsKey(kh.MaTrungTam) ? trungTamLookup[kh.MaTrungTam] : (kh.MaTrungTam ?? "-"))</span>
                        </td>
                        <td style="text-align:right;">
                            <div style="display:flex;gap:4px;justify-content:flex-end;">
                                <button class="btn-icon btn-outline btn-sm"
                                        data-id="@kh.MaKhoaHoc"
                                        data-ten="@kh.TenKhoaHoc"
                                        data-thoiluong="@kh.ThoiLuong"
                                        data-hocphi="@kh.HocPhi"
                                        data-matrungtam="@kh.MaTrungTam"
                                        onclick="openEditCourse(this)">
                                    <i class="fas fa-edit"></i>
                                </button>
                                <button class="btn-icon btn-outline btn-sm" onclick="deleteCourse('@kh.MaKhoaHoc')">
                                    <i class="fas fa-trash" style="color:#ef4444;"></i>
                                </button>
                            </div>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr><td colspan="5"><div class="empty-state"><i class="fas fa-book"></i><p>Không tìm thấy khóa học nào</p></div></td></tr>
            }
        </tbody>
    </table>
    <div class="pagination-bar">
        <span class="pagination-info">Đang hiển thị @(Model?.Count() ?? 0) khóa học</span>
        <div class="pagination-btns">
            <button class="page-btn"><i class="fas fa-chevron-left" style="font-size:10px;"></i></button>
            <button class="page-btn active">1</button>
            <button class="page-btn">2</button>
            <button class="page-btn"><i class="fas fa-chevron-right" style="font-size:10px;"></i></button>
        </div>
    </div>
</div>

<div id="editModal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.4);z-index:2000;align-items:center;justify-content:center;">
    <div style="background:white;border-radius:12px;padding:32px;width:520px;max-width:90vw;">
        <h4 style="margin-bottom:24px;">Sửa khóa học</h4>
        <form method="post" action="/Admin/UpdateKhoaHoc">
            @Html.AntiForgeryToken()
            <input type="hidden" id="editMaKhoaHoc" name="maKhoaHoc" />
            <div class="form-group">
                <label class="form-label">Mã khóa học</label>
                <input type="text" id="editMaKhoaHocDisplay" class="form-control" readonly>
            </div>
            <div class="form-group">
                <label class="form-label">Tên khóa học</label>
                <input type="text" id="editTenKhoaHoc" name="tenKhoaHoc" class="form-control" required>
            </div>
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;">
                <div class="form-group">
                    <label class="form-label">Thời lượng (tuần)</label>
                    <input type="number" id="editThoiLuong" name="thoiLuong" class="form-control" min="1">
                </div>
                <div class="form-group">
                    <label class="form-label">Học phí</label>
                    <input type="number" id="editHocPhi" name="hocPhi" class="form-control" min="0">
                </div>
            </div>
            <div class="form-group">
                <label class="form-label">Trung tâm</label>
                <select id="editMaTrungTam" name="maTrungTam" class="form-control form-select">
                    <option value="">- Chọn trung tâm -</option>
                    @foreach (var tt in trungTams)
                    {
                        <option value="@tt.MaTrungTam">@(tt.TenTrungTam ?? tt.MaTrungTam) (@tt.MaTrungTam)</option>
                    }
                </select>
            </div>
            <div style="display:flex;gap:12px;justify-content:flex-end;margin-top:24px;">
                <button type="button" class="btn-outline" onclick="document.getElementById('editModal').style.display='none'">Hủy</button>
                <button type="submit" class="btn-primary">Lưu thay đổi</button>
            </div>
        </form>
    </div>
</div>

<div id="addModal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.4);z-index:2000;align-items:center;justify-content:center;">
    <div style="background:white;border-radius:12px;padding:32px;width:520px;max-width:90vw;">
        <h4 style="margin-bottom:24px;">Thêm khóa học mới</h4>
        <form method="post" action="/Admin/AddKhoaHoc">
            @Html.AntiForgeryToken()
            <div class="form-group">
                <label class="form-label">Tên khóa học</label>
                <input type="text" name="TenKhoaHoc" class="form-control" required>
            </div>
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;">
                <div class="form-group">
                    <label class="form-label">Thời lượng (tuần)</label>
                    <input type="number" name="ThoiLuong" class="form-control" min="1">
                </div>
                <div class="form-group">
                    <label class="form-label">Học phí</label>
                    <input type="number" name="HocPhi" class="form-control" min="0">
                </div>
            </div>
            <div class="form-group">
                <label class="form-label">Trung tâm</label>
                <select name="MaTrungTam" class="form-control form-select">
                    <option value="">- Chọn trung tâm -</option>
                    @foreach (var tt in trungTams)
                    {
                        <option value="@tt.MaTrungTam">@(tt.TenTrungTam ?? tt.MaTrungTam) (@tt.MaTrungTam)</option>
                    }
                </select>
            </div>
            <div style="display:flex;gap:12px;justify-content:flex-end;margin-top:24px;">
                <button type="button" class="btn-outline" onclick="document.getElementById('addModal').style.display='none'">Hủy</button>
                <button type="submit" class="btn-primary">Thêm khóa học</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
<script>
let courseAjaxSearchTimer;
const courseFilterInput = document.getElementById('courseFilterInput');
const courseTableBody = document.getElementById('courseTableBody');

const escapeHtml = window.appEscapeHtml || function (value) {
    return String(value ?? '')
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#39;');
};

function buildCourseRow(course) {
    const safeCourseId = escapeHtml(course.maKhoaHoc);
    const safeCourseName = escapeHtml(course.tenKhoaHoc || course.maKhoaHoc);
    const duration = Number(course.thoiLuong || 0);
    const hours = duration * 6;
    const rawHocPhi = course.hocPhi ?? '';
    const safeTenRaw = escapeHtml(course.tenKhoaHoc || '');
    const safeThoiLuongRaw = Number(course.thoiLuong || 0);
    const safeCenterId = escapeHtml(course.maTrungTam || '');
    const safeCenterName = escapeHtml(course.centerName || course.maTrungTam || '-');
    const feeDisplay = rawHocPhi === '' ? '<span class="user-sub">-</span>' : `<span class="chip chip-blue">${Number(rawHocPhi).toLocaleString('vi-VN')} VNĐ</span>`;

    return `
        <tr class="course-row">
            <td>
                <div style="display:flex;align-items:center;gap:12px;">
                    <div class="avatar" style="background:rgba(219,225,255,0.3);color:var(--primary);">
                        <i class="fas fa-book"></i>
                    </div>
                    <div>
                        <div class="user-name">${safeCourseName}</div>
                        <div class="user-sub">${safeCourseId}</div>
                    </div>
                </div>
            </td>
            <td>
                <div class="user-name">${duration} tuần</div>
                <div class="user-sub">${hours} giờ học</div>
            </td>
            <td>
                ${feeDisplay}
            </td>
            <td>
                <span class="user-sub">${safeCenterName}</span>
            </td>
            <td style="text-align:right;">
                <div style="display:flex;gap:4px;justify-content:flex-end;">
                    <button class="btn-icon btn-outline btn-sm"
                            data-id="${safeCourseId}"
                            data-ten="${safeTenRaw}"
                            data-thoiluong="${safeThoiLuongRaw}"
                            data-hocphi="${escapeHtml(rawHocPhi)}"
                            data-matrungtam="${safeCenterId}"
                            onclick="openEditCourse(this)">
                        <i class="fas fa-edit"></i>
                    </button>
                    <button class="btn-icon btn-outline btn-sm" onclick="deleteCourse('${safeCourseId}')">
                        <i class="fas fa-trash" style="color:#ef4444;"></i>
                    </button>
                </div>
            </td>
        </tr>`;
}

function renderCourseEmptyState() {
    if (!courseTableBody) {
        return;
    }

    courseTableBody.innerHTML = '<tr><td colspan="5"><div class="empty-state"><i class="fas fa-book"></i><p>Không tìm thấy khóa học nào</p></div></td></tr>';
}

async function runCourseAjaxSearch(keyword) {
    if (!courseTableBody) {
        return;
    }

    const pageSize = Number(courseTableBody.dataset.pageSize || 10);
    const endpoint = `/api/courses?keyword=${encodeURIComponent(keyword || '')}&page=1&pageSize=${pageSize}`;

    try {
        const response = await fetch(endpoint, {
            headers: {
                'X-Requested-With': 'XMLHttpRequest'
            }
        });

        if (!response.ok) {
            return;
        }

        const data = await response.json();
        if (!data.items || data.items.length === 0) {
            renderCourseEmptyState();
            return;
        }

        courseTableBody.innerHTML = data.items.map(buildCourseRow).join('');
    } catch {
        // Keep server-rendered content when API fails.
    }
}

function toggleCourseFilter() {
    const panel = document.getElementById('courseFilterPanel');
    if (!panel) return;
    panel.style.display = panel.style.display === 'none' || panel.style.display === '' ? 'block' : 'none';
}

function applyCourseFilter() {
    clearTimeout(courseAjaxSearchTimer);
    const query = (courseFilterInput?.value || '').trim();
    courseAjaxSearchTimer = setTimeout(() => runCourseAjaxSearch(query), 300);
}

function clearCourseFilter() {
    if (courseFilterInput) {
        courseFilterInput.value = '';
    }

    runCourseAjaxSearch('');
}

if (courseFilterInput) {
    courseFilterInput.addEventListener('input', applyCourseFilter);
}

function deleteCourse(id) {
    if (confirm('Bạn có chắc muốn xóa khóa học ' + id + '?')) location.href = '/Admin/DeleteKhoaHoc/' + id;
}

function openEditCourse(btn) {
    document.getElementById('editMaKhoaHoc').value = btn.dataset.id || '';
    document.getElementById('editMaKhoaHocDisplay').value = btn.dataset.id || '';
    document.getElementById('editTenKhoaHoc').value = btn.dataset.ten || '';
    document.getElementById('editThoiLuong').value = btn.dataset.thoiluong || '';
    document.getElementById('editHocPhi').value = btn.dataset.hocphi || '';
    document.getElementById('editMaTrungTam').value = btn.dataset.matrungtam || '';
    document.getElementById('editModal').style.display = 'flex';
}
</script>
}
