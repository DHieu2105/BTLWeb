@model IEnumerable<BTL_Web.Models.KhoaHoc>
@using System.Security.Claims
@{
    ViewData["Title"] = "Manage Courses";
    var role = User.FindFirst(ClaimTypes.Role)?.Value ?? "";
    var isAdmin = role == "Admin";
    var currentPage = ViewBag.Page != null ? (int)ViewBag.Page : 1;
    var totalPages = ViewBag.TotalPages != null ? (int)ViewBag.TotalPages : 1;
    var keyword = ViewBag.Keyword as string ?? "";
    var trungTams = ViewBag.TrungTams as IEnumerable<BTL_Web.Models.TrungTam> ?? Enumerable.Empty<BTL_Web.Models.TrungTam>();
}

<div class="page-header">
    <div>
        <h2>Manage Courses</h2>
        <p>@(ViewBag.TotalItems ?? Model?.Count() ?? 0) courses in curriculum and catalog</p>
    </div>
    <div class="page-actions">
        <form method="get" style="display:flex;gap:8px;align-items:center;">
            <input class="form-control" type="text" name="keyword" value="@keyword" placeholder="Search course..." style="width:240px;" />
            <button class="btn-outline" type="submit"><i class="fas fa-filter"></i> Filter</button>
        </form>
        @if (isAdmin)
        {
            <button class="btn-primary" onclick="document.getElementById('addModal').style.display='flex'">
                <i class="fas fa-plus"></i> Add Course
            </button>
        }
    </div>
</div>

<!-- Hero Stats -->
<div style="display:grid;grid-template-columns:2fr 1fr 1fr;gap:24px;margin-bottom:24px;">
    <div class="card-plain" style="padding:32px;background:var(--sidebar-bg);color:white;position:relative;overflow:hidden;">
        <div style="font-size:12px;font-weight:700;color:rgba(255,255,255,0.6);text-transform:uppercase;letter-spacing:0.6px;margin-bottom:8px;">
            <span style="background:rgba(255,255,255,0.15);padding:4px 10px;border-radius:12px;">Active Curriculum</span>
        </div>
        <h3 style="font-size:28px;font-weight:800;color:white;margin-bottom:8px;">Manage Academic Courses</h3>
        <p style="color:rgba(255,255,255,0.7);font-size:14px;margin-bottom:24px;">Comprehensive course catalog with enrollment tracking and performance analytics.</p>
        <div style="display:flex;gap:32px;">
            <div>
                <div style="font-size:30px;font-weight:800;color:white;">@(ViewBag.TotalItems ?? Model?.Count() ?? 0)</div>
                <div style="font-size:12px;color:rgba(255,255,255,0.6);">Total Courses</div>
            </div>
            <div style="width:1px;background:rgba(255,255,255,0.2);"></div>
            <div>
                <div style="font-size:30px;font-weight:800;color:white;">1,248</div>
                <div style="font-size:12px;color:rgba(255,255,255,0.6);">Enrolled Students</div>
            </div>
            <div style="width:1px;background:rgba(255,255,255,0.2);"></div>
            <div>
                <div style="font-size:30px;font-weight:800;color:white;">86%</div>
                <div style="font-size:12px;color:rgba(255,255,255,0.6);">Avg. Capacity</div>
            </div>
        </div>
    </div>
    <div class="stat-card blue">
        <div class="stat-card-header">
            <div class="stat-icon blue"><i class="fas fa-fire"></i></div>
            <span class="stat-badge blue">Hot</span>
        </div>
        <div class="stat-label">Highest Demand</div>
        <div class="stat-value" style="font-size:20px;">IELTS Intensive</div>
        <div class="smaller text-muted" style="margin-top:4px;">85% Seat Capacity</div>
    </div>
    <div class="card-plain" style="padding:24px;">
        <div class="section-heading" style="margin-bottom:16px;">
            <h4 style="font-size:16px;">Quick Actions</h4>
        </div>
        <div style="display:flex;flex-direction:column;gap:8px;">
            @if (isAdmin)
            {
                <a href="/Admin/CourseRegistration" class="btn-outline" style="justify-content:flex-start;">
                    <i class="fas fa-user-plus"></i> Enroll Student
                </a>
                <button class="btn-outline" style="justify-content:flex-start;">
                    <i class="fas fa-file-export"></i> Export Catalog
                </button>
                <button class="btn-outline" style="justify-content:flex-start;">
                    <i class="fas fa-chart-bar"></i> View Analytics
                </button>
            }
        </div>
    </div>
</div>

<!-- Table -->
<div class="card-plain" style="padding:0;">
    <div class="card-header-plain">
        <div>
            <h5 style="margin-bottom:4px;">Course Catalog</h5>
            <p class="small text-muted">@(Model?.Count() ?? 0) courses available</p>
        </div>
        <div style="display:flex;gap:8px;">
            @if (isAdmin)
            {
                <button class="btn-primary btn-sm" onclick="document.getElementById('addModal').style.display='flex'">
                    <i class="fas fa-plus"></i> New Course
                </button>
            }
        </div>
    </div>
    <table class="data-table">
        <thead>
            <tr>
                <th>Mã KH</th>
                <th>Tên khóa học</th>
                <th>Thời lượng</th>
                <th>Học phí</th>
                <th>Trung tâm</th>
                <th>Số lớp</th>
                <th style="text-align:right;">Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                @foreach (var kh in Model)
                {
                    <tr>
                        <td><div class="user-sub">@kh.MaKhoaHoc</div></td>
                        <td>
                            <div style="display:flex;align-items:center;gap:12px;">
                                <div class="avatar" style="background:rgba(219,225,255,0.3);color:var(--primary);">
                                    <i class="fas fa-book"></i>
                                </div>
                                <div>
                                    <div class="user-name">@kh.TenKhoaHoc</div>
                                    <div class="user-sub">@(kh.DangKis.Count) đăng ký</div>
                                </div>
                            </div>
                        </td>
                        <td>
                            <div class="user-name">@(kh.ThoiLuong ?? 0) tuần</div>
                            <div class="user-sub">@((kh.ThoiLuong ?? 0) * 6) giờ học</div>
                        </td>
                        <td>
                            <div class="user-name">@((kh.HocPhi ?? 0).ToString("N0")) VND</div>
                        </td>
                        <td>
                            <div class="user-sub">@(kh.MaTrungTamNavigation?.TenTrungTam ?? kh.MaTrungTam ?? "—")</div>
                        </td>
                        <td>
                            <span class="chip chip-blue">@kh.LopHocs.Count lớp</span>
                        </td>
                        <td style="text-align:right;">
                            <div style="display:flex;gap:4px;justify-content:flex-end;">
                                <a href="/Admin/CourseDetail/@kh.MaKhoaHoc" class="btn-icon btn-outline btn-sm"><i class="fas fa-eye"></i></a>
                                @if (isAdmin)
                                {
                                    <button class="btn-icon btn-outline btn-sm"
                                            data-id="@kh.MaKhoaHoc"
                                            data-ten="@kh.TenKhoaHoc"
                                            data-thoiluong="@(kh.ThoiLuong ?? 0)"
                                            data-hocphi="@(kh.HocPhi ?? 0)"
                                            data-matrungtam="@kh.MaTrungTam"
                                            onclick="openEditCourse(this)">
                                        <i class="fas fa-edit"></i>
                                    </button>
                                    <button class="btn-icon btn-outline btn-sm" onclick="deleteCourse('@kh.MaKhoaHoc')">
                                        <i class="fas fa-trash" style="color:#ef4444;"></i>
                                    </button>
                                }
                            </div>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr><td colspan="7"><div class="empty-state"><i class="fas fa-book"></i><p>No courses found</p></div></td></tr>
            }
        </tbody>
    </table>
    <div class="pagination-bar">
        <span class="pagination-info">Page @currentPage / @totalPages</span>
        <div class="pagination-btns">
            <a class="page-btn" href="/Admin/KhoaHoc?page=@(currentPage > 1 ? currentPage - 1 : 1)&pageSize=@(ViewBag.PageSize ?? 10)&keyword=@keyword"><i class="fas fa-chevron-left" style="font-size:10px;"></i></a>
            @for (var i = 1; i <= totalPages; i++)
            {
                if (i == currentPage)
                {
                    <button class="page-btn active">@i</button>
                }
                else
                {
                    <a class="page-btn" href="/Admin/KhoaHoc?page=@i&pageSize=@(ViewBag.PageSize ?? 10)&keyword=@keyword">@i</a>
                }
            }
            <a class="page-btn" href="/Admin/KhoaHoc?page=@(currentPage < totalPages ? currentPage + 1 : totalPages)&pageSize=@(ViewBag.PageSize ?? 10)&keyword=@keyword"><i class="fas fa-chevron-right" style="font-size:10px;"></i></a>
        </div>
    </div>
</div>

@if (isAdmin)
{
    <div id="addModal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.4);z-index:2000;align-items:center;justify-content:center;">
        <div style="background:white;border-radius:12px;padding:32px;width:520px;max-width:90vw;">
            <h4 style="margin-bottom:24px;">Add New Course</h4>
            <form method="post" action="/Admin/AddKhoaHoc">
                @Html.AntiForgeryToken()
                <div class="form-group">
                    <label class="form-label">Course Name</label>
                    <input type="text" name="TenKhoaHoc" class="form-control" required>
                </div>
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;">
                    <div class="form-group">
                        <label class="form-label">Duration (Weeks)</label>
                        <input type="number" name="ThoiLuong" class="form-control" min="1">
                    </div>
                    <div class="form-group">
                        <label class="form-label">Học phí</label>
                        <input type="number" name="HocPhi" class="form-control" min="0">
                    </div>
                </div>
                <div class="form-group">
                    <label class="form-label">Trung tâm</label>
                    <select name="MaTrungTam" class="form-control">
                        <option value="">-- Chọn trung tâm --</option>
                        @foreach (var tt in trungTams)
                        {
                            <option value="@tt.MaTrungTam">@tt.MaTrungTam - @tt.TenTrungTam</option>
                        }
                    </select>
                </div>
                <div style="display:flex;gap:12px;justify-content:flex-end;margin-top:24px;">
                    <button type="button" class="btn-outline" onclick="document.getElementById('addModal').style.display='none'">Cancel</button>
                    <button type="submit" class="btn-primary">Add Course</button>
                </div>
            </form>
        </div>
    </div>

    <div id="editCourseModal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.4);z-index:2000;align-items:center;justify-content:center;">
        <div style="background:white;border-radius:12px;padding:32px;width:520px;max-width:90vw;">
            <h4 style="margin-bottom:24px;">Edit Course</h4>
            <form method="post" action="/Admin/UpdateKhoaHoc">
                @Html.AntiForgeryToken()
                <input type="hidden" id="editMaKhoaHoc" name="MaKhoaHoc" />
                <div class="form-group">
                    <label class="form-label">Course Name</label>
                    <input type="text" id="editTenKhoaHoc" name="TenKhoaHoc" class="form-control" required>
                </div>
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;">
                    <div class="form-group">
                        <label class="form-label">Duration (Weeks)</label>
                        <input type="number" id="editThoiLuong" name="ThoiLuong" class="form-control" min="1">
                    </div>
                    <div class="form-group">
                        <label class="form-label">Học phí</label>
                        <input type="number" id="editHocPhi" name="HocPhi" class="form-control" min="0">
                    </div>
                </div>
                <div class="form-group">
                    <label class="form-label">Trung tâm</label>
                    <select id="editMaTrungTam" name="MaTrungTam" class="form-control">
                        <option value="">-- Chọn trung tâm --</option>
                        @foreach (var tt in trungTams)
                        {
                            <option value="@tt.MaTrungTam">@tt.MaTrungTam - @tt.TenTrungTam</option>
                        }
                    </select>
                </div>
                <div style="display:flex;gap:12px;justify-content:flex-end;margin-top:24px;">
                    <button type="button" class="btn-outline" onclick="document.getElementById('editCourseModal').style.display='none'">Cancel</button>
                    <button type="submit" class="btn-primary">Save</button>
                </div>
            </form>
        </div>
    </div>
}

@section Scripts {
<script>
function deleteCourse(id) {
    if (confirm('Delete course ' + id + '?')) location.href = '/Admin/DeleteKhoaHoc/' + id;
}

function openEditCourse(btn) {
    document.getElementById('editMaKhoaHoc').value = btn.dataset.id || '';
    document.getElementById('editTenKhoaHoc').value = btn.dataset.ten || '';
    document.getElementById('editThoiLuong').value = btn.dataset.thoiluong || '';
    document.getElementById('editHocPhi').value = btn.dataset.hocphi || '';
    document.getElementById('editMaTrungTam').value = btn.dataset.matrungtam || '';
    document.getElementById('editCourseModal').style.display = 'flex';
}
</script>
}
