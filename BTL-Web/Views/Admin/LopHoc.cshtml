@model BTL_Web.Models.LopHocPage
@{
    ViewData["Title"] = "Quản lý lớp học";
    var pageModel = Model ?? new BTL_Web.Models.LopHocPage();
}

<div class="page-header">
    <div>
        <h2>Quản lý lớp học</h2>
        <p>Lên lịch và quản lý tất cả các buổi học đang hoạt động</p>
    </div>
    <div class="page-actions">
        <button type="button" class="btn-outline" title="Lọc" onclick="toggleClassFilterPanel()"><i class="fas fa-filter"></i></button>
        <button class="btn-primary" onclick="document.getElementById('addModal').style.display='flex'">
            <i class="fas fa-plus"></i> Lên lịch lớp mới
        </button>
    </div>
</div>

<div id="classFilterPanel" class="card-plain" style="display:none;padding:16px 20px;margin-bottom:16px;">
    <div style="display:grid;grid-template-columns:1fr auto;gap:10px;align-items:end;">
        <div class="form-group" style="margin:0;">
            <label class="form-label">Tìm lớp</label>
            <input id="classFilterInput" type="text" class="form-control" placeholder="Mã lớp, tên lớp, khóa học, giáo viên, phòng" oninput="applyClassFilters()" />
        </div>
        <button type="button" class="btn-outline" onclick="clearClassFilter()">Xóa lọc</button>
    </div>
</div>

<div class="stats-grid" style="grid-template-columns:repeat(3,1fr);margin-bottom:24px;">
    <div class="stat-card blue">
        <div class="stat-card-header">
            <div class="stat-icon blue"><i class="fas fa-graduation-cap"></i></div><span
            class="stat-badge blue">+5%</span>
        </div>
        <div class="stat-label">Tổng lớp học</div>
        <div class="stat-value">@pageModel.TotalItems</div>
    </div>
    <div class="stat-card teal">
        <div class="stat-card-header">
            <div class="stat-icon teal"><i class="fas fa-hourglass-half"></i></div>
        </div>
        <div class="stat-label">Tổng học viên</div>
        <div class="stat-value">@pageModel.Items.Sum(l => l.MaHocViens?.Count ?? 0)</div>
    </div>
    <div class="stat-card orange">
        <div class="stat-card-header">
            <div class="stat-icon orange"><i class="fas fa-chart-pie"></i></div>
        </div>
        <div class="stat-label">Sức chứa trung bình</div>
        <div class="stat-value">88%</div>
    </div>
</div>

@if (TempData["Error"] != null)
{
    <div class="alert alert-error" style="margin-bottom:16px;">
        @TempData["Error"]
    </div>
}
@if (TempData["Success"] != null)
{
    <div class="alert alert-success" style="margin-bottom:16px;">
        @TempData["Success"]
    </div>
}

<div class="card-plain" style="padding:0;">
    <div style="padding:16px 24px;border-bottom:1px solid var(--surface-low);display:flex;align-items:center;gap:8px;">
        <button class="filter-btn active" data-filter="all">Tất cả lớp</button>
        <button class="filter-btn" data-filter="active">Đang hoạt động</button>
        <button class="filter-btn" data-filter="completed">Đã hoàn thành</button>
    </div>
    <table class="data-table">
        <thead>
            <tr>
                <th>Mã lớp</th>
                <th>Tên lớp</th>
                <th>Khóa học</th>
                <th>Giáo viên</th>
                <th>Phòng</th>
                <th>Học viên</th>
                <th style="text-align:right;">Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @if (pageModel.Items.Any())
            {
                @foreach (var lh in pageModel.Items)
                {
                    <tr class="class-row" data-students="@(lh.MaHocViens?.Count ?? 0)">
                        <td><span class="chip chip-gray">@lh.MaLop</span></td>
                        <td>
                            <div class="user-name">@(lh.TenLop ?? "—")</div>
                        </td>
                        <td class="user-sub">@(lh.MaKhoaHocNavigation?.TenKhoaHoc ?? lh.MaKhoaHoc ?? "—")</td>
                        <td>@(lh.MaGvNavigation?.Ten ?? lh.MaGv ?? "—")</td>
                        <td class="user-sub">@(lh.MaPhongNavigation?.TenPhong ?? lh.MaPhong ?? "—")</td>
                        <td>
                            <div class="progress-bar-wrap" style="width:60px;margin-bottom:4px;">
                                <div class="progress-bar-fill" style="width:70%;"></div>
                            </div>
                            <span class="smaller text-muted">@(lh.MaHocViens?.Count ?? 0)</span>
                        </td>
                        <td style="text-align:right;">
                            <div style="display:flex;gap:4px;justify-content:flex-end;">
                                          <a href="/Admin/StudentsInClass/@lh.MaLop" class="btn-icon btn-outline btn-sm"
                                              title="Học viên"><i class="fas fa-users"></i></a>

                                <a asp-controller="Admin" asp-action="EditLopHoc" asp-route-id="@lh.MaLop"
                                              class="btn-icon btn-outline btn-sm" title="Sửa lớp"><i class="fas fa-edit"></i></a>
                                <button class="btn-icon btn-outline btn-sm" onclick="deleteClass('@lh.MaLop')">
                                    <i class="fas fa-trash" style="color:#ef4444;"></i>
                                </button>
                            </div>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="7">
                        <div class="empty-state"><i class="fas fa-graduation-cap"></i>
                            <p>Không tìm thấy lớp học nào</p>
                        </div>
                    </td>
                </tr>
            }
            <tr id="classFilterEmptyRow" style="display:none;">
                <td colspan="7">
                    <div class="empty-state"><i class="fas fa-filter"></i>
                        <p>Không có lớp nào phù hợp với bộ lọc hiện tại</p>
                    </div>
                </td>
            </tr>
        </tbody>
    </table>

    @* <div class="pagination-bar">
        <span class="pagination-info">Showing @(Model?.Count() ?? 0) classes</span>
        <div class="pagination-btns">
            <button class="page-btn"><i class="fas fa-chevron-left" style="font-size:10px;"></i></button>
            <button class="page-btn active">1</button>
            <button class="page-btn">2</button>
            <button class="page-btn"><i class="fas fa-chevron-right" style="font-size:10px;"></i></button>
        </div>
    </div> *@
    <div class="pagination-bar">
        <span class="pagination-info">
            Đang hiển thị @pageModel.StartItem-@pageModel.EndItem trong tổng @pageModel.TotalItems lớp học
        </span>

        <div class="pagination-btns">
            @if (pageModel.HasPrevious)
            {
                <a class="page-btn" href="@Url.Action("LopHoc", new { page = pageModel.Page - 1, pageSize = pageModel.PageSize })">
                    <i class="fas fa-chevron-left" style="font-size:10px;"></i>
                </a>
            }
            else
            {
                <button class="page-btn" disabled>
                    <i class="fas fa-chevron-left" style="font-size:10px;"></i>
                </button>
            }

            @for (int p = 1; p <= pageModel.TotalPages; p++)
            {
                if (p == pageModel.Page)
                {
                    <button class="page-btn active">@p</button>
                }
                else
                {
                    <a class="page-btn" href="@Url.Action("LopHoc", new { page = p, pageSize = pageModel.PageSize })">@p</a>
                }
            }

            @if (pageModel.HasNext)
            {
                <a class="page-btn" href="@Url.Action("LopHoc", new { page = pageModel.Page + 1, pageSize = pageModel.PageSize })">
                    <i class="fas fa-chevron-right" style="font-size:10px;"></i>
                </a>
            }
            else
            {
                <button class="page-btn" disabled>
                    <i class="fas fa-chevron-right" style="font-size:10px;"></i>
                </button>
            }
        </div>
    </div>

</div>

<div id="addModal"
     style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.4);z-index:2000;align-items:center;justify-content:center;">
    <div
        style="background:white;border-radius:12px;padding:32px;width:520px;max-width:90vw;max-height:90vh;overflow-y:auto;">
        <h4 style="margin-bottom:24px;">Lên lịch lớp mới</h4>
        <form method="post" action="/Admin/AddLopHoc">
            @Html.AntiForgeryToken()
            <div class="form-group">
                <label class="form-label">Tên lớp</label>
                <input type="text" name="TenLop" class="form-control" required>
            </div>
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;">
                <div class="form-group">
                    <label class="form-label">Khóa học</label>
                    <select name="MaKhoaHoc" class="form-control form-select">
                        <option value="">— Chọn —</option>
                        @if (ViewBag.KhoaHocs != null)
                        {
                            @foreach (var kh in (IEnumerable<BTL_Web.Models.KhoaHoc>)ViewBag.KhoaHocs)
                            {
                                <option value="@kh.MaKhoaHoc">@kh.TenKhoaHoc</option>
                            }
                        }
                    </select>
                </div>
                <div class="form-group">
                    <label class="form-label">Giáo viên</label>
                    <select name="MaGv" class="form-control form-select">
                        <option value="">— Chọn —</option>
                        @if (ViewBag.GiaoViens != null)
                        {
                            @foreach (var gv in (IEnumerable<BTL_Web.Models.GiaoVien>)ViewBag.GiaoViens)
                            {
                                <option value="@gv.MaGv">@gv.Ten</option>
                            }
                        }
                    </select>
                </div>
            </div>
            <div class="form-group">
                <label class="form-label">Phòng</label>
                <select name="MaPhong" class="form-control form-select">
                    <option value="">— Chọn —</option>
                    @if (ViewBag.PhongHocs != null)
                    {
                        @foreach (var ph in (IEnumerable<BTL_Web.Models.PhongHoc>)ViewBag.PhongHocs)
                        {
                            <option value="@ph.MaPhong">@ph.TenPhong</option>
                        }
                    }
                </select>
            </div>
            <div style="display:flex;gap:12px;justify-content:flex-end;margin-top:24px;">
                <button type="button" class="btn-outline"
                        onclick="document.getElementById('addModal').style.display='none'">Hủy</button>
                <button type="submit" class="btn-primary">Tạo lớp</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        let currentClassStatus = 'all';

        function toggleClassFilterPanel() {
            const panel = document.getElementById('classFilterPanel');
            if (!panel) return;
            panel.style.display = panel.style.display === 'none' || panel.style.display === '' ? 'block' : 'none';
        }

        function applyClassFilters() {
            const query = (document.getElementById('classFilterInput')?.value || '').trim().toLowerCase();
            const rows = document.querySelectorAll('.class-row');
            let visible = 0;

            rows.forEach(row => {
                const students = Number(row.getAttribute('data-students') || '0');
                let statusMatch = true;
                if (currentClassStatus === 'active') statusMatch = students > 0;
                if (currentClassStatus === 'completed') statusMatch = students === 0;

                const text = (row.textContent || '').toLowerCase();
                const queryMatch = !query || text.includes(query);

                const show = statusMatch && queryMatch;
                row.style.display = show ? '' : 'none';
                if (show) visible++;
            });

            const emptyRow = document.getElementById('classFilterEmptyRow');
            if (emptyRow) emptyRow.style.display = visible === 0 ? '' : 'none';
        }

        function clearClassFilter() {
            const input = document.getElementById('classFilterInput');
            if (input) input.value = '';
            currentClassStatus = 'all';
            document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
            const allBtn = document.querySelector('.filter-btn');
            if (allBtn) allBtn.classList.add('active');
            applyClassFilters();
        }

        document.querySelectorAll('.filter-btn').forEach(btn => {
            btn.addEventListener('click', function () {
                document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
                this.classList.add('active');

                const text = (this.textContent || '').trim().toLowerCase();
                    currentClassStatus = this.dataset.filter || 'all';

                applyClassFilters();
            });
        });

        function deleteClass(id) {
                if (confirm('Bạn có chắc muốn xóa lớp ' + id + '?')) location.href = '/Admin/DeleteLopHoc/' + id;
        }
    </script>
}
