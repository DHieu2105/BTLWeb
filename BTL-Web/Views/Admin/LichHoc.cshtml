@model IEnumerable<BTL_Web.Models.LichHoc>
@{
    ViewData["Title"] = "Manage Schedules";
    var sessions = (Model ?? Enumerable.Empty<BTL_Web.Models.LichHoc>()).ToList();
}

<div class="page-header">
    <div>
        <h2>Manage Schedules</h2>
        <p>Weekly class schedule and session management</p>
    </div>
    <div class="page-actions">
        <button class="btn-outline"><i class="fas fa-calendar-week"></i> Week View</button>
        <button class="btn-primary" onclick="openScheduleModal('add')">
            <i class="fas fa-plus"></i> Add Schedule
        </button>
    </div>
</div>

<div class="stats-grid" style="grid-template-columns:repeat(3,1fr);margin-bottom:24px;">
    <div class="stat-card blue">
        <div class="stat-card-header">
            <div class="stat-icon blue"><i class="fas fa-calendar-check"></i></div><span
            class="stat-badge blue">Live</span>
        </div>
        <div class="stat-label">Total Sessions</div>
        <div class="stat-value">@sessions.Count</div>
    </div>
    <div class="stat-card teal">
        <div class="stat-card-header">
            <div class="stat-icon teal"><i class="fas fa-door-open"></i></div>
        </div>
        <div class="stat-label">Room Occupancy</div>
        <div class="stat-value">75%</div>
    </div>
    <div class="stat-card highlighted" style="background:var(--sidebar-bg);">
        <div class="stat-card-header">
            <div class="stat-icon white"><i class="fas fa-bell"></i></div>
        </div>
        <div class="stat-label" style="color:rgba(255,255,255,0.7);">Next Session</div>
        <div class="stat-value" style="color:white;font-size:18px;">IELTS B2 — 10:00 AM</div>
    </div>
</div>

<div class="card-plain" style="padding:0;">
    <div class="card-header-plain">
        <h5>Schedule List</h5>
        <div style="display:flex;gap:8px;">
            <button type="button" class="filter-btn active" data-filter="all">All</button>
            <button type="button" class="filter-btn" data-filter="morning">Morning</button>
            <button type="button" class="filter-btn" data-filter="afternoon">Afternoon</button>
        </div>
    </div>
    <table class="data-table">
        <thead>
            <tr>
                <th>Schedule ID</th>
                <th>Class</th>
                <th>Date</th>
                <th>Start Time</th>
                <th>End Time</th>
                <th>Room</th>
                <th>Status</th>
                <th style="text-align:right;">Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (sessions.Any())
            {
                @foreach (var lh in sessions)
                {
                    <tr class="schedule-row" data-hour="@(lh.GioBatDau?.Hour ?? 0)"
                        data-date="@(lh.NgayHoc?.ToString("yyyy-MM-dd") ?? "")">
                        <td><span class="chip chip-gray">@lh.MaLichHoc</span></td>
                        <td>@(lh.MaLopNavigation?.TenLop ?? lh.MaLop ?? "—")</td>
                        <td class="user-name">@(lh.NgayHoc?.ToString("dd/MM/yyyy") ?? "—")</td>
                        <td class="user-name">@(lh.GioBatDau?.ToString(@"HH\:mm") ?? "—")</td>
                        <td class="user-sub">@(lh.GioKetThuc?.ToString(@"HH\:mm") ?? "—")</td>
                        <td>@(lh.MaPhongNavigation?.TenPhong ?? lh.MaPhong ?? "—")</td>
                        <td><span class="chip chip-green">Active</span></td>
                        <td style="text-align:right;">
                            <div style="display:flex;gap:4px;justify-content:flex-end;">
                                <button type="button" class="btn-icon btn-outline btn-sm edit-schedule-btn"
                                        data-id="@lh.MaLichHoc" data-class="@lh.MaLop"
                                        data-date="@(lh.NgayHoc?.ToString("yyyy-MM-dd") ?? "")"
                                        data-start="@(lh.GioBatDau?.ToString(@"HH\:mm") ?? "")"
                                        data-end="@(lh.GioKetThuc?.ToString(@"HH\:mm") ?? "")">
                                    <i class="fas fa-edit"></i>
                                </button>
                                <button class="btn-icon btn-outline btn-sm" onclick="deleteSched('@lh.MaLichHoc')">
                                    <i class="fas fa-trash" style="color:#ef4444;"></i>
                                </button>
                            </div>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="8">
                        <div class="empty-state"><i class="fas fa-calendar-alt"></i>
                            <p>No schedules found</p>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
    <div class="pagination-bar">
        <span class="pagination-info" id="scheduleCount">Showing @sessions.Count sessions</span>
        <div class="pagination-btns">
            <button type="button" class="page-btn" id="prevPageBtn"><i class="fas fa-chevron-left"
                                                                           style="font-size:10px;"></i></button>
                <div id="paginationNumbers" style="display:flex;gap:6px;"></div>
                <button type="button" class="page-btn" id="nextPageBtn"><i class="fas fa-chevron-right"
                                                                               style="font-size:10px;"></i></button>
                </div>
            </div>
        </div>

        <div id="scheduleModal"
             style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.4);z-index:2000;align-items:center;justify-content:center;">
            <div style="background:white;border-radius:12px;padding:32px;width:520px;max-width:90vw;">
                <h4 id="scheduleModalTitle" style="margin-bottom:24px;">Add Schedule</h4>
                <form method="post" action="/Admin/AddLichHoc" id="scheduleForm">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="MaLichHoc" id="scheduleId" value="">
                    <div class="form-group">
                        <label class="form-label">Class</label>
                        <select name="MaLop" id="classSelect" class="form-control form-select">
                            <option value="">— Select Class —</option>
                            @if (ViewBag.LopHocs != null)
                            {
                                @foreach (var lop in (IEnumerable<BTL_Web.Models.LopHoc>)ViewBag.LopHocs)
                                {
                                    <option value="@lop.MaLop" data-class-name="@(lop.TenLop ?? lop.MaLop)"
                                            data-teacher-name="@(lop.MaGvNavigation?.Ten ?? "—")"
                                            data-course-name="@(lop.MaKhoaHocNavigation?.TenKhoaHoc ?? "—")">
                                        @(lop.TenLop ?? lop.MaLop)
                                    </option>
                                }
                            }
                        </select>
                    </div>
                    <div class="card-plain" style="padding:16px;margin-bottom:16px;background:var(--surface-low);">
                        <div class="section-heading" style="margin-bottom:12px;">
                            <h5 style="margin:0;">Selected Class Info</h5>
                        </div>
                        <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
                            <div>
                                <div class="stat-label">Class Name</div>
                                <div id="modalClassName" class="user-name" style="font-size:14px;">—</div>
                            </div>
                            <div>
                                <div class="stat-label">Teacher</div>
                                <div id="modalTeacherName" class="user-name" style="font-size:14px;">—</div>
                            </div>
                        </div>
                        <div style="margin-top:12px;">
                            <div class="stat-label">Course</div>
                            <div id="modalCourseName" class="user-name" style="font-size:14px;">—</div>
                        </div>
                    </div>
                    <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;">
                        <div class="form-group">
                            <label class="form-label">Date</label>
                            <input type="date" name="NgayHoc" id="dateInput" class="form-control">
                        </div>
                        <div class="form-group">
                            <label class="form-label">Start Time</label>
                            <input type="time" name="GioBatDau" id="startInput" class="form-control">
                        </div>
                        <div class="form-group">
                            <label class="form-label">End Time</label>
                            <input type="time" name="GioKetThuc" id="endInput" class="form-control">
                        </div>
                        <div class="form-group">
                            <label class="form-label">Room</label>
                            <input type="text" id="roomDisplay" class="form-control" value="Auto from selected class" readonly>
                        </div>
                    </div>
                    <div style="display:flex;gap:12px;justify-content:flex-end;margin-top:24px;">
                        <button type="button" class="btn-outline" onclick="closeScheduleModal()">Cancel</button>
                        <button type="submit" id="scheduleSubmitBtn" class="btn-primary">Add Schedule</button>
                    </div>
                </form>
            </div>
        </div>

        @section Scripts {
            <script>
                document.addEventListener('DOMContentLoaded', function () {
                    const filterButtons = document.querySelectorAll('.filter-btn');
                    const rows = document.querySelectorAll('.schedule-row');
                    const scheduleCount = document.getElementById('scheduleCount');
                    const paginationNumbers = document.getElementById('paginationNumbers');
                    const prevPageBtn = document.getElementById('prevPageBtn');
                    const nextPageBtn = document.getElementById('nextPageBtn');
                    const modal = document.getElementById('scheduleModal');
                    const modalTitle = document.getElementById('scheduleModalTitle');
                    const scheduleForm = document.getElementById('scheduleForm');
                    const scheduleId = document.getElementById('scheduleId');
                    const classSelect = document.getElementById('classSelect');
                    const modalClassName = document.getElementById('modalClassName');
                    const modalTeacherName = document.getElementById('modalTeacherName');
                    const modalCourseName = document.getElementById('modalCourseName');
                    const roomDisplay = document.getElementById('roomDisplay');
                    const dateInput = document.getElementById('dateInput');
                    const startInput = document.getElementById('startInput');
                    const endInput = document.getElementById('endInput');
                    const submitBtn = document.getElementById('scheduleSubmitBtn');

                    const pageSize = 8;
                    let currentFilter = 'all';
                    let currentPage = 1;

                    function getFilteredRows() {
                        const list = [];
                        rows.forEach(row => {
                            const hour = parseInt(row.dataset.hour || '0', 10);
                            let visible = true;

                            if (currentFilter === 'morning') {
                                visible = hour < 12;
                            } else if (currentFilter === 'afternoon') {
                                visible = hour >= 12;
                            }

                            if (visible) {
                                list.push(row);
                            }
                        });
                        return list;
                    }

                    function setButtonState(btn, disabled) {
                        if (!btn) return;
                        btn.disabled = disabled;
                        btn.style.opacity = disabled ? '0.5' : '1';
                        btn.style.cursor = disabled ? 'not-allowed' : 'pointer';
                    }

                    function renderPagination(totalPages) {
                        if (!paginationNumbers) return;
                        paginationNumbers.innerHTML = '';
                        for (let page = 1; page <= totalPages; page++) {
                            const btn = document.createElement('button');
                            btn.type = 'button';
                            btn.className = 'page-btn' + (page === currentPage ? ' active' : '');
                            btn.textContent = page;
                            btn.addEventListener('click', function () {
                                if (currentPage === page) return;
                                currentPage = page;
                                applyPagination(false);
                            });
                            paginationNumbers.appendChild(btn);
                        }
                        setButtonState(prevPageBtn, currentPage <= 1);
                        setButtonState(nextPageBtn, currentPage >= totalPages);
                    }

                    function applyPagination(resetPage) {
                        const filteredRows = getFilteredRows();
                        const totalItems = filteredRows.length;
                        const totalPages = Math.max(1, Math.ceil(totalItems / pageSize));

                        if (resetPage) {
                            currentPage = 1;
                        } else if (currentPage > totalPages) {
                            currentPage = totalPages;
                        }

                        rows.forEach(row => row.style.display = 'none');

                        const startIndex = (currentPage - 1) * pageSize;
                        const endIndex = Math.min(startIndex + pageSize, totalItems);
                        for (let i = startIndex; i < endIndex; i++) {
                            filteredRows[i].style.display = '';
                        }

                        renderPagination(totalPages);
                        if (scheduleCount) {
                            scheduleCount.textContent = totalItems === 0
                                ? 'Showing 0 sessions'
                                : 'Showing ' + (startIndex + 1) + '-' + endIndex + ' of ' + totalItems + ' sessions';
                        }
                    }

                    filterButtons.forEach(btn => {
                        btn.addEventListener('click', function () {
                            filterButtons.forEach(b => b.classList.remove('active'));
                            this.classList.add('active');
                            currentFilter = this.dataset.filter || 'all';
                            applyPagination(true);
                        });
                    });

                    if (prevPageBtn) {
                        prevPageBtn.addEventListener('click', function () {
                            if (currentPage <= 1) return;
                            currentPage -= 1;
                            applyPagination(false);
                        });
                    }

                    if (nextPageBtn) {
                        nextPageBtn.addEventListener('click', function () {
                            const totalItems = getFilteredRows().length;
                            const totalPages = Math.max(1, Math.ceil(totalItems / pageSize));
                            if (currentPage >= totalPages) return;
                            currentPage += 1;
                            applyPagination(false);
                        });
                    }

                    function updateClassInfo() {
                        if (!classSelect || !modalClassName || !modalTeacherName || !modalCourseName) {
                            return;
                        }

                        const selected = classSelect.options[classSelect.selectedIndex];
                        if (!selected) {
                            modalClassName.textContent = '—';
                            modalTeacherName.textContent = '—';
                            modalCourseName.textContent = '—';
                            if (roomDisplay) roomDisplay.value = 'Auto from selected class';
                            return;
                        }

                        modalClassName.textContent = selected.dataset.className || selected.textContent.trim() || '—';
                        modalTeacherName.textContent = selected.dataset.teacherName || '—';
                        modalCourseName.textContent = selected.dataset.courseName || '—';
                        if (roomDisplay) roomDisplay.value = 'Auto from selected class';
                    }

                    if (classSelect) {
                        classSelect.addEventListener('change', updateClassInfo);
                        updateClassInfo();
                    }

                    document.querySelectorAll('.edit-schedule-btn').forEach(btn => {
                        btn.addEventListener('click', function () {
                            openScheduleModal('edit', this.dataset);
                        });
                    });

                    applyPagination(true);

                    window.openScheduleModal = function (mode, data) {
                        if (!modal || !scheduleForm || !scheduleId || !classSelect || !dateInput || !startInput || !endInput || !submitBtn || !modalTitle) {
                            return;
                        }

                        scheduleForm.action = mode === 'edit' ? '/Admin/EditLichHoc' : '/Admin/AddLichHoc';
                        modalTitle.textContent = mode === 'edit' ? 'Edit Schedule' : 'Add Schedule';
                        submitBtn.textContent = mode === 'edit' ? 'Save Changes' : 'Add Schedule';
                        scheduleId.value = mode === 'edit' ? (data?.id || '') : '';
                        classSelect.value = mode === 'edit' ? (data?.class || '') : '';
                        dateInput.value = mode === 'edit' ? (data?.date || '') : '';
                        startInput.value = mode === 'edit' ? (data?.start || '') : '';
                        endInput.value = mode === 'edit' ? (data?.end || '') : '';
                        updateClassInfo();
                        modal.style.display = 'flex';
                    };

                    window.closeScheduleModal = function () {
                        if (modal) {
                            modal.style.display = 'none';
                        }
                    };
                });
                function deleteSched(id) {
                    if (confirm('Delete schedule ' + id + '?')) location.href = '/Admin/DeleteLichHoc/' + id;
                }
            </script>
        }
