@{
    ViewData["Title"] = "Phân công nhân viên - giáo viên";
    var isAdmin = User.IsInRole("Admin");
    var nhanViens = ViewBag.NhanViens as IEnumerable<BTL_Web.Models.NhanVien> ?? new List<BTL_Web.Models.NhanVien>();
    var giaoViens = ViewBag.GiaoViens as IEnumerable<BTL_Web.Models.GiaoVien> ?? new List<BTL_Web.Models.GiaoVien>();
    var trungTams = ViewBag.TrungTams as IEnumerable<BTL_Web.Models.TrungTam> ?? new List<BTL_Web.Models.TrungTam>();
    var keyword = ViewBag.Keyword as string ?? "";
    var center = ViewBag.Center as string ?? "";
    var unassignedOnly = ViewBag.UnassignedOnly != null && (bool)ViewBag.UnassignedOnly;
    var currentPage = ViewBag.Page != null ? (int)ViewBag.Page : 1;
    var totalPages = ViewBag.TotalPages != null ? (int)ViewBag.TotalPages : 1;
    var pageSize = ViewBag.PageSize != null ? (int)ViewBag.PageSize : 10;
    var totalItems = ViewBag.TotalItems != null ? (int)ViewBag.TotalItems : nhanViens.Count();
    var totalStaff = ViewBag.TotalStaff != null ? (int)ViewBag.TotalStaff : nhanViens.Count();
    var totalTeachers = ViewBag.TotalTeachers != null ? (int)ViewBag.TotalTeachers : giaoViens.Count();
    var unassignedTeachers = ViewBag.UnassignedTeachers != null ? (int)ViewBag.UnassignedTeachers : giaoViens.Count(g => !g.MaNvs.Any());
    var maxTeachersPerStaff = ViewBag.MaxTeachersPerStaff != null ? (int)ViewBag.MaxTeachersPerStaff : 8;
}

<div class="page-header">
    <div>
        <h2>Phân công nhân viên - giáo viên</h2>
        <p>@totalItems bản ghi nhân viên trong bộ lọc hiện tại</p>
    </div>
    <div class="page-actions">
        <form method="get" style="display:flex;gap:8px;align-items:center;">
            <input class="form-control" type="text" name="keyword" value="@keyword" placeholder="Tìm nhân viên..." style="width:210px;" />
            <select class="form-control form-select" name="center" style="width:170px;">
                <option value="">Tất cả trung tâm</option>
                @foreach (var tt in trungTams)
                {
                    if (tt.MaTrungTam == center)
                    {
                        <option value="@tt.MaTrungTam" selected>@tt.TenTrungTam</option>
                    }
                    else
                    {
                        <option value="@tt.MaTrungTam">@tt.TenTrungTam</option>
                    }
                }
            </select>
            <label style="display:flex;gap:6px;align-items:center;font-size:13px;white-space:nowrap;">
                <input type="checkbox" name="unassignedOnly" value="true" @(unassignedOnly ? "checked" : null) />
                Chỉ chưa phân công
            </label>
            <select class="form-control form-select" name="pageSize" style="width:110px;">
                @foreach (var size in new[] { 10, 20, 50 })
                {
                    if (size == pageSize)
                    {
                        <option value="@size" selected>@size / trang</option>
                    }
                    else
                    {
                        <option value="@size">@size / trang</option>
                    }
                }
            </select>
            <button class="btn-outline" type="submit"><i class="fas fa-filter"></i> Lọc</button>
        </form>
        @if (isAdmin)
        {
            <button class="btn-primary" onclick="document.getElementById('assignModal').style.display='flex'">
                <i class="fas fa-plus"></i> Phân công mới
            </button>
        }
    </div>
</div>

<div style="display:grid;grid-template-columns:1fr 1fr 1fr 1fr;gap:16px;margin-bottom:24px;">
    <div class="card-plain" style="padding:20px;">
        <div class="stat-label">Tổng nhân viên</div>
        <div class="stat-value">@totalStaff</div>
    </div>
    <div class="card-plain" style="padding:20px;">
        <div class="stat-label">Tổng giáo viên</div>
        <div class="stat-value">@totalTeachers</div>
    </div>
    <div class="card-plain" style="padding:20px;">
        <div class="stat-label">Giáo viên chưa phân công</div>
        <div class="stat-value" style="color:#f97316;">@unassignedTeachers</div>
    </div>
    <div class="card-plain" style="padding:20px;">
        <div class="stat-label">Tải công việc tối đa</div>
        <div class="stat-value" style="color:#10b981;">@maxTeachersPerStaff teachers</div>
    </div>
</div>

@if (TempData["Success"] is string success)
{
    <div class="alert alert-success" style="margin-bottom:16px;">@success</div>
}
@if (TempData["Error"] is string error)
{
    <div class="alert alert-danger" style="margin-bottom:16px;">@error</div>
}

<div style="display:grid;grid-template-columns:2fr 1fr;gap:24px;">
    <div class="card-plain" style="padding:0;">
        <div class="card-header-plain">
            <h5>Phân công nhân viên</h5>
            <span class="chip chip-blue">@totalItems nhân viên</span>
        </div>
        <table class="data-table">
            <thead>
                <tr>
                    <th>Nhân viên</th>
                    <th>Giáo viên đã gán</th>
                    <th>Tải công việc</th>
                    <th>Trạng thái</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var nv in nhanViens)
                {
                    var name = nv.HoVaTen ?? nv.MaNv;
                    var ini = string.Join("", name.Split(' ').Take(2).Select(w => w.FirstOrDefault().ToString().ToUpper()));
                    var assignedCount = nv.MaGvs.Count;
                    var workloadPercent = Math.Min((int)Math.Round((double)assignedCount * 100 / maxTeachersPerStaff), 100);
                    <tr>
                        <td>
                            <div class="user-row">
                                <div class="avatar">@ini</div>
                                <div>
                                    <div class="user-name">@name</div>
                                    <div class="user-sub">@(nv.ChucVu ?? nv.MaNv) • @(nv.MaTrungTamNavigation?.TenTrungTam ?? nv.MaTrungTam ?? "—")</div>
                                </div>
                            </div>
                        </td>
                        <td>
                            @if (nv.MaGvs.Any())
                            {
                                <div style="display:flex;flex-wrap:wrap;gap:6px;max-width:380px;">
                                    @foreach (var gv in nv.MaGvs.OrderBy(g => g.MaGv))
                                    {
                                        if (isAdmin)
                                        {
                                            <form method="post" action="/Admin/UnassignStaffTeacher" style="display:inline;">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="MaNv" value="@nv.MaNv" />
                                                <input type="hidden" name="MaGv" value="@gv.MaGv" />
                                                <button type="submit" class="chip chip-blue" title="Unassign @gv.Ten" style="border:none;cursor:pointer;">
                                                    @gv.Ten (@gv.MaGv) <i class="fas fa-times" style="font-size:10px;margin-left:4px;"></i>
                                                </button>
                                            </form>
                                        }
                                        else
                                        {
                                            <span class="chip chip-blue">@gv.Ten (@gv.MaGv)</span>
                                        }
                                    }
                                </div>
                            }
                            else
                            {
                                <span class="small text-muted">Chưa gán giáo viên</span>
                            }
                            <span class="smaller text-muted" style="margin-top:4px;display:block;">@assignedCount / @maxTeachersPerStaff giáo viên</span>
                        </td>
                        <td>
                            <div class="progress-bar-wrap" style="width:100px;margin-bottom:4px;">
                                <div class="progress-bar-fill" style="width:@workloadPercent%;"></div>
                            </div>
                            <span class="smaller text-muted">@workloadPercent%</span>
                        </td>
                        <td>
                            @if (assignedCount == 0)
                            {
                                <span class="chip chip-gray">Rảnh</span>
                            }
                            else if (assignedCount >= maxTeachersPerStaff)
                            {
                                <span class="chip" style="background:#fef2f2;color:#dc2626;">Đầy</span>
                            }
                            else
                            {
                                <span class="chip chip-green">Đang hoạt động</span>
                            }
                        </td>
                    </tr>
                }
                @if (!nhanViens.Any())
                {
                    <tr><td colspan="4"><div class="empty-state"><i class="fas fa-users-cog"></i><p>Không tìm thấy nhân viên nào</p></div></td></tr>
                }
            </tbody>
        </table>
        <div class="pagination-bar">
            <span class="pagination-info">Trang @currentPage / @totalPages</span>
            <div class="pagination-btns">
                <a class="page-btn" href="@Url.Action("StaffTeacherAssignment", new { page = currentPage > 1 ? currentPage - 1 : 1, pageSize, keyword, center, unassignedOnly })"><i class="fas fa-chevron-left" style="font-size:10px;"></i></a>
                @for (var i = 1; i <= totalPages; i++)
                {
                    if (i == currentPage)
                    {
                        <button class="page-btn active">@i</button>
                    }
                    else
                    {
                        <a class="page-btn" href="@Url.Action("StaffTeacherAssignment", new { page = i, pageSize, keyword, center, unassignedOnly })">@i</a>
                    }
                }
                <a class="page-btn" href="@Url.Action("StaffTeacherAssignment", new { page = currentPage < totalPages ? currentPage + 1 : totalPages, pageSize, keyword, center, unassignedOnly })"><i class="fas fa-chevron-right" style="font-size:10px;"></i></a>
            </div>
        </div>
    </div>

    <div style="display:flex;flex-direction:column;gap:16px;">
        <div class="card-plain" style="padding:24px;">
            <h5 style="margin-bottom:16px;"><i class="fas fa-filter" style="color:var(--primary);margin-right:8px;"></i>Bộ lọc nhanh</h5>
            <div class="form-group">
                <label class="form-label">Trung tâm</label>
                <select class="form-control form-select" onchange="applyCenterFilter(this.value)">
                    <option value="">Tất cả trung tâm</option>
                    @foreach (var tt in trungTams)
                    {
                        if (tt.MaTrungTam == center)
                        {
                            <option value="@tt.MaTrungTam" selected>@tt.TenTrungTam</option>
                        }
                        else
                        {
                            <option value="@tt.MaTrungTam">@tt.TenTrungTam</option>
                        }
                    }
                </select>
            </div>
            <a class="btn-outline" href="@Url.Action("StaffTeacherAssignment")" style="justify-content:center;">Đặt lại</a>
        </div>

        <div class="card-plain" style="padding:24px;">
            <h5 style="margin-bottom:16px;">Giáo viên gần đây</h5>
            <div style="display:flex;flex-direction:column;gap:12px;">
                @foreach (var gv in giaoViens.Take(5))
                                {
                                    var gn = gv.Ten ?? "?";
                                    var gi = string.Join("", gn.Split(' ').Take(2).Select(w => w.FirstOrDefault().ToString().ToUpper()));
                    <div style="display:flex;gap:12px;padding:10px;background:var(--surface-low);border-radius:8px;border-left:3px solid var(--primary);">
                        <div class="avatar avatar-sm">@gi</div>
                        <div>
                            <div class="user-name" style="font-size:13px;">@gn</div>
                            <div class="user-sub">@(gv.ChuyenMon ?? "—")</div>
                            <div class="activity-time">@gv.MaGv</div>
                        </div>
                    </div>
                }
            </div>
        </div>
        <div class="card-plain" style="padding:24px;">
            <h5 style="margin-bottom:8px;">Quy tắc phân công</h5>
            <p class="small text-muted" style="margin-bottom:16px;">Một nhân viên có thể phụ trách tối đa <strong>@maxTeachersPerStaff</strong> giáo viên. Nhân viên đã đầy sẽ không nhận thêm phân công mới.</p>
            @if (isAdmin)
            {
                <button class="btn-outline" style="width:100%;justify-content:center;" onclick="document.getElementById('assignModal').style.display='flex'">
                    <i class="fas fa-user-plus"></i> Phân công ngay
                </button>
            }
            else
            {
                <div class="small text-muted">Bạn có quyền xem phân công. Chức năng gán/bỏ gán dành cho Admin.</div>
            }
        </div>
    </div>
</div>

@if (isAdmin)
{
    <div id="assignModal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.4);z-index:2000;align-items:center;justify-content:center;">
        <div style="background:white;border-radius:12px;padding:32px;width:480px;max-width:90vw;">
            <h4 style="margin-bottom:24px;">Gán giáo viên cho nhân viên</h4>
            <form method="post" action="/Admin/AssignStaffTeacher">
                @Html.AntiForgeryToken()
                <div class="form-group">
                    <label class="form-label">Nhân viên</label>
                    <select name="MaNv" id="assignStaffSelect" class="form-control form-select">
                        <option value="">— Chọn nhân viên —</option>
                        @foreach (var nv in (ViewBag.AllNhanViens as IEnumerable<BTL_Web.Models.NhanVien> ?? new List<BTL_Web.Models.NhanVien>()).OrderBy(n => n.MaNv))
                        {
                            <option value="@nv.MaNv">@(nv.HoVaTen ?? nv.MaNv) (@nv.MaNv)</option>
                        }
                    </select>
                </div>
                <div class="form-group">
                    <label class="form-label">Giáo viên</label>
                    <select name="MaGv" class="form-control form-select">
                        <option value="">— Chọn giáo viên —</option>
                        @foreach (var gv in giaoViens.OrderBy(g => g.MaGv))
                        {
                            <option value="@gv.MaGv">@(gv.Ten ?? gv.MaGv) (@gv.MaGv)</option>
                        }
                    </select>
                </div>
                <div style="display:flex;gap:12px;justify-content:flex-end;margin-top:24px;">
                    <button type="button" class="btn-outline" onclick="document.getElementById('assignModal').style.display='none'">Hủy</button>
                    <button type="submit" class="btn-primary">Gán</button>
                </div>
            </form>
        </div>
    </div>
}

@section Scripts {
<script>
function applyCenterFilter(value) {
    const params = new URLSearchParams(window.location.search);
    if (value) {
        params.set('center', value);
    } else {
        params.delete('center');
    }
    params.set('page', '1');
    window.location.href = '/Admin/StaffTeacherAssignment?' + params.toString();
}
</script>
}
