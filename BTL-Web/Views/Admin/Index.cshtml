@{
    ViewData["Title"] = "Bảng điều khiển quản trị";
}

<div class="page-header">
    <div>
        <h2>Thông tin trung tâm</h2>
        <p>Chào mừng trở lại, @User.Identity?.Name. Hôm nay đang có gì mới.</p>
    </div>
    <div class="page-actions">
        <button class="btn-outline">
            <i class="far fa-file-alt"></i> Xuất báo cáo
        </button>
        <a href="/Admin/LopHoc" class="btn-primary">
            <i class="fas fa-plus"></i> Ghi danh lớp nhanh
        </a>
    </div>
</div>

<!-- Stats Grid -->
<div class="stats-grid">
    <div class="stat-card blue">
        <div class="stat-card-header">
            <div class="stat-icon blue"><i class="fas fa-users"></i></div>
            <span class="stat-badge blue">+12%</span>
        </div>
        <div class="stat-label">Tổng học viên</div>
        <div class="stat-value">@(ViewBag.TotalStudents ?? 1248)</div>
    </div>
    <div class="stat-card orange">
        <div class="stat-card-header">
            <div class="stat-icon orange"><i class="fas fa-chalkboard-teacher"></i></div>
            <span class="stat-badge orange">Đang hoạt động</span>
        </div>
        <div class="stat-label">Tổng giáo viên</div>
        <div class="stat-value">@(ViewBag.TotalTeachers ?? 42)</div>
    </div>
    <div class="stat-card teal">
        <div class="stat-card-header">
            <div class="stat-icon teal"><i class="fas fa-book-open"></i></div>
            <span class="stat-badge teal">18 hôm nay</span>
        </div>
        <div class="stat-label">Lớp đang hoạt động</div>
        <div class="stat-value">@(ViewBag.TotalClasses ?? 86)</div>
    </div>
    <div class="stat-card highlighted">
        <div class="stat-card-header">
            <div class="stat-icon white"><i class="fas fa-dollar-sign"></i></div>
            <span class="stat-badge white">+4.2%</span>
        </div>
        <div class="stat-label">Doanh thu tháng</div>
        <div class="stat-value">$52,490</div>
    </div>
</div>

<!-- Main Content -->
<div style="display:grid;grid-template-columns:2fr 1fr;gap:24px;margin-bottom:24px;">
    <!-- Bar Chart Card -->
    <div class="card-plain" style="padding:32px;">
        <div class="section-heading">
            <div>
                <h4 style="margin-bottom:4px;">Ghi danh học viên</h4>
                <p class="small text-muted">Số lượt ghi danh mới trong 6 tháng gần đây</p>
            </div>
            <button class="btn-icon btn-outline"><i class="fas fa-ellipsis-h"></i></button>
        </div>
        <div class="bar-chart" style="height:200px;margin-top:24px;">
            <div class="bar-item">
                <div class="bar" style="height:50%;"></div>
                <span class="bar-label">JAN</span>
            </div>
            <div class="bar-item">
                <div class="bar" style="height:62%;"></div>
                <span class="bar-label">FEB</span>
            </div>
            <div class="bar-item">
                <div class="bar" style="height:75%;"></div>
                <span class="bar-label">MAR</span>
            </div>
            <div class="bar-item">
                <div class="bar" style="height:56%;"></div>
                <span class="bar-label">APR</span>
            </div>
            <div class="bar-item">
                <div class="bar" style="height:87%;"></div>
                <span class="bar-label">MAY</span>
            </div>
            <div class="bar-item">
                <div class="bar active" style="height:100%;"></div>
                <span class="bar-label">JUN</span>
            </div>
        </div>
    </div>

    <!-- Recent Activity -->
    <div class="card-plain" style="padding:32px;">
        <div class="section-heading">
            <h4>Sự kiện gần đây</h4>
            <a href="/Admin/NhanVien">XEM TẤT CẢ</a>
        </div>
        <div>
            <div class="activity-item">
                <div class="activity-icon blue"><i class="fas fa-user-plus"></i></div>
                <div class="activity-content">
                    <div class="activity-title">Học viên mới đã ghi danh</div>
                    <div class="activity-desc">Sarah Jenkins tham gia <strong>IELTS Prep B2</strong></div>
                    <div class="activity-time">2 phút trước</div>
                </div>
            </div>
            <div class="activity-item">
                <div class="activity-icon orange"><i class="fas fa-credit-card"></i></div>
                <div class="activity-content">
                    <div class="activity-title">Đã nhận thanh toán</div>
                    <div class="activity-desc">Học phí của <strong>Marc Oliver</strong> đã được xử lý</div>
                    <div class="activity-time">45 phút trước</div>
                </div>
            </div>
            <div class="activity-item">
                <div class="activity-icon purple"><i class="fas fa-file-alt"></i></div>
                <div class="activity-content">
                    <div class="activity-title">Đã công bố kết quả thi</div>
                    <div class="activity-desc">Kết quả cuối cùng của <strong>C1 Advanced Group 3</strong></div>
                    <div class="activity-time">2 giờ trước</div>
                </div>
            </div>
            <div class="activity-item">
                <div class="activity-icon red"><i class="fas fa-times-circle"></i></div>
                <div class="activity-content">
                    <div class="activity-title">Đã hủy lớp học</div>
                    <div class="activity-desc">Business English <strong>Phòng 402</strong> (giảng viên bị ốm)</div>
                    <div class="activity-time">5 giờ trước</div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Department Leads Table -->
<div class="card-plain" style="padding:0;">
    <div class="card-header-plain">
        <h5>Trưởng bộ phận</h5>
        <a href="/Admin/NhanVien" class="small" style="color:var(--primary);font-weight:700;text-decoration:none;">
            Xem danh bạ <i class="fas fa-arrow-right" style="font-size:10px;"></i>
        </a>
    </div>
    <table class="data-table">
        <thead>
            <tr>
                <th>Nhân sự</th>
                <th>Phòng ban</th>
                <th>Phân bổ</th>
                <th>Trạng thái</th>
                <th style="text-align:right;">Thao tác</th>
            </tr>
        </thead>
        <tbody>
            <tr>
                <td>
                    <div class="user-row">
                        <div class="avatar">ER</div>
                        <div>
                            <div class="user-name">Elena Rodriguez</div>
                            <div class="user-sub">e.rodriguez@center.edu</div>
                        </div>
                    </div>
                </td>
                <td>Trưởng bộ phận khảo thí</td>
                <td>
                    <div class="progress-bar-wrap" style="width:100px;margin-bottom:4px;">
                        <div class="progress-bar-fill" style="width:85%;"></div>
                    </div>
                    <span class="smaller text-muted">Đã tải 85%</span>
                </td>
                <td><span class="chip chip-blue">Tại trung tâm</span></td>
                <td style="text-align:right;">
                    <button class="btn-icon btn-outline btn-sm"><i class="fas fa-ellipsis-v"></i></button>
                </td>
            </tr>
            <tr>
                <td>
                    <div class="user-row">
                        <div class="avatar">MC</div>
                        <div>
                            <div class="user-name">Marcus Chen</div>
                            <div class="user-sub">m.chen@center.edu</div>
                        </div>
                    </div>
                </td>
                <td>Phát triển chương trình</td>
                <td>
                    <div class="progress-bar-wrap" style="width:100px;margin-bottom:4px;">
                        <div class="progress-bar-fill" style="width:42%;"></div>
                    </div>
                    <span class="smaller text-muted">Đã tải 42%</span>
                </td>
                <td><span class="chip chip-yellow">Từ xa</span></td>
                <td style="text-align:right;">
                    <button class="btn-icon btn-outline btn-sm"><i class="fas fa-ellipsis-v"></i></button>
                </td>
            </tr>
        </tbody>
    </table>
</div>
