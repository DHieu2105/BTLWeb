@model BTL_Web.Models.PhongHoc
@{
    ViewData["Title"] = "Chi tiết phòng";
}

<div class="page-header">
    <div>
        <h2>Chi tiết phòng</h2>
        <p>Tổng quan hoạt động cho phòng học đã chọn</p>
    </div>
    <div class="page-actions">
        <a href="/Admin/PhongHoc" class="btn-outline"><i class="fas fa-arrow-left"></i> Quay lại</a>
        @if (Model != null)
        {
            <a href="/Admin/RoomEquipmentAssignment?roomId=@Model.MaPhong" class="btn-primary"><i class="fas fa-tools"></i> Quản lý thiết bị</a>
        }
    </div>
</div>

@if (Model == null)
{
    <div class="card-plain" style="padding:32px;">
        <div class="empty-state"><i class="fas fa-door-open"></i><p>Không tìm thấy phòng</p></div>
    </div>
}
else
{
    <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:16px;margin-bottom:24px;">
        <div class="card-plain" style="padding:20px;">
            <div class="stat-label">Phòng</div>
            <div class="stat-value" style="font-size:20px;">@(Model.TenPhong ?? Model.MaPhong)</div>
            <div class="user-sub">@Model.MaPhong</div>
        </div>
        <div class="card-plain" style="padding:20px;">
            <div class="stat-label">Trung tâm</div>
            <div class="stat-value" style="font-size:18px;">@(Model.MaTrungTamNavigation?.TenTrungTam ?? "—")</div>
        </div>
        <div class="card-plain" style="padding:20px;">
            <div class="stat-label">Lịch học</div>
            <div class="stat-value" style="font-size:24px;">@(Model.LichHocs?.Count ?? 0)</div>
        </div>
        <div class="card-plain" style="padding:20px;">
            <div class="stat-label">Thiết bị</div>
            <div class="stat-value" style="font-size:24px;">@(Model.MaThietBis?.Count ?? 0)</div>
        </div>
    </div>

    <div style="display:grid;grid-template-columns:2fr 1fr;gap:24px;">
        <div class="card-plain" style="padding:0;">
            <div class="card-header-plain">
                <h5>Lịch học</h5>
            </div>
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Ngày</th>
                        <th>Bắt đầu</th>
                        <th>Kết thúc</th>
                        <th>Trạng thái</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.LichHocs != null && Model.LichHocs.Any())
                    {
                        @foreach (var sc in Model.LichHocs.OrderBy(s => s.NgayHoc))
                        {
                            <tr>
                                <td>@(sc.NgayHoc?.ToString("dd/MM/yyyy") ?? "—")</td>
                                <td>@(sc.GioBatDau?.ToString(@"hh\:mm") ?? "—")</td>
                                <td>@(sc.GioKetThuc?.ToString(@"hh\:mm") ?? "—")</td>
                                <td><span class="chip chip-green">Đang hoạt động</span></td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr><td colspan="4"><div class="empty-state"><i class="fas fa-calendar"></i><p>Không có lịch học</p></div></td></tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="card-plain" style="padding:24px;">
            <h5 style="margin-bottom:12px;">Thiết bị hiện tại</h5>
            @if (Model.MaThietBis != null && Model.MaThietBis.Any())
            {
                <div style="display:flex;flex-direction:column;gap:8px;">
                    @foreach (var tb in Model.MaThietBis)
                    {
                        <div class="activity-item" style="padding:10px;background:var(--surface-low);border-radius:8px;">
                            <div class="activity-icon blue"><i class="fas fa-laptop"></i></div>
                            <div class="activity-content">
                                <div class="activity-title">@(tb.TenThietBi ?? tb.MaThietBi)</div>
                                <div class="activity-desc">@tb.MaThietBi</div>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="empty-state"><i class="fas fa-tools"></i><p>Chưa gán thiết bị</p></div>
            }
        </div>
    </div>
}
