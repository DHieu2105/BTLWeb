@model IEnumerable<BTL_Web.Models.GiaoVien>
@using System.Security.Claims
@{
    ViewData["Title"] = "Quản lý giáo viên";
    var role = User.FindFirst(ClaimTypes.Role)?.Value ?? "";
    var isAdmin = role == "Admin";
    var currentPage = ViewBag.Page != null ? (int)ViewBag.Page : 1;
    var totalPages = ViewBag.TotalPages != null ? (int)ViewBag.TotalPages : 1;
    var keyword = ViewBag.Keyword as string ?? "";
}

<div class="page-header">
    <div>
        <h2>Quản lý giáo viên</h2>
        <p>@(ViewBag.TotalItems ?? Model?.Count() ?? 0) các giảng viên thuộc tất cả các khoa</p>
    </div>
    <div class="page-actions">
        <form id="teacherSearchForm" method="get" data-page-size="@(ViewBag.PageSize ?? 10)" style="display:flex;gap:8px;align-items:center;">
            <input id="teacherSearchInput" class="form-control" type="text" name="keyword" value="@keyword" placeholder="Tìm giáo viên..." style="width:240px;" />
            <button class="btn-outline" type="submit"><i class="fas fa-filter"></i></button>
        </form>
        @if (isAdmin)
        {
            <button class="btn-primary" onclick="document.getElementById('addModal').style.display='flex'">
                <i class="fas fa-plus"></i> Thêm giáo viên
            </button>
        }
    </div>
</div>

<div class="stats-grid" style="grid-template-columns:repeat(3,1fr);margin-bottom:24px;">
    <div class="stat-card blue">
        <div class="stat-card-header"><div class="stat-icon blue"><i class="fas fa-chalkboard-teacher"></i></div><span class="stat-badge blue">Hoạt động</span></div>
        <div class="stat-label">Tổng số giảng viên</div>
        <div class="stat-value">@(ViewBag.TotalItems ?? Model?.Count() ?? 0)</div>
    </div>
    <div class="stat-card teal">
        <div class="stat-card-header"><div class="stat-icon teal"><i class="fas fa-user-check"></i></div></div>
        <div class="stat-label">Hoạt động ngay bây giờ</div>
        <div class="stat-value">32</div>
    </div>
    <div class="stat-card orange">
        <div class="stat-card-header"><div class="stat-icon orange"><i class="fas fa-clipboard-list"></i></div></div>
        <div class="stat-label">Đánh giá đang chờ</div>
        <div class="stat-value">07</div>
    </div>
</div>

<div class="card-plain" style="padding:0;">
    <div class="card-header-plain">
        <h5>Hồ sơ giảng viên</h5>
        <a href="/Admin/GiaoVien" class="small" style="color:var(--primary);font-weight:700;text-decoration:none;">View All</a>
    </div>
    <table class="data-table">
        <thead>
            <tr>
                <th>Giáo viên</th>
                <th>Chuyên môn</th>
                <th>Điện thoại</th>
                <th>Lớp học</th>
                <th>Trạng thái</th>
                <th style="text-align:right;">Hành động</th>
            </tr>
        </thead>
        <tbody id="teacherTableBody">
            @if (Model != null && Model.Any())
            {
                @foreach (var gv in Model)
                {
                    var name = gv.Ten ?? gv.MaGv;
                    var initials = string.Join("", name.Split(' ').Take(2).Select(w => w.FirstOrDefault().ToString().ToUpper()));
                    <tr>
                        <td>
                            <div class="user-row">
                                <div class="avatar">@initials</div>
                                <div>
                                    <div class="user-name">@name</div>
                                    <div class="user-sub">@gv.MaGv</div>
                                </div>
                            </div>
                        </td>
                        <td>@(gv.ChuyenMon ?? "—")</td>
                        <td class="user-sub">@(gv.Sdt ?? "—")</td>
                        <td><span class="chip chip-blue">@gv.LopHocs.Count lớp</span></td>
                        <td><span class="chip chip-green">Hoạt động</span></td>
                        <td style="text-align:right;">
                            <div style="display:flex;gap:4px;justify-content:flex-end;">
                                <a href="/Admin/TeacherDetail/@gv.MaGv" class="btn-icon btn-outline btn-sm"><i class="fas fa-eye"></i></a>
                                @if (isAdmin)
                                {
                                    <button class="btn-icon btn-outline btn-sm"
                                            data-id="@gv.MaGv"
                                            data-ten="@gv.Ten"
                                            data-sdt="@gv.Sdt"
                                            data-chuyenmon="@gv.ChuyenMon"
                                            data-gioitinh="@gv.GioiTinh"
                                            onclick="openEditTeacher(this)">
                                        <i class="fas fa-edit"></i>
                                    </button>
                                    <button class="btn-icon btn-outline btn-sm" onclick="deleteTeacher('@gv.MaGv')">
                                        <i class="fas fa-trash" style="color:#ef4444;"></i>
                                    </button>
                                }
                            </div>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr><td colspan="6"><div class="empty-state"><i class="fas fa-chalkboard-teacher"></i><p>Không tìm thấy giáo viên nào</p></div></td></tr>
            }
        </tbody>
    </table>
    <div class="pagination-bar">
        <span class="pagination-info">Page @currentPage / @totalPages</span>
        <div class="pagination-btns">
            <a class="page-btn" href="/Admin/GiaoVien?page=@(currentPage > 1 ? currentPage - 1 : 1)&pageSize=@(ViewBag.PageSize ?? 10)&keyword=@keyword"><i class="fas fa-chevron-left" style="font-size:10px;"></i></a>
            @for (var i = 1; i <= totalPages; i++)
            {
                if (i == currentPage)
                {
                    <button class="page-btn active">@i</button>
                }
                else
                {
                    <a class="page-btn" href="/Admin/GiaoVien?page=@i&pageSize=@(ViewBag.PageSize ?? 10)&keyword=@keyword">@i</a>
                }
            }
            <a class="page-btn" href="/Admin/GiaoVien?page=@(currentPage < totalPages ? currentPage + 1 : totalPages)&pageSize=@(ViewBag.PageSize ?? 10)&keyword=@keyword"><i class="fas fa-chevron-right" style="font-size:10px;"></i></a>
        </div>
    </div>
</div>

@if (isAdmin)
{
    <div id="addModal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.4);z-index:2000;align-items:center;justify-content:center;">
        <div style="background:white;border-radius:12px;padding:32px;width:480px;max-width:90vw;">
            <h4 style="margin-bottom:24px;">Thêm Giáo Viên Mới</h4>
            <form method="post" action="/Admin/AddGiaoVien">
                @Html.AntiForgeryToken()
                <div class="form-group">
                    <label class="form-label">Họ và Tên</label>
                    <input type="text" name="Ten" class="form-control" required>
                </div>
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;">
                    <div class="form-group">
                        <label class="form-label">Chuyên Môn</label>
                        <input type="text" name="ChuyenMon" class="form-control">
                    </div>
                    <div class="form-group">
                        <label class="form-label">Điện thoại</label>
                        <input type="text" name="Sdt" class="form-control">
                    </div>
                </div>
                <div style="display:flex;gap:12px;justify-content:flex-end;margin-top:24px;">
                    <button type="button" class="btn-outline" onclick="document.getElementById('addModal').style.display='none'">Hủy</button>
                    <button type="submit" class="btn-primary">Thêm Giáo Viên</button>
                </div>
            </form>
        </div>
    </div>

    <div id="editModal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.4);z-index:2000;align-items:center;justify-content:center;">
        <div style="background:white;border-radius:12px;padding:32px;width:480px;max-width:90vw;">
            <h4 style="margin-bottom:24px;">Chỉnh sửa Giáo Viên</h4>
            <form method="post" action="/Admin/UpdateGiaoVien">
                @Html.AntiForgeryToken()
                <input type="hidden" id="editMaGv" name="MaGv" />
                <div class="form-group">
                    <label class="form-label">Họ và Tên</label>
                    <input type="text" id="editTen" name="Ten" class="form-control" required>
                </div>
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;">
                    <div class="form-group">
                        <label class="form-label">Chuyên Môn</label>
                        <input type="text" id="editChuyenMon" name="ChuyenMon" class="form-control">
                    </div>
                    <div class="form-group">
                        <label class="form-label">Điện thoại</label>
                        <input type="text" id="editSdt" name="Sdt" class="form-control">
                    </div>
                </div>
                <div class="form-group">
                    <label class="form-label">Giới tính</label>
                    <input type="text" id="editGioiTinh" name="GioiTinh" class="form-control">
                </div>
                <div style="display:flex;gap:12px;justify-content:flex-end;margin-top:24px;">
                    <button type="button" class="btn-outline" onclick="document.getElementById('editModal').style.display='none'">Hủy</button>
                    <button type="submit" class="btn-primary">Lưu thay đổi</button>
                </div>
            </form>
        </div>
    </div>
}

@section Scripts {
<script>
let teacherAjaxSearchTimer;
const teacherTableBody = document.getElementById('teacherTableBody');
const teacherSearchForm = document.getElementById('teacherSearchForm');
const teacherSearchInput = document.getElementById('teacherSearchInput');

const escapeHtml = window.appEscapeHtml || function (value) {
    return String(value ?? '')
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#39;');
};

function buildTeacherRow(teacher) {
    const name = teacher.ten || teacher.maGv;
    const initials = name
        .split(' ')
        .slice(0, 2)
        .map(w => (w || '').charAt(0).toUpperCase())
        .join('');
    const safeId = escapeHtml(teacher.maGv);
    const safeName = escapeHtml(name);
    const safeSpecialization = escapeHtml(teacher.chuyenMon || '—');
    const safePhone = escapeHtml(teacher.sdt || '—');
    const safeGender = escapeHtml(teacher.gioiTinh || '—');

    return `
        <tr>
            <td>
                <div class="user-row">
                    <div class="avatar">${escapeHtml(initials)}</div>
                    <div>
                        <div class="user-name">${safeName}</div>
                        <div class="user-sub">${safeId}</div>
                    </div>
                </div>
            </td>
            <td>${safeSpecialization}</td>
            <td class="user-sub">${safePhone}</td>
            <td><span class="chip chip-blue">—</span></td>
            <td><span class="chip chip-green">Đang hoạt động</span></td>
            <td style="text-align:right;">
                <div style="display:flex;gap:4px;justify-content:flex-end;">
                    <a href="/Admin/TeacherDetail/${encodeURIComponent(teacher.maGv)}" class="btn-icon btn-outline btn-sm"><i class="fas fa-eye"></i></a>
                    <button class="btn-icon btn-outline btn-sm"
                            data-id="${safeId}"
                            data-ten="${safeName}"
                            data-sdt="${safePhone}"
                            data-chuyenmon="${safeSpecialization}"
                            data-gioitinh="${safeGender}"
                            onclick="openEditTeacher(this)">
                        <i class="fas fa-edit"></i>
                    </button>
                    <button class="btn-icon btn-outline btn-sm" onclick="deleteTeacher('${safeId}')">
                        <i class="fas fa-trash" style="color:#ef4444;"></i>
                    </button>
                </div>
            </td>
        </tr>`;
}

function renderTeacherEmptyState() {
    if (!teacherTableBody) {
        return;
    }

    teacherTableBody.innerHTML = '<tr><td colspan="6"><div class="empty-state"><i class="fas fa-chalkboard-teacher"></i><p>Không tìm thấy giáo viên nào</p></div></td></tr>';
}

async function runTeacherAjaxSearch(keyword) {
    if (!teacherTableBody || !teacherSearchForm) {
        return;
    }

    const pageSize = Number(teacherSearchForm.dataset.pageSize || 10);
    const endpoint = `/api/teachers?keyword=${encodeURIComponent(keyword || '')}&page=1&pageSize=${pageSize}`;

    try {
        const response = await fetch(endpoint, {
            headers: {
                'X-Requested-With': 'XMLHttpRequest'
            }
        });

        if (!response.ok) {
            return;
        }

        const data = await response.json();
        if (!data.items || data.items.length === 0) {
            renderTeacherEmptyState();
            return;
        }

        teacherTableBody.innerHTML = data.items.map(buildTeacherRow).join('');
    } catch {
        // Keep server-rendered content when API fails.
    }
}

if (teacherSearchForm) {
    teacherSearchForm.addEventListener('submit', function (event) {
        event.preventDefault();
        runTeacherAjaxSearch(teacherSearchInput ? teacherSearchInput.value : '');
    });
}

if (teacherSearchInput) {
    teacherSearchInput.addEventListener('input', function (event) {
        clearTimeout(teacherAjaxSearchTimer);
        const keyword = event.target.value || '';
        teacherAjaxSearchTimer = setTimeout(() => runTeacherAjaxSearch(keyword), 300);
    });
}

function deleteTeacher(id) {
    if (confirm('Delete teacher ' + id + '?')) location.href = '/Admin/DeleteGiaoVien/' + id;
}

function openEditTeacher(btn) {
    document.getElementById('editMaGv').value = btn.dataset.id || '';
    document.getElementById('editTen').value = btn.dataset.ten || '';
    document.getElementById('editSdt').value = btn.dataset.sdt || '';
    document.getElementById('editChuyenMon').value = btn.dataset.chuyenmon || '';
    document.getElementById('editGioiTinh').value = btn.dataset.gioitinh || '';
    document.getElementById('editModal').style.display = 'flex';
}
</script>
}
