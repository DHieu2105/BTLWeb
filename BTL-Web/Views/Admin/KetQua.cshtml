@model IEnumerable<BTL_Web.Models.KetQua>
@{
    ViewData["Title"] = "Manage Results";
    int page = ViewBag.Page ?? 1;
    int totalPages = ViewBag.TotalPages ?? 1;
    int pageSize = ViewBag.PageSize ?? 10;
    int totalItems = ViewBag.TotalItems ?? (Model?.Count() ?? 0);

    int startPage = Math.Max(1, page - 1);
    int endPage = Math.Min(totalPages, startPage + 2);
    startPage = Math.Max(1, endPage - 2);

    var avgScore = Model?.Any() == true ? Model.Average(k => k.DiemTong ?? 0) : 0;
    var passRate = Model?.Any() == true ? (double)Model.Count(k => (k.DiemTong ?? 0) >= 60) / Model.Count() * 100 : 0;
}

<div class="page-header">
    <div>
        <h2>Manage Results</h2>
        <p>Student assessment results and performance tracking (view only)</p>
    </div>
    <div class="page-actions">
        <button class="btn-outline"><i class="fas fa-download"></i> Export</button>
    </div>
</div>

<div class="stats-grid" style="grid-template-columns:repeat(3,1fr);margin-bottom:24px;">
    <div class="stat-card blue">
        <div class="stat-card-header"><div class="stat-icon blue"><i class="fas fa-percentage"></i></div><span class="stat-badge blue">↑</span></div>
        <div class="stat-label">Pass Rate</div>
        <div class="stat-value">@passRate.ToString("F0")%</div>
    </div>
    <div class="stat-card teal">
        <div class="stat-card-header"><div class="stat-icon teal"><i class="fas fa-star"></i></div></div>
        <div class="stat-label">Avg. Score</div>
        <div class="stat-value">@avgScore.ToString("F1")</div>
    </div>
    <div class="stat-card highlighted" style="background:var(--sidebar-bg);">
        <div class="stat-card-header"><div class="stat-icon white"><i class="fas fa-trophy"></i></div></div>
        <div class="stat-label" style="color:rgba(255,255,255,0.7);">Total Records</div>
        <div class="stat-value" style="color:white;">@totalItems</div>
    </div>
</div>

<div class="card-plain" style="padding:0;">
    <div class="card-header-plain">
        <h5>Assessment Results</h5>
        <form method="get" action="/Admin/KetQua" style="display:flex;gap:8px;align-items:center;">
            <label style="font-size:14px;color:rgba(0,0,0,0.6);">Score Range:</label>
            <input type="number" name="minScore" class="form-control" placeholder="Min" value="@(ViewBag.MinScore ?? "")" style="width:80px;">
            <span style="color:rgba(0,0,0,0.4);">-</span>
            <input type="number" name="maxScore" class="form-control" placeholder="Max" value="@(ViewBag.MaxScore ?? "")" style="width:80px;">
            <button type="submit" class="btn-outline btn-sm"><i class="fas fa-search"></i> Filter</button>
            @if (ViewBag.MinScore != null || ViewBag.MaxScore != null)
            {
                <a href="/Admin/KetQua" class="btn-outline btn-sm"><i class="fas fa-times"></i> Clear</a>
            }
        </form>
    </div>
    <table class="data-table">
        <thead>
            <tr>
                <th>Student</th>
                <th>Course</th>
                <th>Listening</th>
                <th>Reading</th>
                <th>Total</th>
                <th>Status</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                @foreach (var kq in Model)
                {
                    var total = kq.DiemTong ?? 0;
                    var chipClass = total >= 70 ? "chip-green" : total >= 60 ? "chip-yellow" : "chip-red";
                    var name = kq.MaHocVienNavigation?.HoVaTen ?? kq.MaHocVien;
                    var initials = string.Join("", name.Split(' ').Take(2).Select(w => w.FirstOrDefault().ToString().ToUpper()));
                    <tr>
                        <td>
                            <div class="user-row">
                                <div class="avatar">@initials</div>
                                <div>
                                    <div class="user-name">@name</div>
                                    <div class="user-sub">@kq.MaHocVien</div>
                                </div>
                            </div>
                        </td>
                        <td>
                            <div class="user-name">@(kq.MaKhoaHocNavigation?.TenKhoaHoc ?? kq.MaKhoaHoc)</div>
                        </td>
                        <td><span style="font-size:16px;font-weight:700;">@(kq.DiemListening ?? 0)</span></td>
                        <td><span style="font-size:16px;font-weight:700;">@(kq.DiemReading ?? 0)</span></td>
                        <td>
                            <span style="font-size:20px;font-weight:800;color:var(--primary);">@total</span>
                            <div class="progress-bar-wrap" style="width:60px;margin-top:4px;">
                                <div class="progress-bar-fill" style="width:@(Math.Min(total, 100))%;"></div>
                            </div>
                        </td>
                        <td><span class="chip @chipClass">@(total >= 60 ? "Passed" : "Failed")</span></td>
                    </tr>
                }
            }
            else
            {
                <tr><td colspan="6"><div class="empty-state"><i class="fas fa-poll-h"></i><p>No results found</p></div></td></tr>
            }
        </tbody>
    </table>
    <div class="pagination-bar">
        <span class="pagination-info">Showing @(Model?.Count() ?? 0) / @totalItems results</span>
        <div class="pagination-btns">
            <a class="page-btn" href="/Admin/KetQua?page=@Math.Max(1, page - 1)&pageSize=@pageSize&minScore=@(ViewBag.MinScore ?? "")&maxScore=@(ViewBag.MaxScore ?? "")"><i class="fas fa-chevron-left" style="font-size:10px;"></i></a>
            @for (int p = startPage; p <= endPage; p++)
            {
                if (p == page)
                {
                    <span class="page-btn active">@p</span>
                }
                else
                {
                    <a class="page-btn" href="/Admin/KetQua?page=@p&pageSize=@pageSize&minScore=@(ViewBag.MinScore ?? "")&maxScore=@(ViewBag.MaxScore ?? "")">@p</a>
                }
            }
            <a class="page-btn" href="/Admin/KetQua?page=@Math.Min(totalPages, page + 1)&pageSize=@pageSize&minScore=@(ViewBag.MinScore ?? "")&maxScore=@(ViewBag.MaxScore ?? "")"><i class="fas fa-chevron-right" style="font-size:10px;"></i></a>
        </div>
    </div>
</div>
