@model IEnumerable<BTL_Web.Models.HocVien>
@{
    ViewData["Title"] = "Manage Students";
    int page = ViewBag.Page ?? 1;
    int totalPages = ViewBag.TotalPages ?? 1;
    int pageSize = ViewBag.PageSize ?? 10;
    int totalItems = ViewBag.TotalItems ?? (Model?.Count() ?? 0);

    int startPage = Math.Max(1, page - 1);
    int endPage = Math.Min(totalPages, startPage + 2);
    startPage = Math.Max(1, endPage - 2);
}

<div class="page-header">
    <div>
        <h2>Manage Students</h2>
        <p>@(Model?.Count() ?? 0) students enrolled across all programs</p>
    </div>
    <div class="page-actions">
        <form method="get" action="/Admin/HocVien" style="display:flex;gap:8px;align-items:center;">
            <input type="text" name="searchStudent" class="form-control" placeholder="Search by name or ID" value="@(ViewBag.SearchStudent ?? "")" style="width:240px;">
            <button type="submit" class="btn-outline"><i class="fas fa-search"></i> Search</button>
            @if (!string.IsNullOrWhiteSpace(ViewBag.SearchStudent))
            {
                <a href="/Admin/HocVien" class="btn-outline"><i class="fas fa-times"></i> Clear</a>
            }
        </form>
        <button class="btn-primary" onclick="document.getElementById('addModal').style.display='flex'">
            <i class="fas fa-plus"></i> Add Student
        </button>
    </div>
</div>

<div class="stats-grid" style="grid-template-columns:repeat(3,1fr);margin-bottom:24px;">
    <div class="stat-card blue">
        <div class="stat-card-header"><div class="stat-icon blue"><i class="fas fa-users"></i></div><span class="stat-badge blue">+8%</span></div>
        <div class="stat-label">Total Students</div>
        <div class="stat-value">@(Model?.Count() ?? 0)</div>
    </div>
    <div class="stat-card orange">
        <div class="stat-card-header"><div class="stat-icon orange"><i class="fas fa-user-clock"></i></div></div>
        <div class="stat-label">Active Trials</div>
        <div class="stat-value">42</div>
    </div>
    <div class="stat-card teal">
        <div class="stat-card-header"><div class="stat-icon teal"><i class="fas fa-dollar-sign"></i></div></div>
        <div class="stat-label">Pending Payments</div>
        <div class="stat-value">$42,900</div>
    </div>
</div>

<div class="card-plain" style="padding:0;">
    <div class="card-header-plain">
        <h5>Student Records</h5>
        <div style="display:flex;gap:8px;">
            <button class="btn-outline btn-sm"><i class="fas fa-filter"></i> Filter</button>
            <button class="btn-icon btn-outline"><i class="fas fa-ellipsis-v"></i></button>
        </div>
    </div>
    <table class="data-table">
        <thead>
            <tr>
                <th>Student</th>
                <th>Student ID</th>
                <th>Enrolled Course</th>
                <th>Phone</th>
                <th style="text-align:right;">Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                @foreach (var sv in Model)
                {
                    var name = sv.HoVaTen ?? sv.MaHocVien;
                    var initials = string.Join("", name.Split(' ').Take(2).Select(w => w.FirstOrDefault().ToString().ToUpper()));
                    <tr>
                        <td>
                            <div class="user-row">
                                <div class="avatar">@initials</div>
                                <div>
                                    <div class="user-name">@name</div>
                                    <div class="user-sub">@sv.GioiTinh</div>
                                </div>
                            </div>
                        </td>
                        <td><span class="chip chip-blue">@sv.MaHocVien</span></td>
                        <td>@(sv.DangKis?.FirstOrDefault()?.MaKhoaHocNavigation?.TenKhoaHoc ?? "—")</td>
                        <td class="user-sub">@(sv.Sdt ?? "—")</td>
                        <td style="text-align:right;">
                            <div style="display:flex;gap:4px;justify-content:flex-end;">
                                <a href="/Admin/StudentDetail/@sv.MaHocVien" class="btn-icon btn-outline btn-sm"><i class="fas fa-eye"></i></a>
                                <button class="btn-icon btn-outline btn-sm" onclick="openEditStudent('@sv.MaHocVien','@Html.Raw((sv.HoVaTen ?? "").Replace("'", "\\'"))','@Html.Raw((sv.Sdt ?? "").Replace("'", "\\'"))','@sv.GioiTinh')">
                                    <i class="fas fa-pen"></i>
                                </button>
                                <button class="btn-icon btn-outline btn-sm" onclick="deleteStudent('@sv.MaHocVien')">
                                    <i class="fas fa-trash" style="color:#ef4444;"></i>
                                </button>
                            </div>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr><td colspan="5"><div class="empty-state"><i class="fas fa-user-graduate"></i><p>No students found</p></div></td></tr>
            }
        </tbody>
    </table>
    <div class="pagination-bar">
        <span class="pagination-info">Showing @(Model?.Count() ?? 0) / @totalItems records</span>
        <div class="pagination-btns">
            <a class="page-btn" href="/Admin/HocVien?page=@Math.Max(1, page - 1)&pageSize=@pageSize&searchStudent=@(ViewBag.SearchStudent ?? "")"><i class="fas fa-chevron-left" style="font-size:10px;"></i></a>
            @for (int p = startPage; p <= endPage; p++)
            {
                if (p == page)
                {
                    <span class="page-btn active">@p</span>
                }
                else
                {
                    <a class="page-btn" href="/Admin/HocVien?page=@p&pageSize=@pageSize&searchStudent=@(ViewBag.SearchStudent ?? "")">@p</a>
                }
            }
            <a class="page-btn" href="/Admin/HocVien?page=@Math.Min(totalPages, page + 1)&pageSize=@pageSize&searchStudent=@(ViewBag.SearchStudent ?? "")"><i class="fas fa-chevron-right" style="font-size:10px;"></i></a>
        </div>
    </div>
</div>

<div id="addModal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.4);z-index:2000;align-items:center;justify-content:center;">
    <div style="background:white;border-radius:12px;padding:32px;width:480px;max-width:90vw;">
        <h4 style="margin-bottom:24px;">Add New Student</h4>
        <form method="post" action="/Admin/AddHocVien">
            @Html.AntiForgeryToken()
            <div class="form-group">
                <label class="form-label">Student ID</label>
                <input type="text" class="form-control" value="Auto-generated by system (HV000001, HV000002...)" readonly>
            </div>
            <div class="form-group">
                <label class="form-label">Full Name</label>
                <input type="text" name="HoVaTen" class="form-control" placeholder="Enter full name" required>
            </div>
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;">
                <div class="form-group">
                    <label class="form-label">Phone</label>
                    <input type="text" name="Sdt" class="form-control" placeholder="+84...">
                </div>
                <div class="form-group">
                    <label class="form-label">Gender</label>
                    <select name="GioiTinh" class="form-control form-select">
                        <option value="Nam">Nam</option>
                        <option value="Nu">Nữ</option>
                    </select>
                </div>
            </div>
            <div style="display:flex;gap:12px;justify-content:flex-end;margin-top:24px;">
                <button type="button" class="btn-outline" onclick="document.getElementById('addModal').style.display='none'">Cancel</button>
                <button type="submit" class="btn-primary">Add Student</button>
            </div>
        </form>
    </div>
</div>

<div id="editModal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.4);z-index:2000;align-items:center;justify-content:center;">
    <div style="background:white;border-radius:12px;padding:32px;width:480px;max-width:90vw;">
        <h4 style="margin-bottom:24px;">Edit Student</h4>
        <form method="post" action="/Admin/EditHocVien">
            @Html.AntiForgeryToken()
            <input type="hidden" name="MaHocVien" id="editMaHocVien">
            <div class="form-group">
                <label class="form-label">Student ID</label>
                <input type="text" id="editMaHocVienReadonly" class="form-control" readonly>
            </div>
            <div class="form-group">
                <label class="form-label">Full Name</label>
                <input type="text" name="HoVaTen" id="editHoVaTen" class="form-control" required>
            </div>
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;">
                <div class="form-group">
                    <label class="form-label">Phone</label>
                    <input type="text" name="Sdt" id="editSdt" class="form-control">
                </div>
                <div class="form-group">
                    <label class="form-label">Gender</label>
                    <select name="GioiTinh" id="editGioiTinh" class="form-control form-select">
                        <option value="Nam">Nam</option>
                        <option value="Nu">Nữ</option>
                    </select>
                </div>
            </div>
            <div style="display:flex;gap:12px;justify-content:flex-end;margin-top:24px;">
                <button type="button" class="btn-outline" onclick="document.getElementById('editModal').style.display='none'">Cancel</button>
                <button type="submit" class="btn-primary">Save Changes</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
<script>
function openEditStudent(id, name, phone, gender) {
    document.getElementById('editMaHocVien').value = id;
    document.getElementById('editMaHocVienReadonly').value = id;
    document.getElementById('editHoVaTen').value = name || '';
    document.getElementById('editSdt').value = phone || '';
    document.getElementById('editGioiTinh').value = gender || 'Nam';
    document.getElementById('editModal').style.display = 'flex';
}
function deleteStudent(id) {
    if (confirm('Delete student ' + id + '?')) location.href = '/Admin/DeleteHocVien/' + id;
}
</script>
}
