@{
    ViewData["Title"] = "Phân công thiết bị phòng";
    var phongHocs = ViewBag.PhongHocs as IEnumerable<BTL_Web.Models.PhongHoc> ?? new List<BTL_Web.Models.PhongHoc>();
    var thietBis  = ViewBag.ThietBis  as IEnumerable<BTL_Web.Models.ThietBi>  ?? new List<BTL_Web.Models.ThietBi>();
}

<div class="page-header">
    <div>
        <h2>Phân công thiết bị phòng</h2>
        <p>Phân công và quản lý thiết bị cho tất cả phòng học</p>
    </div>
    <div class="page-actions">
        <button type="button" class="btn-outline" title="Lọc" onclick="toggleEquipFilter()"><i class="fas fa-filter"></i></button>
        <button class="btn-primary" onclick="document.getElementById('assignModal').style.display='flex'">
            <i class="fas fa-plus"></i> Gán thiết bị
        </button>
    </div>
</div>

<div id="equipFilterPanel" class="card-plain" style="display:none;padding:16px 20px;margin-bottom:16px;">
    <div style="display:grid;grid-template-columns:1fr auto;gap:10px;align-items:end;">
        <div class="form-group" style="margin:0;">
            <label class="form-label">Tìm thiết bị hoặc phòng</label>
            <input id="equipFilterInput" type="text" class="form-control" placeholder="Tên/mã thiết bị hoặc phòng" oninput="applyEquipFilter()" />
        </div>
        <button type="button" class="btn-outline" onclick="clearEquipFilter()">Xóa lọc</button>
    </div>
</div>

<!-- Stats -->
<div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:16px;margin-bottom:24px;">
    <div class="card-plain" style="padding:20px;border-left:4px solid var(--primary);">
        <div class="stat-label">Tổng thiết bị</div>
        <div class="stat-value">@thietBis.Count()</div>
        <div class="smaller text-muted" style="margin-top:4px;">Tỷ lệ sử dụng 92%</div>
    </div>
    <div class="card-plain" style="padding:20px;border-left:4px solid #0891b2;">
        <div class="stat-label">Tổng phòng</div>
        <div class="stat-value">@phongHocs.Count()</div>
    </div>
    <div class="card-plain" style="padding:20px;border-left:4px solid #f97316;">
        <div class="stat-label">Thiết bị chưa gán</div>
        <div class="stat-value" style="color:#f97316;">@thietBis.Count(t => !t.MaPhongs.Any())</div>
    </div>
</div>

<div style="display:grid;grid-template-columns:1fr 2fr;gap:24px;">
    <!-- Room Selector -->
    <div class="card-plain" style="padding:0;">
        <div class="card-header-plain"><h5>Phòng học</h5></div>
        <div style="padding:16px;display:flex;flex-direction:column;gap:8px;">
            @foreach (var ph in phongHocs)
            {
                var equipCount = ph.MaThietBis.Count;
                 <div class="room-card" onclick="selectRoom('@ph.MaPhong','@ph.TenPhong')"
                     id="room-@ph.MaPhong"
                     style="padding:16px;border-radius:8px;cursor:pointer;border:2px solid var(--surface-high);transition:all 0.15s;"
                     onmouseover="this.style.borderColor='var(--primary)'" onmouseout="this.style.borderColor='var(--surface-high)'">
                    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:8px;">
                        <div class="user-name">@ph.TenPhong</div>
                        <span class="chip chip-blue" style="font-size:10px;">@equipCount thiết bị</span>
                    </div>
                    <div class="user-sub">@ph.MaPhong</div>
                    <div class="progress-bar-wrap" style="margin-top:8px;">
                        <div class="progress-bar-fill" style="width:@(Math.Min(equipCount * 25, 100))%;"></div>
                    </div>
                </div>
            }
            @if (!phongHocs.Any())
            {
                <div class="empty-state"><i class="fas fa-door-open"></i><p>Không tìm thấy phòng nào</p></div>
            }
        </div>
    </div>

    <!-- Equipment Assignment Canvas -->
    <div style="display:flex;flex-direction:column;gap:16px;">
        <!-- Selected Room Info -->
        <div class="card-plain" style="padding:24px;" id="roomInfoCard">
            <div style="display:flex;align-items:center;gap:12px;margin-bottom:16px;">
                <div class="stat-icon blue" style="width:48px;height:48px;border-radius:12px;flex-shrink:0;"><i class="fas fa-door-open"></i></div>
                <div>
                    <div class="user-name" id="selectedRoomName">Chọn một phòng để quản lý thiết bị</div>
                    <div class="user-sub" id="selectedRoomId">Bấm vào một phòng bên trái</div>
                </div>
            </div>
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
                <div style="padding:12px;background:var(--surface-low);border-radius:8px;">
                    <div class="stat-label">Thiết bị hình ảnh</div>
                    <div style="display:flex;flex-direction:column;gap:8px;margin-top:8px;">
                        @foreach (var tb in thietBis.Where(t => t.MaPhongs.Any()).Take(2))
                        {
                            <div style="display:flex;align-items:center;gap:8px;padding:8px;background:white;border-radius:6px;">
                                <i class="fas fa-tv" style="color:var(--primary);"></i>
                                <div>
                                    <div class="user-name" style="font-size:12px;">@tb.TenThietBi</div>
                                    <div class="user-sub">@tb.MaThietBi</div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
                <div style="padding:12px;background:var(--surface-low);border-radius:8px;">
                    <div class="stat-label">Thiết bị âm thanh</div>
                    <div style="display:flex;flex-direction:column;gap:8px;margin-top:8px;">
                        @foreach (var tb in thietBis.Skip(2).Take(2))
                        {
                            <div style="display:flex;align-items:center;gap:8px;padding:8px;background:white;border-radius:6px;">
                                <i class="fas fa-microphone" style="color:#0891b2;"></i>
                                <div>
                                    <div class="user-name" style="font-size:12px;">@tb.TenThietBi</div>
                                    <div class="user-sub">@tb.MaThietBi</div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- Equipment Table -->
        <div class="card-plain" style="padding:0;">
            <div class="card-header-plain">
                <h5>Danh sách thiết bị</h5>
                <div style="display:flex;gap:8px;align-items:center;">
                    <span class="chip chip-green">Đang hoạt động</span>
                    <span class="chip chip-yellow">Bảo trì</span>
                </div>
            </div>
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Thiết bị</th>
                        <th>Phòng đã gán</th>
                        <th>Số lượng</th>
                        <th>Trạng thái</th>
                        <th style="text-align:right;">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var tb in thietBis)
                    {
                        <tr class="equip-row">
                            <td>
                                <div style="display:flex;align-items:center;gap:10px;">
                                    <div class="avatar avatar-sm" style="background:rgba(219,225,255,0.3);color:var(--primary);">
                                        <i class="fas fa-laptop" style="font-size:12px;"></i>
                                    </div>
                                    <div>
                                        <div class="user-name">@tb.TenThietBi</div>
                                        <div class="user-sub">@tb.MaThietBi</div>
                                    </div>
                                </div>
                            </td>
                            <td>
                                @if (tb.MaPhongs.Any())
                                {
                                    @foreach (var ph in tb.MaPhongs.Take(2))
                                    {
                                        <span class="chip chip-blue" style="font-size:11px;margin-right:4px;">@ph.TenPhong</span>
                                    }
                                }
                                else
                                {
                                    <span class="chip chip-gray" style="font-size:11px;">Chưa gán</span>
                                }
                            </td>
                            <td class="user-name">@(tb.SoLuong ?? 1)</td>
                            <td><span class="chip chip-green">Đang hoạt động</span></td>
                            <td style="text-align:right;">
                                <button class="btn-outline btn-sm" onclick="assignEquip('@tb.MaThietBi')">
                                    <i class="fas fa-link"></i> Gán
                                </button>
                            </td>
                        </tr>
                    }
                    @if (!thietBis.Any())
                    {
                        <tr><td colspan="5"><div class="empty-state"><i class="fas fa-laptop"></i><p>Không tìm thấy thiết bị nào</p></div></td></tr>
                    }
                    <tr id="equipFilterEmptyRow" style="display:none;"><td colspan="5"><div class="empty-state"><i class="fas fa-filter"></i><p>Không có thiết bị nào phù hợp với bộ lọc hiện tại</p></div></td></tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Assign Modal -->
<div id="assignModal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.4);z-index:2000;align-items:center;justify-content:center;">
    <div style="background:white;border-radius:12px;padding:32px;width:480px;max-width:90vw;">
        <h4 style="margin-bottom:24px;">Gán thiết bị vào phòng</h4>
        <form method="post" action="/Admin/AssignEquipmentToRoom">
            @Html.AntiForgeryToken()
            <div class="form-group">
                <label class="form-label">Thiết bị</label>
                <select name="MaThietBi" id="equipSelect" class="form-control form-select">
                    <option value="">— Chọn thiết bị —</option>
                    @foreach (var tb in thietBis)
                    {
                        <option value="@tb.MaThietBi">@tb.TenThietBi (@tb.MaThietBi)</option>
                    }
                </select>
            </div>
            <div class="form-group">
                <label class="form-label">Phòng</label>
                <select name="MaPhong" class="form-control form-select">
                    <option value="">— Chọn phòng —</option>
                    @foreach (var ph in phongHocs)
                    {
                        <option value="@ph.MaPhong">@ph.TenPhong</option>
                    }
                </select>
            </div>
            <div style="display:flex;gap:12px;justify-content:flex-end;margin-top:24px;">
                <button type="button" class="btn-outline" onclick="document.getElementById('assignModal').style.display='none'">Hủy</button>
                <button type="submit" class="btn-primary"><i class="fas fa-link"></i> Gán</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
<script>
function toggleEquipFilter() {
    const panel = document.getElementById('equipFilterPanel');
    if (!panel) return;
    panel.style.display = panel.style.display === 'none' || panel.style.display === '' ? 'block' : 'none';
}

function applyEquipFilter() {
    const query = (document.getElementById('equipFilterInput')?.value || '').trim().toLowerCase();

    document.querySelectorAll('.room-card').forEach(card => {
        const text = (card.textContent || '').toLowerCase();
        card.style.display = !query || text.includes(query) ? '' : 'none';
    });

    const rows = document.querySelectorAll('.equip-row');
    let visible = 0;
    rows.forEach(row => {
        const text = (row.textContent || '').toLowerCase();
        const show = !query || text.includes(query);
        row.style.display = show ? '' : 'none';
        if (show) visible++;
    });

    const emptyRow = document.getElementById('equipFilterEmptyRow');
    if (emptyRow) emptyRow.style.display = visible === 0 ? '' : 'none';
}

function clearEquipFilter() {
    const input = document.getElementById('equipFilterInput');
    if (input) input.value = '';
    applyEquipFilter();
}

function selectRoom(id, name) {
    document.querySelectorAll('[id^="room-"]').forEach(r => r.style.borderColor = 'var(--surface-high)');
    const el = document.getElementById('room-' + id);
    if (el) el.style.borderColor = 'var(--primary)';
    document.getElementById('selectedRoomName').textContent = name;
    document.getElementById('selectedRoomId').textContent = id;
}
function assignEquip(id) {
    document.getElementById('equipSelect').value = id;
    document.getElementById('assignModal').style.display = 'flex';
}
</script>
}
