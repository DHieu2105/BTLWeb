@model BTL_Web.Models.LopHoc
@{
    ViewData["Title"] = "Học viên trong lớp";
    var allStudents = ViewBag.AllStudents as IEnumerable<BTL_Web.Models.HocVien> ?? new List<BTL_Web.Models.HocVien>();
    var allClasses = ViewBag.AllClasses as IEnumerable<BTL_Web.Models.LopHoc> ?? new List<BTL_Web.Models.LopHoc>();
    var enrolledIds = Model?.MaHocViens.Select(h => h.MaHocVien).ToHashSet() ?? new HashSet<string>();
    var available = allStudents.Where(s => !enrolledIds.Contains(s.MaHocVien)).ToList();
}

<div class="page-header">
    <div>
        <a href="/Admin/LopHoc" style="font-size:13px;color:var(--primary);text-decoration:none;display:flex;align-items:center;gap:4px;margin-bottom:8px;">
            <i class="fas fa-arrow-left"></i> Quay lại danh sách lớp
        </a>
        <h2>@(Model?.TenLop ?? "Chi tiết lớp")</h2>
        <p>@(Model?.MaKhoaHocNavigation?.TenKhoaHoc ?? "—") — Giáo viên: @(Model?.MaGvNavigation?.Ten ?? "—")</p>
    </div>
    <div class="page-actions">
        <span class="chip chip-blue">@(Model?.MaHocViens.Count ?? 0) học viên</span>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success" style="margin-bottom:16px;">@TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-error" style="margin-bottom:16px;">@TempData["Error"]</div>
}

<div style="display:grid;grid-template-columns:3fr 2fr;gap:24px;">
    <!-- Enrolled Students -->
    <div class="card-plain" style="padding:0;">
        <div class="card-header-plain">
            <div>
                <h5>Đang ghi danh</h5>
                <p class="small text-muted">@(Model?.MaHocViens.Count ?? 0) học viên trong lớp này</p>
            </div>
            <span class="chip chip-green">@(Model?.MaHocViens.Count ?? 0) / Đang hoạt động</span>
        </div>
        @if (Model?.MaHocViens.Any() == true)
        {
            <div style="padding:16px;display:flex;flex-direction:column;gap:8px;">
                @foreach (var sv in Model.MaHocViens)
                {
                    var name = sv.HoVaTen ?? sv.MaHocVien;
                    var initials = string.Join("", name.Split(' ').Take(2).Select(w => w.FirstOrDefault().ToString().ToUpper()));
                    <div style="display:flex;align-items:center;justify-content:space-between;padding:12px 16px;background:var(--surface-low);border-radius:8px;">
                        <div class="user-row">
                            <div class="avatar">@initials</div>
                            <div>
                                <div class="user-name">@name</div>
                                <div class="user-sub">@sv.MaHocVien</div>
                            </div>
                        </div>
                        <div style="display:flex;gap:8px;align-items:center;">
                            <span class="chip chip-green" style="font-size:11px;">Đã ghi danh</span>
                            <button type="button" class="btn-icon btn-outline btn-sm" title="Chuyển lớp"
                                    onclick="openTransferModal('@sv.MaHocVien', '@Html.Raw(name.Replace("'", "\\'"))')">
                                <i class="fas fa-right-left"></i>
                            </button>
                            <form method="post" action="/Admin/RemoveStudentFromClass" style="margin:0;">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="maLop" value="@Model.MaLop">
                                <input type="hidden" name="maHocVien" value="@sv.MaHocVien">
                                <button type="submit" class="btn-icon btn-outline btn-sm" title="Xóa khỏi lớp">
                                    <i class="fas fa-times" style="color:#ef4444;"></i>
                                </button>
                            </form>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="empty-state"><i class="fas fa-users"></i><p>Chưa có học viên nào ghi danh</p></div>
        }
    </div>

    <!-- Available Students -->
    <div class="card-plain" style="padding:0;">
        <div class="card-header-plain">
            <h5>Học viên khả dụng</h5>
        </div>
        <div style="padding:16px;">
            <div class="search-box" style="margin-bottom:16px;">
                <i class="fas fa-search"></i>
                <input type="text" id="searchStudent" placeholder="Tìm theo tên hoặc mã..." oninput="filterStudents(this.value)">
            </div>
            <div id="studentList" style="display:flex;flex-direction:column;gap:6px;max-height:400px;overflow-y:auto;">
                @foreach (var sv in available)
                {
                    var name = sv.HoVaTen ?? sv.MaHocVien;
                    var initials = string.Join("", name.Split(' ').Take(2).Select(w => w.FirstOrDefault().ToString().ToUpper()));
                    <div class="student-item" data-name="@name.ToLower()" style="display:flex;align-items:center;justify-content:space-between;padding:10px 12px;background:var(--surface-low);border-radius:8px;">
                        <div class="user-row">
                            <div class="avatar avatar-sm">@initials</div>
                            <div>
                                <div class="user-name" style="font-size:13px;">@name</div>
                                <div class="user-sub">@sv.MaHocVien</div>
                            </div>
                        </div>
                        <form method="post" action="/Admin/AddStudentToClass" style="margin:0;">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="maLop" value="@(Model?.MaLop)">
                            <input type="hidden" name="maHocVien" value="@sv.MaHocVien">
                            <button type="submit" class="btn-icon btn-primary btn-sm" title="Thêm">
                                <i class="fas fa-plus"></i>
                            </button>
                        </form>
                    </div>
                }
                @if (!available.Any())
                {
                    <div class="empty-state" style="padding:24px;"><i class="fas fa-check-circle" style="color:#10b981;"></i><p>Tất cả học viên đã ghi danh</p></div>
                }
            </div>
        </div>
    </div>
</div>

<div id="transferModal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.4);z-index:2100;align-items:center;justify-content:center;">
    <div style="background:white;border-radius:12px;padding:28px;width:520px;max-width:92vw;">
        <h4 style="margin-bottom:18px;">Chuyển học viên sang lớp khác</h4>
        <div class="small" id="transferStudentLabel" style="margin-bottom:16px;color:rgba(0,0,0,0.65);"></div>
        <form method="post" action="/Admin/UpdateStudentClass">
            @Html.AntiForgeryToken()
            <input type="hidden" name="oldMaLop" value="@(Model?.MaLop)">
            <input type="hidden" name="maHocVien" id="transferStudentId">
            <div class="form-group">
                <label class="form-label">Lớp đích</label>
                <select name="newMaLop" class="form-control form-select" required>
                    @foreach (var lop in allClasses.Where(c => c.MaLop != Model?.MaLop))
                    {
                        <option value="@lop.MaLop">@(lop.TenLop ?? lop.MaLop) - @(lop.MaKhoaHocNavigation?.TenKhoaHoc ?? lop.MaKhoaHoc)</option>
                    }
                </select>
            </div>
            <div style="display:flex;gap:12px;justify-content:flex-end;margin-top:20px;">
                <button type="button" class="btn-outline" onclick="document.getElementById('transferModal').style.display='none'">Hủy</button>
                <button type="submit" class="btn-primary">Chuyển</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
<script>
function filterStudents(q) {
    document.querySelectorAll('.student-item').forEach(item => {
        item.style.display = item.dataset.name.includes(q.toLowerCase()) ? 'flex' : 'none';
    });
}

function openTransferModal(studentId, studentName) {
    document.getElementById('transferStudentId').value = studentId;
    document.getElementById('transferStudentLabel').textContent = studentName + ' (' + studentId + ')';
    document.getElementById('transferModal').style.display = 'flex';
}
</script>
}
