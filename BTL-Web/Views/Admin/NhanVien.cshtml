@model IEnumerable<BTL_Web.Models.NhanVien>
@{
    ViewData["Title"] = "Manage Staff";
}

<div class="page-header">
    <div>
        <h2>Manage Staff</h2>
        <p>Administrative and support personnel management</p>
    </div>
    <div class="page-actions">
        <button class="btn-outline"><i class="fas fa-filter"></i> Filter</button>
        <button class="btn-primary" onclick="document.getElementById('addModal').style.display='flex'">
            <i class="fas fa-plus"></i> Add Staff
        </button>
    </div>
</div>

<div class="stats-grid" style="grid-template-columns:repeat(4,1fr);margin-bottom:24px;">
    <div class="stat-card blue">
        <div class="stat-card-header"><div class="stat-icon blue"><i class="fas fa-users"></i></div></div>
        <div class="stat-label">Total Personnel</div>
        <div class="stat-value">@(Model?.Count() ?? 0)</div>
    </div>
    <div class="stat-card teal">
        <div class="stat-card-header"><div class="stat-icon teal"><i class="fas fa-user-tie"></i></div></div>
        <div class="stat-label">Active Lecturers</div>
        <div class="stat-value">86</div>
    </div>
    <div class="stat-card orange">
        <div class="stat-card-header"><div class="stat-icon orange"><i class="fas fa-building"></i></div></div>
        <div class="stat-label">Dept. Coverage</div>
        <div class="stat-value">12</div>
    </div>
    <div class="stat-card green">
        <div class="stat-card-header"><div class="stat-icon blue"><i class="fas fa-headset"></i></div></div>
        <div class="stat-label">Support Staff</div>
        <div class="stat-value">38</div>
    </div>
</div>

<div class="card-plain" style="padding:0;">
    <div class="card-header-plain">
        <h5>Staff Directory</h5>
        <div style="display:flex;gap:8px;">
            <button class="filter-btn active">All</button>
            <button class="filter-btn">Lecturers</button>
            <button class="filter-btn">Support</button>
        </div>
    </div>
    <table class="data-table">
        <thead>
            <tr>
                <th>Staff Member</th>
                <th>Position</th>
                <th>Center</th>
                <th>Gender</th>
                <th>Status</th>
                <th style="text-align:right;">Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                @foreach (var nv in Model)
                {
                    var name = nv.HoVaTen ?? nv.MaNv;
                    var initials = string.Join("", name.Split(' ').Take(2).Select(w => w.FirstOrDefault().ToString().ToUpper()));
                    <tr>
                        <td>
                            <div class="user-row">
                                <div class="avatar">@initials</div>
                                <div>
                                    <div class="user-name">@name</div>
                                    <div class="user-sub">@nv.MaNv</div>
                                </div>
                            </div>
                        </td>
                        <td>@(nv.ChucVu ?? "—")</td>
                        <td>@(nv.MaTrungTamNavigation?.TenTrungTam ?? nv.MaTrungTam ?? "—")</td>
                        <td class="user-sub">@(nv.GioiTinh ?? "—")</td>
                        <td><span class="chip chip-green">Active</span></td>
                        <td style="text-align:right;">
                            <button class="btn-icon btn-outline btn-sm"><i class="fas fa-ellipsis-v"></i></button>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr><td colspan="6"><div class="empty-state"><i class="fas fa-users-cog"></i><p>No staff found</p></div></td></tr>
            }
        </tbody>
    </table>
    <div class="pagination-bar">
        <span class="pagination-info">Showing @(Model?.Count() ?? 0) records</span>
        <div class="pagination-btns">
            <button class="page-btn"><i class="fas fa-chevron-left" style="font-size:10px;"></i></button>
            <button class="page-btn active">1</button>
            <button class="page-btn">2</button>
            <button class="page-btn"><i class="fas fa-chevron-right" style="font-size:10px;"></i></button>
        </div>
    </div>
</div>

<div id="addModal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.4);z-index:2000;align-items:center;justify-content:center;">
    <div style="background:white;border-radius:12px;padding:32px;width:480px;max-width:90vw;">
        <h4 style="margin-bottom:24px;">Add New Staff Member</h4>
        <form method="post" action="/Admin/AddNhanVien">
            @Html.AntiForgeryToken()
            <div class="form-group">
                <label class="form-label">Full Name</label>
                <input type="text" name="HoVaTen" class="form-control" required>
            </div>
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;">
                <div class="form-group">
                    <label class="form-label">Position</label>
                    <input type="text" name="ChucVu" class="form-control">
                </div>
                <div class="form-group">
                    <label class="form-label">Gender</label>
                    <select name="GioiTinh" class="form-control form-select">
                        <option value="Nam">Nam</option>
                        <option value="Nu">Nữ</option>
                    </select>
                </div>
            </div>
            <div class="form-group">
                <label class="form-label">Center</label>
                <select name="MaTrungTam" class="form-control form-select">
                    <option value="">— Select Center —</option>
                    @if (ViewBag.TrungTams != null)
                    {
                        @foreach (var tt in (IEnumerable<BTL_Web.Models.TrungTam>)ViewBag.TrungTams)
                        {
                            <option value="@tt.MaTrungTam">@tt.TenTrungTam</option>
                        }
                    }
                </select>
            </div>
            <div style="display:flex;gap:12px;justify-content:flex-end;margin-top:24px;">
                <button type="button" class="btn-outline" onclick="document.getElementById('addModal').style.display='none'">Cancel</button>
                <button type="submit" class="btn-primary">Add Staff</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
<script>
document.querySelectorAll('.filter-btn').forEach(btn => {
    btn.addEventListener('click', function() {
        document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
        this.classList.add('active');
    });
});
</script>
}
