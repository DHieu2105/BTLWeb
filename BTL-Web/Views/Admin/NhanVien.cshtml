@model IEnumerable<BTL_Web.Models.NhanVien>
@{
    ViewData["Title"] = "Quản lý nhân viên";
    var currentPage = ViewBag.Page != null ? (int)ViewBag.Page : 1;
    var totalPages = ViewBag.TotalPages != null ? (int)ViewBag.TotalPages : 1;
    var pageSize = ViewBag.PageSize != null ? (int)ViewBag.PageSize : 10;
    var keyword = ViewBag.Keyword as string ?? "";
    var center = ViewBag.Center as string ?? "";
    var totalItems = ViewBag.TotalItems != null ? (int)ViewBag.TotalItems : (Model?.Count() ?? 0);
    var trungTams = ViewBag.TrungTams as IEnumerable<BTL_Web.Models.TrungTam> ?? new List<BTL_Web.Models.TrungTam>();
}

<div class="page-header">
    <div>
        <h2>Quản lý nhân viên</h2>
        <p>@totalItems bản ghi nhân viên trong hệ thống</p>
    </div>
    <div class="page-actions">
        <form method="get" style="display:flex;gap:8px;align-items:center;">
            <input class="form-control" type="text" name="keyword" value="@keyword" placeholder="Tìm nhân viên..." style="width:220px;" />
            <select class="form-control form-select" name="center" style="width:180px;">
                <option value="">Tất cả trung tâm</option>
                @foreach (var tt in trungTams)
                {
                    if (tt.MaTrungTam == center)
                    {
                        <option value="@tt.MaTrungTam" selected>@tt.TenTrungTam</option>
                    }
                    else
                    {
                        <option value="@tt.MaTrungTam">@tt.TenTrungTam</option>
                    }
                }
            </select>
            <select class="form-control form-select" name="pageSize" style="width:110px;">
                @foreach (var size in new[] { 10, 20, 50 })
                {
                    if (size == pageSize)
                        {
                            <option value="@size" selected>@size / trang</option>
                        }
                        else
                        {
                            <option value="@size">@size / trang</option>
                        }
                }
            </select>
            <button class="btn-outline" type="submit"><i class="fas fa-filter"></i> Lọc</button>
        </form>
        <button class="btn-primary" onclick="document.getElementById('addModal').style.display='flex'">
            <i class="fas fa-plus"></i> Thêm nhân viên
        </button>
    </div>
</div>

@if (TempData["Success"] is string success)
{
    <div class="alert alert-success" style="margin-bottom:16px;">@success</div>
}
@if (TempData["Error"] is string error)
{
    <div class="alert alert-danger" style="margin-bottom:16px;">@error</div>
}

<div class="stats-grid" style="grid-template-columns:repeat(4,1fr);margin-bottom:24px;">
    <div class="stat-card blue">
        <div class="stat-card-header"><div class="stat-icon blue"><i class="fas fa-users"></i></div></div>
        <div class="stat-label">Tổng nhân sự</div>
        <div class="stat-value">@totalItems</div>
    </div>
    <div class="stat-card teal">
        <div class="stat-card-header"><div class="stat-icon teal"><i class="fas fa-user-tie"></i></div></div>
        <div class="stat-label">Giảng viên đang hoạt động</div>
        <div class="stat-value">86</div>
    </div>
    <div class="stat-card orange">
        <div class="stat-card-header"><div class="stat-icon orange"><i class="fas fa-building"></i></div></div>
        <div class="stat-label">Phủ phòng ban</div>
        <div class="stat-value">12</div>
    </div>
    <div class="stat-card green">
        <div class="stat-card-header"><div class="stat-icon blue"><i class="fas fa-headset"></i></div></div>
        <div class="stat-label">Nhân viên hỗ trợ</div>
        <div class="stat-value">38</div>
    </div>
</div>

<div class="card-plain" style="padding:0;">
    <div class="card-header-plain">
        <h5>Danh bạ nhân viên</h5>
        <a href="@Url.Action("NhanVien")" class="small" style="color:var(--primary);font-weight:700;text-decoration:none;">Xóa lọc</a>
    </div>
    <table class="data-table">
        <thead>
            <tr>
                <th>Nhân viên</th>
                <th>Chức vụ</th>
                <th>Trung tâm</th>
                <th>Giới tính</th>
                <th>Trạng thái</th>
                <th style="text-align:right;">Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                @foreach (var nv in Model)
                {
                    var name = nv.HoVaTen ?? nv.MaNv;
                    var initials = string.Join("", name.Split(' ').Take(2).Select(w => w.FirstOrDefault().ToString().ToUpper()));
                    <tr>
                        <td>
                            <div class="user-row">
                                <div class="avatar">@initials</div>
                                <div>
                                    <div class="user-name">@name</div>
                                    <div class="user-sub">@nv.MaNv</div>
                                </div>
                            </div>
                        </td>
                        <td>@(nv.ChucVu ?? "—")</td>
                        <td>@(nv.MaTrungTamNavigation?.TenTrungTam ?? nv.MaTrungTam ?? "—")</td>
                        <td class="user-sub">@(nv.GioiTinh ?? "—")</td>
                        <td><span class="chip chip-green">Đang hoạt động</span></td>
                        <td style="text-align:right;">
                            <div style="display:flex;gap:4px;justify-content:flex-end;">
                                <button class="btn-icon btn-outline btn-sm"
                                        data-id="@nv.MaNv"
                                        data-name="@nv.HoVaTen"
                                        data-role="@nv.ChucVu"
                                        data-gender="@nv.GioiTinh"
                                        data-center="@nv.MaTrungTam"
                                        onclick="openEditStaff(this)">
                                    <i class="fas fa-edit"></i>
                                </button>
                                <form method="post" action="/Admin/DeleteNhanVien" style="display:inline;" onsubmit="return confirm('Bạn có chắc muốn xóa nhân viên @nv.MaNv?');">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@nv.MaNv" />
                                    <button type="submit" class="btn-icon btn-outline btn-sm">
                                        <i class="fas fa-trash" style="color:#ef4444;"></i>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr><td colspan="6"><div class="empty-state"><i class="fas fa-users-cog"></i><p>Không tìm thấy nhân viên nào</p></div></td></tr>
            }
        </tbody>
    </table>
    <div class="pagination-bar">
        <span class="pagination-info">Trang @currentPage / @totalPages</span>
        <div class="pagination-btns">
            <a class="page-btn" href="@Url.Action("NhanVien", new { page = currentPage > 1 ? currentPage - 1 : 1, pageSize, keyword, center })"><i class="fas fa-chevron-left" style="font-size:10px;"></i></a>
            @for (var i = 1; i <= totalPages; i++)
            {
                if (i == currentPage)
                {
                    <button class="page-btn active">@i</button>
                }
                else
                {
                    <a class="page-btn" href="@Url.Action("NhanVien", new { page = i, pageSize, keyword, center })">@i</a>
                }
            }
            <a class="page-btn" href="@Url.Action("NhanVien", new { page = currentPage < totalPages ? currentPage + 1 : totalPages, pageSize, keyword, center })"><i class="fas fa-chevron-right" style="font-size:10px;"></i></a>
        </div>
    </div>
</div>

<div id="addModal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.4);z-index:2000;align-items:center;justify-content:center;">
    <div style="background:white;border-radius:12px;padding:32px;width:480px;max-width:90vw;">
        <h4 style="margin-bottom:24px;">Thêm nhân viên mới</h4>
        <form method="post" action="/Admin/AddNhanVien">
            @Html.AntiForgeryToken()
            <div class="form-group">
                <label class="form-label">Họ và tên</label>
                <input type="text" name="HoVaTen" class="form-control" required>
            </div>
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;">
                <div class="form-group">
                    <label class="form-label">Chức vụ</label>
                    <input type="text" name="ChucVu" class="form-control">
                </div>
                <div class="form-group">
                    <label class="form-label">Giới tính</label>
                    <select name="GioiTinh" class="form-control form-select">
                        <option value="Nam">Nam</option>
                        <option value="Nữ">Nữ</option>
                    </select>
                </div>
            </div>
            <div class="form-group">
                <label class="form-label">Trung tâm</label>
                <select name="MaTrungTam" class="form-control form-select">
                    <option value="">— Chọn trung tâm —</option>
                    @if (ViewBag.TrungTams != null)
                    {
                        @foreach (var tt in (IEnumerable<BTL_Web.Models.TrungTam>)ViewBag.TrungTams)
                        {
                            <option value="@tt.MaTrungTam">@tt.TenTrungTam</option>
                        }
                    }
                </select>
            </div>
            <div style="display:flex;gap:12px;justify-content:flex-end;margin-top:24px;">
                <button type="button" class="btn-outline" onclick="document.getElementById('addModal').style.display='none'">Hủy</button>
                <button type="submit" class="btn-primary">Thêm nhân viên</button>
            </div>
        </form>
    </div>
</div>

<div id="editModal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.4);z-index:2000;align-items:center;justify-content:center;">
    <div style="background:white;border-radius:12px;padding:32px;width:480px;max-width:90vw;">
        <h4 style="margin-bottom:24px;">Sửa nhân viên</h4>
        <form method="post" action="/Admin/UpdateNhanVien">
            @Html.AntiForgeryToken()
            <input type="hidden" id="editMaNv" name="MaNv" />
            <div class="form-group">
                <label class="form-label">Mã nhân viên</label>
                <input type="text" id="editMaNvDisplay" class="form-control" readonly>
            </div>
            <div class="form-group">
                <label class="form-label">Họ và tên</label>
                <input type="text" id="editHoVaTen" name="HoVaTen" class="form-control" required>
            </div>
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;">
                <div class="form-group">
                    <label class="form-label">Chức vụ</label>
                    <input type="text" id="editChucVu" name="ChucVu" class="form-control">
                </div>
                <div class="form-group">
                    <label class="form-label">Giới tính</label>
                    <select id="editGioiTinh" name="GioiTinh" class="form-control form-select">
                        <option value="">— Chọn —</option>
                        <option value="Nam">Nam</option>
                        <option value="Nữ">Nữ</option>
                    </select>
                </div>
            </div>
            <div class="form-group">
                <label class="form-label">Trung tâm</label>
                <select id="editMaTrungTam" name="MaTrungTam" class="form-control form-select">
                    <option value="">— Chọn trung tâm —</option>
                    @foreach (var tt in trungTams)
                    {
                        <option value="@tt.MaTrungTam">@tt.TenTrungTam</option>
                    }
                </select>
            </div>
            <div style="display:flex;gap:12px;justify-content:flex-end;margin-top:24px;">
                <button type="button" class="btn-outline" onclick="document.getElementById('editModal').style.display='none'">Hủy</button>
                <button type="submit" class="btn-primary">Lưu</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
<script>
function openEditStaff(btn) {
    document.getElementById('editMaNv').value = btn.dataset.id || '';
    document.getElementById('editMaNvDisplay').value = btn.dataset.id || '';
    document.getElementById('editHoVaTen').value = btn.dataset.name || '';
    document.getElementById('editChucVu').value = btn.dataset.role || '';
    document.getElementById('editGioiTinh').value = btn.dataset.gender || '';
    document.getElementById('editMaTrungTam').value = btn.dataset.center || '';
    document.getElementById('editModal').style.display = 'flex';
}
</script>
}
